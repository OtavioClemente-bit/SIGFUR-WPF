<Window x:Class="SIGFUR.Wpf.Views.Military.MilitaryWalletWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SIGFUR.Wpf.Controls"
        Title="SIGFUR — Carteira do Militar" Width="1240" Height="820" MinWidth="980" MinHeight="650"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResize" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico"
        Loaded="Window_Loaded" MouseDoubleClick="Window_MouseDoubleClick">
<Grid>
        <Grid.RowDefinitions><RowDefinition Height="46"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="34"/></Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="14,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Image Source="/Assets/sigfur.png" Width="28" Height="28" Stretch="Uniform" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="CARTEIRA DO MILITAR" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="Dados, documentos e contracheques" FontSize="10" Foreground="{DynamicResource MutedBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Cabeçalho da carteira -->
        <Border Grid.Row="1" Margin="16,14,16,10" Background="{DynamicResource PrimaryDarkBrush}" CornerRadius="15" Padding="18">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="16"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <Border Width="102" Height="124" Background="{DynamicResource SurfaceBrush}" CornerRadius="12" ClipToBounds="True">
                    <Grid><TextBlock Text="SEM FOTO" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource SubtleTextBrush}" FontWeight="SemiBold"/><Image x:Name="HeaderPhoto" Source="{Binding Military.PhotoPath}" Stretch="UniformToFill"/></Grid>
                </Border>
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Military.ShortRank}" Foreground="{DynamicResource TextOnPrimaryMutedBrush}" FontSize="13" FontWeight="SemiBold"/>
                    <controls:HighlightedNameTextBlock FullName="{Binding Military.Name}" WarName="{Binding Military.WarName}" Foreground="{DynamicResource TextOnPrimaryBrush}" FontSize="26" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,3,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Border Background="#22FFFFFF" CornerRadius="12" Padding="9,4" Margin="0,0,7,0"><TextBlock Text="{Binding Military.FormattedCpf}" Foreground="White" FontWeight="SemiBold"/></Border>
                        <Border Background="#22FFFFFF" CornerRadius="12" Padding="9,4" Margin="0,0,7,0"><TextBlock Foreground="White"><Run Text="PREC "/><Run Text="{Binding Military.PrecCp, Mode=OneWay}" FontWeight="SemiBold"/></TextBlock></Border>
                        <Border Background="#22FFFFFF" CornerRadius="12" Padding="9,4"><TextBlock Foreground="White"><Run Text="IDT "/><Run Text="{Binding Military.MilitaryId, Mode=OneWay}" FontWeight="SemiBold"/></TextBlock></Border>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="3" VerticalAlignment="Center" MinWidth="180">
                    <Button Style="{StaticResource LightOnDarkButtonStyle}" Content="Editar cadastro" Click="Edit_Click" Margin="0,0,0,8"/>
                    <Button Style="{StaticResource LightOnDarkButtonStyle}" Content="Copiar resumo" Click="CopySummary_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Margin="16,0,16,12" Style="{StaticResource CardStyle}" Padding="0">
            <TabControl x:Name="WalletTabs" SelectionChanged="WalletTabs_SelectionChanged">
                <TabItem Header="Resumo">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="20">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <Border Style="{StaticResource SoftCardStyle}" Padding="16" Margin="0,0,0,14">
                                    <StackPanel><TextBlock Text="Identificação e contato" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,12"/>
                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                            <TextBlock Text="Telefone" Style="{StaticResource CaptionTextStyle}"/><TextBlock Grid.Column="1" Text="{Binding Military.Phone, FallbackValue='Não informado'}" Foreground="{DynamicResource TextBrush}"/>
                                            <TextBlock Grid.Row="1" Text="E-mail" Style="{StaticResource CaptionTextStyle}" Margin="0,10,0,0"/><TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Military.Email, FallbackValue='Não informado'}" Foreground="{DynamicResource TextBrush}" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                            <TextBlock Grid.Row="2" Text="Nascimento" Style="{StaticResource CaptionTextStyle}" Margin="0,10,0,0"/><TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Military.BirthDate, FallbackValue=—}" Foreground="{DynamicResource TextBrush}" Margin="0,10,0,0"/>
                                            <TextBlock Grid.Row="3" Text="Data de praça" Style="{StaticResource CaptionTextStyle}" Margin="0,10,0,0"/><TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Military.EnlistmentDate, FallbackValue=—}" Foreground="{DynamicResource TextBrush}" Margin="0,10,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource SoftCardStyle}" Padding="16">
                                    <StackPanel><TextBlock Text="Endereço" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,10"/><TextBlock Text="{Binding Military.Address, FallbackValue='Não informado'}" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}"/><TextBlock Text="{Binding Military.ZipCode, StringFormat='CEP: {0}'}" Foreground="{DynamicResource MutedBrush}" Margin="0,7,0,0"/></StackPanel>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Border Style="{StaticResource SoftCardStyle}" Padding="16" Margin="0,0,0,14">
                                    <StackPanel><TextBlock Text="Dados bancários" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,12"/>
                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                            <TextBlock Text="Banco" Style="{StaticResource CaptionTextStyle}"/><TextBlock Grid.Column="1" Text="{Binding Military.Bank, FallbackValue=—}" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"/>
                                            <TextBlock Grid.Row="1" Text="Agência" Style="{StaticResource CaptionTextStyle}" Margin="0,10,0,0"/><TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Military.Agency, FallbackValue=—}" Margin="0,10,0,0"/>
                                            <TextBlock Grid.Row="2" Text="Conta" Style="{StaticResource CaptionTextStyle}" Margin="0,10,0,0"/><TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Military.Account, FallbackValue=—}" Margin="0,10,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource SoftCardStyle}" Padding="16">
                                    <StackPanel><TextBlock Text="Benefícios" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,12"/>
                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                            <TextBlock Text="Pré-Escolar" Style="{StaticResource CaptionTextStyle}"/><TextBlock Grid.Column="1" Text="{Binding Military.ReceivesPreSchool}" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Row="1" Text="Auxílio-Transporte" Style="{StaticResource CaptionTextStyle}" Margin="0,10,0,0"/><TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Military.TransportStatus}" FontWeight="SemiBold" Margin="0,10,0,0"/>
                                            <TextBlock Grid.Row="2" Text="PNR" Style="{StaticResource CaptionTextStyle}" Margin="0,10,0,0"/><TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Military.PnrStatus}" FontWeight="SemiBold" Margin="0,10,0,0"/>
                                            <TextBlock Grid.Row="3" Text="Pensão alimentícia" Style="{StaticResource CaptionTextStyle}" Margin="0,10,0,0"/><TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Military.Alimony}" FontWeight="SemiBold" Margin="0,10,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Documentos">
                    <Grid Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,14"><StackPanel Orientation="Horizontal" DockPanel.Dock="Left"><Button Style="{StaticResource PrimaryButtonStyle}" Content="＋ Incluir documento" Click="AddDocument_Click" Margin="0,0,7,0"/><Button Style="{StaticResource SecondaryButtonStyle}" Content="Abrir arquivo" Click="OpenDocument_Click" Margin="0,0,7,0"/><Button Style="{StaticResource SecondaryButtonStyle}" Content="Abrir pasta" Click="OpenDocumentFolder_Click" Margin="0,0,7,0"/><Button Style="{StaticResource SecondaryButtonStyle}" Content="Ler certidão / OCR" Click="ReprocessDocumentOcr_Click"/></StackPanel><Button DockPanel.Dock="Right" Style="{StaticResource DangerButtonStyle}" Content="Remover da carteira" Click="RemoveDocument_Click" Margin="28,0,0,0"/></DockPanel>
                        <DataGrid x:Name="DocumentsGrid" Grid.Row="1" ItemsSource="{Binding Documents}" SelectedItem="{Binding SelectedDocument}" IsReadOnly="True" MouseDoubleClick="DocumentsGrid_MouseDoubleClick">
                            <DataGrid.Columns><DataGridTextColumn Header="Tipo" Binding="{Binding Type}" Width="160"/><DataGridTextColumn Header="Título" Binding="{Binding Title}" Width="2*"/><DataGridTextColumn Header="Salvo em" Binding="{Binding SavedAt}" Width="145"/><DataGridTextColumn Header="Arquivo" Binding="{Binding FileName, Mode=OneWay}" Width="2*"/><DataGridTextColumn Header="OCR / Chaves" Binding="{Binding OcrStatus, Mode=OneWay}" Width="130"/><DataGridTextColumn Header="Situação" Binding="{Binding Status, Mode=OneWay}" Width="145"/></DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="Auxílio-Transporte">
                    <Grid Margin="18"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="360"/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <DockPanel Margin="0,0,0,10"><TextBlock Text="Auxílio-Transporte — cadastro único" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center"/><StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><Button Style="{StaticResource SecondaryButtonStyle}" Content="＋ Linha" Click="AddFare_Click" Margin="0,0,7,0"/><Button Style="{StaticResource GhostButtonStyle}" Content="Remover" Click="RemoveFare_Click"/></StackPanel></DockPanel>
                            <DataGrid x:Name="FaresGrid" ItemsSource="{Binding Transport.Fares}" AutoGenerateColumns="False" IsReadOnly="False" CanUserAddRows="False" CanUserResizeColumns="True" CanUserReorderColumns="True" MinHeight="220">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding DisplayIndex}" Width="46" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Nº / linha" Binding="{Binding Number, UpdateSourceTrigger=PropertyChanged}" Width="105"/>
                                    <DataGridTextColumn Header="Nome / trajeto" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="2*" MinWidth="220"/>
                                    <DataGridTextColumn Header="Categoria" Binding="{Binding Category, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                                    <DataGridTextColumn Header="1 passagem" Binding="{Binding Fare, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="110"/>
                                    <DataGridTextColumn Header="Ida + volta" Binding="{Binding RoundTripFormatted}" Width="115" IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0"><TextBlock Text="Dias úteis:" VerticalAlignment="Center" Style="{StaticResource CaptionTextStyle}" Margin="0,0,7,0"/><TextBox x:Name="WorkingDaysBox" Width="90" Text="{Binding Transport.WorkingDays}"/><Button Style="{StaticResource PrimaryButtonStyle}" Content="Recalcular e salvar" Click="SaveFares_Click" Margin="12,0,0,0"/></StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <Border Style="{StaticResource SoftCardStyle}" Padding="17" Margin="0,0,0,12"><StackPanel><TextBlock Text="Resumo do cálculo" Style="{StaticResource SectionTitleStyle}"/><TextBlock Text="{Binding Transport.Status}" Foreground="{DynamicResource MutedBrush}" Margin="0,3,0,14"/>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <TextBlock Text="Quantidade de ônibus" Style="{StaticResource CaptionTextStyle}"/><TextBlock Grid.Column="1" Text="{Binding Transport.Fares.Count}" FontWeight="Bold"/>
                                    <TextBlock Grid.Row="1" Text="Bruto por dia" Style="{StaticResource CaptionTextStyle}" Margin="0,10,0,0"/><TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Transport.GrossPerDayText}" FontWeight="Bold" Margin="0,10,0,0"/>
                                    <TextBlock Grid.Row="2" Text="Bruto mensal" Style="{StaticResource CaptionTextStyle}" Margin="0,10,0,0"/><TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Transport.GrossPerMonthText}" FontWeight="Bold" Margin="0,10,0,0"/>
                                    <TextBlock Grid.Row="3" Text="Cota-parte (6%)" Style="{StaticResource CaptionTextStyle}" Margin="0,10,0,0"/><TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Transport.ShareText}" FontWeight="Bold" Margin="0,10,0,0"/>
                                </Grid></StackPanel></Border>
                            <Border Background="{DynamicResource PrimarySoftBrush}" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1" CornerRadius="12" Padding="17"><StackPanel><TextBlock Text="LÍQUIDO MENSAL" Style="{StaticResource MetricCaptionStyle}"/><TextBlock Text="{Binding Transport.NetPerMonthText}" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource PrimaryDarkBrush}" Margin="0,4,0,0"/><TextBlock Text="{Binding Transport.NetPerDayText}" Foreground="{DynamicResource MutedBrush}" Margin="0,5,0,0"/></StackPanel></Border>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="Tempo de Serviço">
                    <Grid Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <Border Style="{StaticResource SoftCardStyle}" Padding="14" Margin="0,0,0,10"><Grid><TextBlock Text="{Binding TotalServiceText}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryDarkBrush}"/><Button HorizontalAlignment="Right" Style="{StaticResource PrimaryButtonStyle}" Content="＋ Novo intervalo" Click="NewInterval_Click"/></Grid></Border>
                        <DataGrid x:Name="ServiceIntervalsGrid" Grid.Row="1" ItemsSource="{Binding ServiceIntervals}" SelectedItem="{Binding SelectedInterval}" IsReadOnly="True" MouseDoubleClick="IntervalsGrid_MouseDoubleClick">
                            <DataGrid.Columns><DataGridTextColumn Header="Início" Binding="{Binding StartDate}" Width="130"/><DataGridTextColumn Header="Fim" Binding="{Binding EndDate}" Width="130"/><DataGridTextColumn Header="Dias" Binding="{Binding FormattedDays, Mode=OneWay}" Width="120"/><DataGridTextColumn Header="Observação" Binding="{Binding Observation}" Width="*"/></DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0"><Button Style="{StaticResource SecondaryButtonStyle}" Content="Editar selecionado" Click="EditInterval_Click" Margin="0,0,7,0"/><Button Style="{StaticResource DangerButtonStyle}" Content="Excluir selecionado" Click="DeleteInterval_Click"/></StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="Controle de Férias">
                    <Grid Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Border Style="{StaticResource SoftCardStyle}" Padding="14" Margin="0,0,0,10"><StackPanel><TextBlock Text="PAGAMENTO DAS FÉRIAS" Style="{StaticResource SectionTitleStyle}"/><TextBlock Text="Mostra se o pagamento foi registrado e a data exata da conferência. A marcação é feita no Plano de Férias." Style="{StaticResource SubtleTextStyle}" Margin="0,4,0,0" TextWrapping="Wrap"/></StackPanel></Border>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding VacationPayments}" IsReadOnly="True" AutoGenerateColumns="False" RowHeight="38">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#B71C1C"/>
                                    <Setter Property="Background" Value="#FFFFCDD2"/>
                                    <Setter Property="BorderBrush" Value="#FFD32F2F"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPaid}" Value="True">
                                            <Setter Property="Foreground" Value="#FF1B5E20"/>
                                            <Setter Property="Background" Value="#FFC8E6C9"/>
                                            <Setter Property="BorderBrush" Value="#FF2E7D32"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                            <DataGridTextColumn Header="Ano" Binding="{Binding Year}" Width="80"/><DataGridTextColumn Header="Período" Binding="{Binding Period}" Width="*"/><DataGridTextColumn Header="Dias" Binding="{Binding Days}" Width="70"/><DataGridTextColumn Header="Pagamento" Binding="{Binding Status}" Width="110"/><DataGridTextColumn Header="Registrado em" Binding="{Binding PaidAtText}" Width="155"/>
                        </DataGrid.Columns></DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="Menções em Boletins">
                    <Grid Margin="16">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Border Style="{StaticResource SoftCardStyle}" Padding="14" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="MENÇÕES ENCONTRADAS PARA O MILITAR" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Boletim Interno e Aditamento do Furriel são mostrados separadamente. Duplo clique abre o PDF e pesquisa automaticamente o nome completo." Style="{StaticResource SubtleTextStyle}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <WrapPanel Grid.Row="1" Margin="0,0,0,10">
                            <TextBlock Text="Ano" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox Width="110" ItemsSource="{Binding MentionYearOptions}" SelectedItem="{Binding SelectedMentionYear}" Margin="0,0,14,0"/>
                            <TextBlock Text="Mês" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox Width="145" ItemsSource="{Binding MentionMonthOptions}" SelectedItem="{Binding SelectedMentionMonth}" Margin="0,0,14,0"/>
                            <TextBlock Text="Pesquisa rápida" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Width="260" Text="{Binding MentionSearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Digite férias, PNR, auxílio, nº da nota, BI ou qualquer termo do assunto/nota." Margin="0,0,14,0"/>
                            <Button Content="↻ Atualizar menções" Style="{StaticResource SecondaryButtonStyle}" Click="RefreshMentions_Click"/>
                        </WrapPanel>
                        <TabControl Grid.Row="2">
                            <TabItem Header="Boletim Interno">
                                <Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <DataGrid x:Name="InternalMentionsGrid" ItemsSource="{Binding InternalBulletinMentions}" SelectedItem="{Binding SelectedMention}" IsReadOnly="True" AutoGenerateColumns="False" MouseDoubleClick="MentionsGrid_MouseDoubleClick">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Data" Binding="{Binding Date}" Width="92"/>
                                            <DataGridTextColumn Header="BI" Binding="{Binding Bulletin}" Width="96"/>
                                            <DataGridTextColumn Header="Nº Nota" Binding="{Binding Category}" Width="88"/>
                                            <DataGridTextColumn Header="Assunto" Binding="{Binding Subject}" Width="1.6*"/>
                                            <DataGridTextColumn Header="Nota/Tipo" Binding="{Binding SubjectNote}" Width="1.25*"/>
                                            <DataGridTextColumn Header="Página" Binding="{Binding Page}" Width="58"/>
                                            <DataGridTextColumn Header="Origem" Binding="{Binding OriginDisplay}" Width="88"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                        <Button Content="Copiar registro" Style="{StaticResource SecondaryButtonStyle}" Click="CopyMention_Click" Margin="0,0,8,0"/>
                                        <Button Content="Abrir e pesquisar nome" Style="{StaticResource PrimaryButtonStyle}" Click="OpenMention_Click"/>
                                    </StackPanel>
                                </Grid>
                            </TabItem>
                            <TabItem Header="Aditamento Furriel">
                                <Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <DataGrid x:Name="FurrielMentionsGrid" ItemsSource="{Binding FurrielAddendumMentions}" SelectedItem="{Binding SelectedMention}" IsReadOnly="True" AutoGenerateColumns="False" MouseDoubleClick="MentionsGrid_MouseDoubleClick">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Data" Binding="{Binding Date}" Width="92"/>
                                            <DataGridTextColumn Header="ADT" Binding="{Binding Bulletin}" Width="96"/>
                                            <DataGridTextColumn Header="Assunto" Binding="{Binding Subject}" Width="1.7*"/>
                                            <DataGridTextColumn Header="Nota/Tipo" Binding="{Binding SubjectNote}" Width="1.35*"/>
                                            <DataGridTextColumn Header="Consequência" Binding="{Binding ConsequenceDisplay}" Width="92"/>
                                            <DataGridTextColumn Header="Página" Binding="{Binding Page}" Width="58"/>
                                            <DataGridTextColumn Header="Origem" Binding="{Binding OriginDisplay}" Width="96"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                        <Button Content="Copiar registro" Style="{StaticResource SecondaryButtonStyle}" Click="CopyMention_Click" Margin="0,0,8,0"/>
                                        <Button Content="Abrir e pesquisar nome" Style="{StaticResource PrimaryButtonStyle}" Click="OpenMention_Click"/>
                                    </StackPanel>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </TabItem>

                <TabItem Header="Contracheques">
                    <Grid Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,10"><WrapPanel><TextBlock Text="Ano" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" Margin="0,0,6,0"/><ComboBox Width="105" ItemsSource="{Binding PaystubYearOptions}" SelectedItem="{Binding SelectedPaystubYear}" Margin="0,0,10,0"/><Button Style="{StaticResource SecondaryButtonStyle}" Content="↻ Atualizar lista" Click="RefreshPaystubs_Click" Margin="0,0,7,0"/><Button Style="{StaticResource SecondaryButtonStyle}" Content="Abrir PDF" Click="OpenPaystub_Click" Margin="0,0,7,0"/><Button Style="{StaticResource SecondaryButtonStyle}" Content="Abrir pasta" Click="OpenPaystubFolder_Click" Margin="0,0,7,0"/><Button Style="{StaticResource DangerButtonStyle}" Content="Excluir PDF" Click="DeletePaystub_Click"/></WrapPanel><TextBlock DockPanel.Dock="Right" Text="Somente consulta • duplo clique abre" Style="{StaticResource SubtleTextStyle}" VerticalAlignment="Center"/></DockPanel>
                        <DataGrid x:Name="PaystubsGrid" Grid.Row="1" ItemsSource="{Binding Paystubs}" SelectedItem="{Binding SelectedPaystub}" IsReadOnly="True" MouseDoubleClick="PaystubsGrid_MouseDoubleClick">
                            <DataGrid.Columns><DataGridTextColumn Header="Referência" Binding="{Binding Reference}" Width="115"/><DataGridTextColumn Header="Arquivo" Binding="{Binding FileName, Mode=OneWay}" Width="2*"/><DataGridTextColumn Header="Alterado em" Binding="{Binding ModifiedAt, StringFormat=dd/MM/yyyy HH:mm}" Width="155"/><DataGridTextColumn Header="Tamanho" Binding="{Binding SizeText, Mode=OneWay}" Width="100"/><DataGridTextColumn Header="Caminho" Binding="{Binding Path}" Width="3*"/></DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="Ficha Financeira">
                    <Grid Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,10"><StackPanel Orientation="Horizontal"><TextBlock Text="Ano" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" Margin="0,0,6,0"/><ComboBox Width="105" ItemsSource="{Binding FinancialStatementYearOptions}" SelectedItem="{Binding SelectedFinancialStatementYear}" Margin="0,0,10,0"/><Button Style="{StaticResource SecondaryButtonStyle}" Content="↻ Atualizar lista" Click="RefreshFinancialStatements_Click" Margin="0,0,7,0"/><Button Style="{StaticResource SecondaryButtonStyle}" Content="Abrir PDF" Click="OpenFinancialStatement_Click" Margin="0,0,7,0"/><Button Style="{StaticResource SecondaryButtonStyle}" Content="Abrir pasta" Click="OpenFinancialStatementFolder_Click" Margin="0,0,7,0"/><Button Style="{StaticResource DangerButtonStyle}" Content="Excluir ficha" Click="DeleteFinancialStatement_Click"/></StackPanel><TextBlock DockPanel.Dock="Right" Text="Somente consulta • duplo clique abre" Style="{StaticResource SubtleTextStyle}" VerticalAlignment="Center"/></DockPanel>
                        <DataGrid x:Name="FinancialStatementsGrid" Grid.Row="1" ItemsSource="{Binding FinancialStatements}" SelectedItem="{Binding SelectedFinancialStatement}" IsReadOnly="True" MouseDoubleClick="FinancialStatementsGrid_MouseDoubleClick">
                            <DataGrid.Columns><DataGridTextColumn Header="Referência" Binding="{Binding Reference}" Width="115"/><DataGridTextColumn Header="Arquivo" Binding="{Binding FileName, Mode=OneWay}" Width="2*"/><DataGridTextColumn Header="Alterado em" Binding="{Binding ModifiedAt, StringFormat=dd/MM/yyyy HH:mm}" Width="155"/><DataGridTextColumn Header="Tamanho" Binding="{Binding SizeText, Mode=OneWay}" Width="100"/><DataGridTextColumn Header="Caminho" Binding="{Binding Path}" Width="3*"/></DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>

        <Border Grid.Row="1" Grid.RowSpan="2" Background="{DynamicResource OverlayBrush}" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" Panel.ZIndex="100">
            <Border Width="430" Padding="28" CornerRadius="18" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderStrongBrush}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <Image Source="/Assets/sigfur.png" Width="76" Height="76" Stretch="Uniform" HorizontalAlignment="Center"/>
                    <TextBlock Text="Atualizando carteira" Style="{StaticResource SectionTitleStyle}" FontSize="19" HorizontalAlignment="Center" Margin="0,14,0,5"/>
                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource SubtleTextStyle}" TextAlignment="Center" TextWrapping="Wrap"/>
                    <ProgressBar IsIndeterminate="True" Height="8" Margin="0,18,0,0"/>
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.Row="3" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="14,0"><Grid><TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}"/><ProgressBar HorizontalAlignment="Right" Width="150" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/></Grid></Border>
    </Grid>
</Window>
