<Window x:Class="SIGFUR.Wpf.Views.Military.DocumentGenerationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIGFUR — Gerar documentação"
        Width="1180" Height="820" MinWidth="940" MinHeight="650"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner" Icon="/Assets/sigfur.ico"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource PrimaryDarkBrush}" Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="GERAR DOCUMENTAÇÃO" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="SelectionSummary" Foreground="#D9EAFE" Margin="0,3,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Background="#22FFFFFF" BorderBrush="#55FFFFFF" BorderThickness="1" CornerRadius="10" Padding="12,7" VerticalAlignment="Center" MaxWidth="430">
                    <TextBlock x:Name="TemplateStatusText" Foreground="White" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="295"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Tipo de documento" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,10"/>
                        <Button x:Name="TransportButton" Style="{StaticResource DocumentTypeButtonStyle}" Content="Auxílio-Transporte" Tag="TransportAid" Click="DocumentType_Click"/>
                        <Button x:Name="PecuniaryButton" Style="{StaticResource DocumentTypeButtonStyle}" Content="Pecuniária" Tag="PecuniaryCompensation" Click="DocumentType_Click"/>
                        <Button x:Name="PostalButton" Style="{StaticResource DocumentTypeButtonStyle}" Content="Correios / etiqueta" Tag="PostalLabel" Click="DocumentType_Click"/>
                        <Button x:Name="PaymentCopyButton" Style="{StaticResource DocumentTypeButtonStyle}" Content="Cópia autêntica de pagamento" Tag="AuthenticPaymentCopy" Click="DocumentType_Click"/>
                        <Button x:Name="ChristmasButton" Style="{StaticResource DocumentTypeButtonStyle}" Content="Adiantamento natalino" Tag="AdvanceChristmasBonus" Click="DocumentType_Click"/>
                        <Separator Margin="0,8,0,10"/>
                        <TextBlock Text="Modelos de Pensão, Grat Rep, EA e PHPM ficam dentro dos respectivos módulos." TextWrapping="Wrap" Style="{StaticResource SubtleTextStyle}" Margin="0,0,0,6"/>

                        <Separator Margin="0,8,0,14"/>
                        <TextBlock Text="Modelo do documento" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,7"/>
                        <TextBlock Text="Esta pasta é somente dos documentos do Listar Militares. Pensão, Grat Rep, Exercício Anterior e PHPM usam suas próprias telas e pastas de modelo." TextWrapping="Wrap" Style="{StaticResource SubtleTextStyle}"/>
                        <TextBlock x:Name="TemplateFolderText" TextWrapping="Wrap" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryDarkBrush}" Margin="0,8,0,0"/>
                        <TextBlock x:Name="SelectedTemplateText" Text="Automático" TextWrapping="Wrap" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryDarkBrush}" Margin="0,8,0,0"/>
                        <Button Style="{StaticResource PrimaryButtonStyle}" Content="Escolher modelo DOCX/ODT" Click="ChooseTemplate_Click" Margin="0,10,0,0"/>
                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="Usar localização automática" Click="UseAutomaticTemplate_Click" Margin="0,7,0,0"/>
                        <Button Style="{StaticResource SidebarActionButtonStyle}" Content="Abrir pasta de modelos" Click="OpenTemplates_Click" Margin="0,7,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="DocumentTitleText" Text="Documento" FontSize="21" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock x:Name="DocumentDescriptionText" Grid.Row="1" TextWrapping="Wrap" Style="{StaticResource SubtleTextStyle}" Margin="0,5,0,12"/>

                    <Border Grid.Row="2" Background="{DynamicResource PrimarySoftBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="NOMES E ASSINATURAS SALVOS" Style="{StaticResource MetricCaptionStyle}"/>
                                <TextBlock Text="O mesmo perfil pode ser usado em todos os documentos" Style="{StaticResource SubtleTextStyle}" FontSize="10"/>
                            </StackPanel>
                            <ComboBox x:Name="ProfileCombo" Grid.Column="2" DisplayMemberPath="DisplayLabel" VerticalAlignment="Center"/>
                            <WrapPanel Grid.Column="4" VerticalAlignment="Center">
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Aplicar" Click="ApplyProfile_Click" Margin="0,0,7,0"/>
                                <Button Style="{StaticResource PrimaryButtonStyle}" Content="+ Salvar nomes" Click="SaveProfile_Click" Margin="0,0,7,0"/>
                                <Button Style="{StaticResource DangerButtonStyle}" Content="Excluir" Click="DeleteProfile_Click"/>
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <Border x:Name="TransportToolsPanel" Grid.Row="3" Visibility="Collapsed" Background="#E8F5E9" BorderBrush="#A5D6A7" BorderThickness="1" CornerRadius="10" Padding="11" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="PREENCHIMENTO AUTOMÁTICO — AUXÍLIO-TRANSPORTE" FontSize="11" FontWeight="Bold" Foreground="#1B5E20"/>
                            <TextBlock Text="O posto/graduação será gerado por extenso e em maiúsculas (ex.: 3º SARGENTO). Endereço, ônibus, tarifas e cálculos são lidos silenciosamente do banco e não aparecem como campos manuais." Style="{StaticResource SubtleTextStyle}" TextWrapping="Wrap" Margin="0,3,0,8"/>
                            <WrapPanel>
                                <CheckBox x:Name="UseTransportAddressCheck" Content="Preencher endereço pelo banco" IsChecked="True" Margin="0,0,18,6" Checked="TransportOption_Changed" Unchecked="TransportOption_Changed"/>
                                <CheckBox x:Name="UseTransportBusesCheck" Content="Preencher ônibus, tarifas e valores pelo banco" IsChecked="True" Margin="0,0,18,6" Checked="TransportOption_Changed" Unchecked="TransportOption_Changed"/>
                                <Button x:Name="ReloadTransportButton" Style="{StaticResource SecondaryButtonStyle}" Content="Atualizar dados automáticos" Click="ReloadTransport_Click" Margin="0,0,0,6"/>
                            </WrapPanel>
                            <TextBlock x:Name="TransportOptionsStatusText" Foreground="#2E7D32" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="PostalToolsPanel" Grid.Row="3" Visibility="Collapsed" Background="#FFF8E1" BorderBrush="#FFE0A3" BorderThickness="1" CornerRadius="10" Padding="11" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="BASE DE ENDEREÇOS DAS ORGANIZAÇÕES MILITARES" FontSize="11" FontWeight="Bold" Foreground="#6D4C41"/>
                            <TextBlock Text="Pesquise uma OM, aplique os dados no formulário ou salve/atualize o endereço preenchido. A sincronização só ocorre quando você clicar no botão." Style="{StaticResource SubtleTextStyle}" TextWrapping="Wrap" Margin="0,3,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="210"/>
                                    <ColumnDefinition Width="7"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="7"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="PostalSearchBox" ToolTip="Digite nome, sigla, cidade ou CEP da OM. A lista é filtrada automaticamente." KeyDown="PostalSearchBox_KeyDown" TextChanged="PostalSearchBox_TextChanged"/>
                                <ComboBox x:Name="PostalOmCombo" Grid.Column="2" DisplayMemberPath="DisplayLabel" IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" SelectionChanged="PostalOmCombo_SelectionChanged" KeyUp="PostalOmCombo_KeyUp" ToolTip="Digite ou escolha a OM cadastrada de destino."/>
                                <Button Grid.Column="4" Style="{StaticResource SecondaryButtonStyle}" Content="Pesquisar" Click="SearchPostal_Click"/>
                            </Grid>
                            <WrapPanel Margin="0,8,0,0">
                                <Button Style="{StaticResource PrimaryButtonStyle}" Content="Aplicar OM no formulário" Click="ApplyPostalOm_Click" Margin="0,0,7,0"/>
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="+ Salvar / atualizar OM" Click="SavePostalOm_Click" Margin="0,0,7,0"/>
                                <Button x:Name="SyncPostalButton" Style="{StaticResource SecondaryButtonStyle}" Content="Sincronizar base oficial" Click="SyncPostal_Click"/>
                                <TextBlock x:Name="PostalStatusText" VerticalAlignment="Center" Foreground="#6D4C41" Margin="12,0,0,0"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="DynamicFormPanel" Margin="0,0,8,0"/>
                    </ScrollViewer>

                    <Border Grid.Row="5" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="10" Padding="12" Margin="0,12,0,0">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <TextBlock Text="Pasta de saída" Style="{StaticResource CaptionTextStyle}"/>
                            <Grid Grid.Row="1" Margin="0,5,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="7"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBox x:Name="OutputFolderBox"/>
                                <Button Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}" Content="Escolher pasta" Click="ChooseOutput_Click"/>
                                <Button Grid.Column="4" Style="{StaticResource SecondaryButtonStyle}" Content="Abrir pasta" Click="OpenOutput_Click"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox x:Name="OpenAfterCheck" Content="Abrir documento após gerar" IsChecked="True" Margin="0,0,18,0"/>
                    <CheckBox x:Name="PrintAfterCheck" Content="Escolher impressora e imprimir" ToolTip="Após gerar, abre a fila com a seleção de impressora."/>
                    <TextBlock x:Name="StatusText" Foreground="{DynamicResource MutedBrush}" Margin="18,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Fechar" Click="Close_Click" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="+ Salvar preenchimento" Click="SaveForm_Click" Margin="0,0,8,0"/>
                    <Button x:Name="GenerateButton" Style="{StaticResource PrimaryButtonStyle}" Content="Gerar documento(s)" Click="Generate_Click" MinWidth="170"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
