<Window x:Class="SIGFUR.Wpf.Views.Military.CopyFormatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIGFUR — Copiar formato" Width="760" Height="650" MinWidth="620" MinHeight="520"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResize" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="86"/><RowDefinition Height="*"/><RowDefinition Height="64"/></Grid.RowDefinitions>
        <Border Background="{DynamicResource PrimaryBrush}" Padding="20,0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="MODELO DE CÓPIA" Foreground="White" FontWeight="Bold" FontSize="19"/>
                <TextBlock x:Name="SelectionText" Foreground="#D7E9FF" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
        <Grid Grid.Row="1" Margin="18">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="120"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,0,12">
                <TextBlock Text="Chaves disponíveis: {PG} {NOME} {NOME_GUERRA} {CPF} {CPF_DIGITOS} {PREC} {IDT} {ANO} {TELEFONE} {EMAIL} {ENDERECO} {CEP} {TEMPO_SERVICO}" TextWrapping="Wrap" Foreground="{DynamicResource PrimaryDarkBrush}"/>
            </Border>
            <TextBox x:Name="TemplateBox" Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" FontSize="13" VerticalScrollBarVisibility="Auto" TextChanged="Template_TextChanged"/>
            <TextBlock Grid.Row="2" Text="Prévia" Style="{StaticResource SectionTitleStyle}" Margin="0,14,0,7"/>
            <TextBox x:Name="PreviewBox" Grid.Row="3" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" FontSize="13" Background="{DynamicResource SurfaceAltBrush}" VerticalScrollBarVisibility="Auto"/>
        </Grid>
        <Border Grid.Row="2" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="18,0">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <Button Style="{StaticResource GhostButtonStyle}" Content="Restaurar padrão" Click="Restore_Click" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Salvar modelo" Click="Save_Click" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource PrimaryButtonStyle}" Content="Copiar agora" Click="Copy_Click" MinWidth="130"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
