<Window x:Class="SIGFUR.Wpf.Views.Military.TransferMilitaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transferir para Licenciados/Transferidos"
        Width="760" Height="540" MinWidth="640" MinHeight="480"
        MaxWidth="980" MaxHeight="780"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        SizeToContent="Manual"
        Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico">
    <Grid Margin="16">
        <Border Style="{StaticResource CardStyle}" Padding="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Transferir para Licenciados/Transferidos" Style="{StaticResource PageTitleStyle}" FontSize="21" TextWrapping="Wrap"/>
                    <TextBlock x:Name="SummaryText" Style="{StaticResource SubtleTextStyle}" TextWrapping="Wrap" Margin="0,4,0,16"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Motivo" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ReasonBox" SelectedIndex="0" Margin="0,0,0,14" MinHeight="36">
                            <ComboBoxItem Content="Transferência"/><ComboBoxItem Content="Licenciamento"/><ComboBoxItem Content="Desligamento"/>
                            <ComboBoxItem Content="Baixa"/><ComboBoxItem Content="Reforma"/><ComboBoxItem Content="Outro"/>
                        </ComboBox>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Detalhe do motivo (opcional)" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4" TextWrapping="Wrap"/>
                                <TextBox x:Name="DetailBox" MinHeight="38" TextWrapping="Wrap" AcceptsReturn="True"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Destino (opcional)" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4" TextWrapping="Wrap"/>
                                <TextBox x:Name="DestinationBox" MinHeight="38" TextWrapping="Wrap" AcceptsReturn="True"/>
                            </StackPanel>
                        </Grid>

                        <Border Background="{DynamicResource WarningSoftBrush}" BorderBrush="{DynamicResource WarningBrush}"
                                BorderThickness="1" CornerRadius="9" Padding="14" Margin="0,18,0,0">
                            <StackPanel>
                                <TextBlock Text="O que será preservado" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,5"/>
                                <TextBlock Text="Os dados cadastrais, contato, documentos, certidões e tarifas do Auxílio-Transporte serão preservados na LT. O registro será removido somente da lista ativa."
                                           TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="2" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Confira o motivo e o destino antes de confirmar." Style="{StaticResource SubtleTextStyle}" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,14,0"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="Cancelar" IsCancel="True" Margin="0,0,8,0" MinWidth="110"/>
                        <Button Style="{StaticResource PrimaryButtonStyle}" Content="Confirmar transferência" IsDefault="True" Click="Confirm_Click" MinWidth="190"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
