<Window x:Class="SIGFUR.Wpf.Views.Military.MilitaryTrashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SIGFUR.Wpf.Controls"
        Title="SIGFUR — Lixeira de Militares" Width="1040" Height="650" MinWidth="820" MinHeight="520"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResize" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico"
        Loaded="Window_Loaded">
<Grid>
        <Grid.RowDefinitions><RowDefinition Height="46"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="70"/><RowDefinition Height="32"/></Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="14,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Image Source="/Assets/sigfur.png" Width="28" Height="28" Stretch="Uniform" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="LIXEIRA DE MILITARES" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="Registros excluídos" FontSize="10" Foreground="{DynamicResource MutedBrush}"/>
                </StackPanel>
            </Grid>
        </Border>
        <Grid Grid.Row="1" Margin="18,16,18,12">
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel><TextBlock Text="Registros excluídos" Style="{StaticResource PageTitleStyle}"/><TextBlock Text="Restaure o registro com o mesmo ID para recuperar também os documentos e dados vinculados preservados no SQLite." Style="{StaticResource SubtleTextStyle}" TextWrapping="Wrap" Margin="0,3,0,0"/></StackPanel>
            <Border Grid.Column="1" Style="{StaticResource SoftMetricCardStyle}" Padding="16,9" VerticalAlignment="Center"><StackPanel Orientation="Horizontal"><TextBlock Text="ITENS  " Style="{StaticResource MetricCaptionStyle}" VerticalAlignment="Center"/><TextBlock Text="{Binding Count}" Style="{StaticResource MetricValueStyle}" FontSize="22"/></StackPanel></Border>
        </Grid>
        <Border Grid.Row="2" Margin="18,0" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid x:Name="TrashGrid" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}" SelectionMode="Single" IsReadOnly="True" MouseDoubleClick="TrashGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Excluído em" Binding="{Binding DeletedAtText, Mode=OneWay}" Width="155"/>
                    <DataGridTextColumn Header="P/G" Binding="{Binding Record.ShortRank, Mode=OneWay}" Width="80"/>
                    <DataGridTemplateColumn Header="Nome completo" Width="2*" MinWidth="270">
                        <DataGridTemplateColumn.CellTemplate><DataTemplate><controls:HighlightedNameTextBlock FullName="{Binding Record.Name}" WarName="{Binding Record.WarName}" TextWrapping="Wrap"/></DataTemplate></DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="CPF" Binding="{Binding Record.FormattedCpf, Mode=OneWay}" Width="130"/>
                    <DataGridTextColumn Header="PREC-CP" Binding="{Binding Record.PrecCp}" Width="110"/>
                    <DataGridTextColumn Header="Ano" Binding="{Binding Record.FormationYear}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        <Grid Grid.Row="3" Margin="18,12,18,12">
            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <Button Grid.Column="0" Style="{StaticResource PrimaryButtonStyle}" Content="Restaurar selecionado" Click="Restore_Click"/>
            <Button Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}" Content="Remover da lixeira" Click="Remove_Click"/>
            <Button Grid.Column="4" Style="{StaticResource DangerButtonStyle}" Content="Esvaziar lixeira" Click="Clear_Click"/>
        </Grid>
        <Border Grid.Row="4" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="14,0"><TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}"/></Border>
    </Grid>
</Window>
