<Window x:Class="SIGFUR.Wpf.Views.Military.RankSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Alterar Posto/Graduação" Width="520" Height="300"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico">
    <Grid Margin="16">
        <Border Style="{StaticResource CardStyle}" Padding="22">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <TextBlock Text="Alterar Posto/Graduação" Style="{StaticResource PageTitleStyle}" FontSize="21"/>
                <TextBlock x:Name="SummaryText" Grid.Row="1" Style="{StaticResource SubtleTextStyle}" TextWrapping="Wrap" Margin="0,4,0,16"/>
                <TextBlock Grid.Row="2" Text="Novo Posto/Graduação" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/>
                <ComboBox x:Name="RankBox" Grid.Row="3"/>
                <Border Grid.Row="4" Background="{DynamicResource PrimarySurfaceBrush}" CornerRadius="9" Padding="12" Margin="0,14,0,0">
                    <TextBlock Text="A alteração será aplicada a todos os militares selecionados. Os demais dados permanecem inalterados." TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}"/>
                </Border>
                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Cancelar" IsCancel="True" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource PrimaryButtonStyle}" Content="Aplicar" IsDefault="True" Click="Apply_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
