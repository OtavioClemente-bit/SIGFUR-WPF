<Window x:Class="SIGFUR.Wpf.Views.Military.PaystubAuditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SIGFUR.Wpf.Controls"
        Title="SIGFUR — Auditoria de contracheques" Width="1520" Height="900" MinWidth="1080" MinHeight="680"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResize" WindowStartupLocation="CenterOwner"
        Icon="/Assets/sigfur.ico" Background="{DynamicResource AppBackgroundBrush}"
        Loaded="Window_Loaded" Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="62"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="145"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="18,0">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="AUDITORIA DE CONTRACHEQUES" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="Leitura das rubricas em segundo plano, filtros rápidos, exportação e ações no militar" Foreground="{DynamicResource MutedBrush}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="CountText" Text="0 resultado(s)" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryDarkBrush}" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="ScopeText" Text="Carregando escopo…" Style="{StaticResource SubtleTextStyle}" FontSize="10" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="14,12,14,8" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="105"/><ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="155"/><ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="245"/><ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="175"/><ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel><TextBlock Text="Ano" Style="{StaticResource CaptionTextStyle}"/><ComboBox x:Name="YearCombo" Margin="0,4,0,0"/></StackPanel>
                <StackPanel Grid.Column="2"><TextBlock Text="Mês" Style="{StaticResource CaptionTextStyle}"/><ComboBox x:Name="MonthCombo" Margin="0,4,0,0"/></StackPanel>
                <StackPanel Grid.Column="4"><TextBlock Text="Filtro" Style="{StaticResource CaptionTextStyle}"/><ComboBox x:Name="FilterCombo" SelectionChanged="Filter_Changed" Margin="0,4,0,0"/></StackPanel>
                <StackPanel Grid.Column="6"><TextBlock Text="Posto / graduação" Style="{StaticResource CaptionTextStyle}"/><ComboBox x:Name="RankCombo" SelectionChanged="Filter_Changed" Margin="0,4,0,0"/></StackPanel>
                <StackPanel Grid.Column="8"><TextBlock Text="Pesquisar" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="SearchBox" TextChanged="Search_TextChanged" Margin="0,4,0,0" ToolTip="Nome, CPF, PREC, situação, rubrica ou banco"/></StackPanel>
                <WrapPanel Grid.Column="10" VerticalAlignment="Bottom">
                    <Button x:Name="AuditButton" Style="{StaticResource PrimaryButtonStyle}" Content="Conferir" Click="Audit_Click" MinWidth="105" Margin="0,0,7,0"/>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Colunas" Click="Columns_Click" Margin="0,0,7,0"/>
                    <Button Style="{StaticResource GhostButtonStyle}" Content="Limpar filtros" Click="ClearFilters_Click"/>
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="14,0,14,8" Padding="0">
            <DataGrid x:Name="AuditGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                      CanUserSortColumns="True" FrozenColumnCount="2" MouseDoubleClick="AuditGrid_MouseDoubleClick"
                      PreviewMouseRightButtonDown="AuditGrid_PreviewMouseRightButtonDown" KeyDown="AuditGrid_KeyDown" Sorting="AuditGrid_Sorting">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Severity, Mode=OneWay}" Value="Critical"><Setter Property="Background" Value="#FFFFE3E3"/></DataTrigger>
                            <DataTrigger Binding="{Binding Severity, Mode=OneWay}" Value="Warning"><Setter Property="Background" Value="#FFFFF3D6"/></DataTrigger>
                            <DataTrigger Binding="{Binding Severity, Mode=OneWay}" Value="Info"><Setter Property="Background" Value="#FFF0F6FF"/></DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Abrir PDF" Click="OpenPdf_Click"/>
                        <MenuItem Header="Abrir pasta do PDF" Click="OpenPdfFolder_Click"/>
                        <Separator/>
                        <MenuItem Header="Ver achados e rubricas" Click="Details_Click"/>
                        <MenuItem Header="Abrir contracheques" Click="OpenPaystubs_Click"/>
                        <MenuItem Header="Abrir carteira" Click="OpenWallet_Click"/>
                        <MenuItem Header="Editar militar" Click="EditMilitary_Click"/>
                        <Separator/>
                        <MenuItem Header="Filtrar somente com achado" Tag="Somente com achado" Click="QuickFilter_Click"/>
                        <MenuItem Header="Filtrar sem contracheque" Tag="Sem contracheque" Click="QuickFilter_Click"/>
                        <MenuItem Header="Filtrar banco divergente" Tag="Banco/Conta divergente" Click="QuickFilter_Click"/>
                        <MenuItem Header="Filtrar auxílio-transporte divergente" Tag="Aux Transporte divergente" Click="QuickFilter_Click"/>
                        <MenuItem Header="Filtrar sem FUSEx 3%" Tag="Sem FUSEx 3%" Click="QuickFilter_Click"/>
                        <MenuItem Header="Filtrar desconto DR de auxílio-transporte" Tag="Com desconto DR de Aux Transporte" Click="QuickFilter_Click"/>
                        <MenuItem Header="Filtrar salário-família" Tag="Com Salário Família" Click="QuickFilter_Click"/>
                        <MenuItem Header="Filtrar pré-escolar" Tag="Com Pré-escolar" Click="QuickFilter_Click"/>
                        <MenuItem Header="Filtrar pensão alimentícia" Tag="Com Pensão Alimentícia" Click="QuickFilter_Click"/>
                        <MenuItem Header="Filtrar DR/AR/atrasados" Tag="Com DR/AR/Atrasados" Click="QuickFilter_Click"/>
                        <MenuItem Header="Filtrar PNR" Tag="Com PNR" Click="QuickFilter_Click"/>
                        <MenuItem Header="Filtrar empréstimo/seguro/FHE" Tag="Com Empréstimo/Seguro/FHE" Click="QuickFilter_Click"/>
                        <MenuItem Header="Filtrar situação diferente de Normal" Tag="Situação diferente de Normal" Click="QuickFilter_Click"/>
                        <MenuItem Header="Filtrar pagamento suspenso" Tag="Pagamento suspenso" Click="QuickFilter_Click"/>
                        <Separator/>
                        <MenuItem Header="Copiar resumo da linha" Click="CopyRowSummary_Click"/>
                        <MenuItem Header="Conferir novamente" Click="Audit_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="RankColumn" Header="P/G" Binding="{Binding ShortRank, Mode=OneWay}" Width="82"/>
                    <DataGridTemplateColumn x:Name="NameColumn" Header="Nome completo" Width="280">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <controls:HighlightedNameTextBlock FullName="{Binding Name}" WarName="{Binding WarName}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn x:Name="PdfColumn" Header="PDF" Binding="{Binding PdfStatus, Mode=OneWay}" Width="150"/>
                    <DataGridTextColumn x:Name="BankColumn" Header="Banco/conta" Binding="{Binding BankStatus, Mode=OneWay}" Width="135"/>
                    <DataGridTextColumn x:Name="PaymentColumn" Header="Situação pagamento" Binding="{Binding PaymentStatus, Mode=OneWay}" Width="145"/>
                    <DataGridTextColumn x:Name="AuxPdfColumn" Header="AT no PDF" Binding="{Binding AuxPdfText, Mode=OneWay}" Width="105"/>
                    <DataGridTextColumn x:Name="AuxDbColumn" Header="AT no cadastro" Binding="{Binding AuxDatabaseText, Mode=OneWay}" Width="115"/>
                    <DataGridTextColumn x:Name="AuxStatusColumn" Header="AT situação" Binding="{Binding AuxStatus, Mode=OneWay}" Width="165"/>
                    <DataGridTextColumn x:Name="AuxDrColumn" Header="AT desconto DR" Binding="{Binding AuxDrText, Mode=OneWay}" Width="115" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="AuxArColumn" Header="AT AR" Binding="{Binding AuxArText, Mode=OneWay}" Width="100" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="FusexColumn" Header="FUSEx 3%" Binding="{Binding FusexText, Mode=OneWay}" Width="105"/>
                    <DataGridTextColumn x:Name="DependentFusexColumn" Header="FUSEx dependente" Binding="{Binding DependentFusexText, Mode=OneWay}" Width="125" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="MedicalFusexColumn" Header="Despesa médica" Binding="{Binding MedicalFusexText, Mode=OneWay}" Width="115" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="FamilyColumn" Header="Salário-família" Binding="{Binding FamilySalaryText, Mode=OneWay}" Width="125"/>
                    <DataGridTextColumn x:Name="DependentsColumn" Header="Dep." Binding="{Binding Dependents, Mode=OneWay}" Width="65" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="PreSchoolColumn" Header="Pré-escolar" Binding="{Binding PreSchoolText, Mode=OneWay}" Width="105"/>
                    <DataGridTextColumn x:Name="VacationColumn" Header="Férias" Binding="{Binding VacationText, Mode=OneWay}" Width="100"/>
                    <DataGridTextColumn x:Name="FoodColumn" Header="Aux. alimentação" Binding="{Binding FoodAidText, Mode=OneWay}" Width="115"/>
                    <DataGridTextColumn x:Name="DifferencesColumn" Header="DR/AR/Atrasados" Binding="{Binding DifferencesText, Mode=OneWay}" Width="125"/>
                    <DataGridTextColumn x:Name="PensionColumn" Header="Pensão" Binding="{Binding PensionText, Mode=OneWay}" Width="100" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="AlimonyColumn" Header="Pensão alimentícia" Binding="{Binding AlimonyText, Mode=OneWay}" Width="125" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="IrrfColumn" Header="IRRF" Binding="{Binding IrrfText, Mode=OneWay}" Width="95" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="QualificationColumn" Header="Adic. habilitação" Binding="{Binding QualificationAdditionalText, Mode=OneWay}" Width="125" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="AvailabilityColumn" Header="AD C DISP MIL" Binding="{Binding AvailabilityCompensationText, Mode=OneWay}" Width="120" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="PnrColumn" Header="PNR" Binding="{Binding PnrText, Mode=OneWay}" Width="95" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="LoansColumn" Header="Empréstimo/Seguro/FHE" Binding="{Binding LoansText, Mode=OneWay}" Width="145" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="RevenueColumn" Header="Receita" Binding="{Binding RevenueText, Mode=OneWay}" Width="105" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="ExpenseColumn" Header="Despesa" Binding="{Binding ExpenseText, Mode=OneWay}" Width="105" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="NetColumn" Header="Líquido" Binding="{Binding NetText, Mode=OneWay}" Width="105" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="SummaryColumn" Header="Resumo / achados" Binding="{Binding Summary, Mode=OneWay}" Width="360"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="14,0,14,8" Padding="12">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Grid>
                    <TextBlock Text="Andamento e registro da auditoria" Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock x:Name="AuditStatusText" Text="Pronto para conferir." HorizontalAlignment="Right" Foreground="{DynamicResource MutedBrush}"/>
                </Grid>
                <Grid Grid.Row="1" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="230"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel>
                        <ProgressBar x:Name="AuditProgress" Height="12" Minimum="0" Maximum="1"/>
                        <TextBlock x:Name="ProgressText" Text="0 / 0" Style="{StaticResource SubtleTextStyle}" Margin="0,6,0,0"/>
                    </StackPanel>
                    <TextBox x:Name="LogBox" Grid.Column="2" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="11"/>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="4" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="14,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <WrapPanel VerticalAlignment="Center">
                    <Button Style="{StaticResource PrimaryButtonStyle}" Content="Abrir PDF" Click="OpenPdf_Click" Margin="0,0,7,0"/>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Ver achados" Click="Details_Click" Margin="0,0,7,0"/>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Contracheques" Click="OpenPaystubs_Click" Margin="0,0,7,0"/>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Editar" Click="EditMilitary_Click" Margin="0,0,7,0"/>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Carteira" Click="OpenWallet_Click" Margin="0,0,7,0"/>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Lista Word filtrada" Click="ExportWord_Click" Margin="0,0,7,0"/>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="CSV filtrado" Click="ExportFilteredCsv_Click" Margin="0,0,7,0"/>
                    <Button Style="{StaticResource GhostButtonStyle}" Content="CSV completo" Click="ExportAllCsv_Click" Margin="0,0,7,0"/>
                    <Button Style="{StaticResource GhostButtonStyle}" Content="Pasta raiz" Click="OpenRootFolder_Click" Margin="0,0,7,0"/>
                    <Button Style="{StaticResource GhostButtonStyle}" Content="Escolher pasta" Click="ChooseRootFolder_Click"/>
                </WrapPanel>
                <Button x:Name="StopCloseButton" Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Content="Fechar" Click="StopClose_Click" MinWidth="105" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
