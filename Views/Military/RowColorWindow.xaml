<Window x:Class="SIGFUR.Wpf.Views.Military.RowColorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cor de destaque" Width="780" Height="650" MinWidth="680" MinHeight="560"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico">
    <Grid Margin="16">
        <Border Style="{StaticResource CardStyle}" Padding="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock x:Name="HeadingText" Text="Destaque visual do militar" Style="{StaticResource PageTitleStyle}" FontSize="22"/>
                    <TextBlock Text="Confira a cor atualmente aplicada e escolha uma opção com contraste adequado."
                               Style="{StaticResource SubtleTextStyle}" TextWrapping="Wrap" Margin="0,4,0,14"/>
                </StackPanel>

                <Border Grid.Row="1" Padding="14" CornerRadius="12" BorderThickness="2"
                        BorderBrush="{DynamicResource BorderStrongBrush}" Background="{DynamicResource SurfaceAltBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="138"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="CurrentColorPreview" Height="66" CornerRadius="10" BorderThickness="2"
                                BorderBrush="#334155" Background="White">
                            <TextBlock Text="COR ATUAL" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontWeight="Bold" Foreground="#102A43"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Cor atualmente aplicada" Style="{StaticResource CaptionTextStyle}"/>
                            <TextBlock x:Name="CurrentColorNameText" Margin="0,4,0,0" FontSize="15" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryDarkBrush}" TextWrapping="Wrap"/>
                            <TextBlock x:Name="SelectedColorText" Margin="0,3,0,0" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="2" Text="Paleta de alto contraste" Style="{StaticResource SectionTitleStyle}" Margin="0,18,0,8"/>

                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <UniformGrid x:Name="PaletteGrid" Columns="4">
                        <Button Tag="#BBDEFB" Click="Color_Click" Margin="5" Height="64" Background="#BBDEFB" BorderBrush="#42A5F5" Content="Azul claro" Foreground="#0D47A1"/>
                        <Button Tag="#64B5F6" Click="Color_Click" Margin="5" Height="64" Background="#64B5F6" BorderBrush="#1565C0" Content="Azul forte" Foreground="#082F49"/>
                        <Button Tag="#A5D6A7" Click="Color_Click" Margin="5" Height="64" Background="#A5D6A7" BorderBrush="#43A047" Content="Verde claro" Foreground="#1B5E20"/>
                        <Button Tag="#81C784" Click="Color_Click" Margin="5" Height="64" Background="#81C784" BorderBrush="#2E7D32" Content="Verde forte" Foreground="#123B20"/>

                        <Button Tag="#FFF59D" Click="Color_Click" Margin="5" Height="64" Background="#FFF59D" BorderBrush="#F9A825" Content="Amarelo claro" Foreground="#5D4600"/>
                        <Button Tag="#FFD54F" Click="Color_Click" Margin="5" Height="64" Background="#FFD54F" BorderBrush="#F57F17" Content="Amarelo forte" Foreground="#4E3600"/>
                        <Button Tag="#FFCC80" Click="Color_Click" Margin="5" Height="64" Background="#FFCC80" BorderBrush="#FB8C00" Content="Laranja claro" Foreground="#6D3300"/>
                        <Button Tag="#FFB74D" Click="Color_Click" Margin="5" Height="64" Background="#FFB74D" BorderBrush="#EF6C00" Content="Laranja forte" Foreground="#5A2500"/>

                        <Button Tag="#EF9A9A" Click="Color_Click" Margin="5" Height="64" Background="#EF9A9A" BorderBrush="#E53935" Content="Vermelho claro" Foreground="#7F1D1D"/>
                        <Button Tag="#E57373" Click="Color_Click" Margin="5" Height="64" Background="#E57373" BorderBrush="#B71C1C" Content="Vermelho forte" Foreground="#5F1111"/>
                        <Button Tag="#F48FB1" Click="Color_Click" Margin="5" Height="64" Background="#F48FB1" BorderBrush="#D81B60" Content="Rosa claro" Foreground="#6A1238"/>
                        <Button Tag="#F06292" Click="Color_Click" Margin="5" Height="64" Background="#F06292" BorderBrush="#AD1457" Content="Rosa forte" Foreground="#58102E"/>

                        <Button Tag="#CE93D8" Click="Color_Click" Margin="5" Height="64" Background="#CE93D8" BorderBrush="#8E24AA" Content="Roxo claro" Foreground="#4A148C"/>
                        <Button Tag="#BA68C8" Click="Color_Click" Margin="5" Height="64" Background="#BA68C8" BorderBrush="#6A1B9A" Content="Roxo forte" Foreground="#3A0E58"/>
                        <Button Tag="#80DEEA" Click="Color_Click" Margin="5" Height="64" Background="#80DEEA" BorderBrush="#00ACC1" Content="Ciano claro" Foreground="#005662"/>
                        <Button Tag="#4DD0E1" Click="Color_Click" Margin="5" Height="64" Background="#4DD0E1" BorderBrush="#00838F" Content="Ciano forte" Foreground="#003F46"/>

                        <Button Tag="#CFD8DC" Click="Color_Click" Margin="5" Height="64" Background="#CFD8DC" BorderBrush="#78909C" Content="Cinza claro" Foreground="#263238"/>
                        <Button Tag="#90A4AE" Click="Color_Click" Margin="5" Height="64" Background="#90A4AE" BorderBrush="#455A64" Content="Cinza forte" Foreground="#17252B"/>
                        <Button Tag="#C5E1A5" Click="Color_Click" Margin="5" Height="64" Background="#C5E1A5" BorderBrush="#7CB342" Content="Lima claro" Foreground="#33691E"/>
                        <Button Tag="#AED581" Click="Color_Click" Margin="5" Height="64" Background="#AED581" BorderBrush="#558B2F" Content="Lima forte" Foreground="#274E13"/>
                    </UniformGrid>
                </ScrollViewer>

                <Grid Grid.Row="4" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <Button Grid.Column="0" HorizontalAlignment="Left" Style="{StaticResource GhostButtonStyle}" Content="Usar cor automática / remover destaque" Click="Clear_Click"/>
                    <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Content="Cancelar" IsCancel="True"/>
                    <Button x:Name="ApplyButton" Grid.Column="3" Style="{StaticResource PrimaryButtonStyle}" Content="Aplicar cor" IsDefault="True" Click="Apply_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
