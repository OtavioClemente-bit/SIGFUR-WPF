<Window x:Class="SIGFUR.Wpf.Views.Military.ServiceIntervalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tempo de Serviço" Width="560" Height="430" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico">
    <Grid Margin="16">
        <Border Style="{StaticResource CardStyle}" Padding="22">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <TextBlock Text="Intervalo de tempo de serviço" Style="{StaticResource PageTitleStyle}" FontSize="21"/>
                <TextBlock Text="Cadastre períodos personalizados. Data final vazia considera a data atual." Grid.Row="1" Style="{StaticResource SubtleTextStyle}" TextWrapping="Wrap" Margin="0,4,0,16"/>
                <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <StackPanel><TextBlock Text="Data inicial *" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><TextBox x:Name="StartBox" ToolTip="dd/mm/aaaa"/></StackPanel>
                    <StackPanel Grid.Column="2"><TextBlock Text="Data final" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><TextBox x:Name="EndBox" ToolTip="dd/mm/aaaa"/></StackPanel>
                </Grid>
                <TextBlock Grid.Row="3" Text="Observação" Style="{StaticResource CaptionTextStyle}" Margin="0,14,0,4"/>
                <TextBox x:Name="ObservationBox" Grid.Row="4" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" MinHeight="100"/>
                <Border Grid.Row="5" Background="{DynamicResource PrimarySurfaceBrush}" CornerRadius="9" Padding="12" Margin="0,14,0,0"><TextBlock Text="O cálculo considera os dias inicial e final. Intervalos são mantidos no mesmo militares.db do SIGFUR." TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}"/></Border>
                <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0"><Button Style="{StaticResource SecondaryButtonStyle}" Content="Cancelar" IsCancel="True" Margin="0,0,8,0"/><Button Style="{StaticResource PrimaryButtonStyle}" Content="Salvar intervalo" IsDefault="True" Click="Save_Click"/></StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
