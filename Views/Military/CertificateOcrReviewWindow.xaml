<Window x:Class="SIGFUR.Wpf.Views.Military.CertificateOcrReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIGFUR — Conferir leitura da certidão" Width="1040" Height="760" MinWidth="860" MinHeight="620"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="104"/><RowDefinition Height="*"/><RowDefinition Height="72"/></Grid.RowDefinitions>
        <Border Background="{DynamicResource PrimaryGradientBrush}" Padding="24,0">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="CONFERÊNCIA DA CERTIDÃO" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    <TextBlock x:Name="HeaderSubtitle" Foreground="#DCEBFF" Margin="0,5,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="#22FFFFFF" CornerRadius="14" Padding="14,8">
                    <TextBlock x:Name="ScoreText" Foreground="White" FontWeight="Bold"/>
                </Border>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="18">
            <TabItem Header="Dados identificados">
                <Grid Margin="12">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Border x:Name="WarningCard" Background="{DynamicResource WarningSoftBrush}" BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                        <TextBlock x:Name="WarningsText" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}"/>
                    </Border>
                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
                        <DataGrid x:Name="KeysGrid" AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Campo" Binding="{Binding Label}" IsReadOnly="True" Width="260"/>
                                <DataGridTextColumn Header="Chave" Binding="{Binding Key}" IsReadOnly="True" Width="230"/>
                                <DataGridTextColumn Header="Valor identificado — revise antes de salvar" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                    <TextBlock Grid.Row="2" Text="Você pode corrigir qualquer valor. Ao confirmar, o documento e as chaves do Boletim serão atualizados juntos." Foreground="{DynamicResource MutedBrush}" Margin="2,9,0,0" TextWrapping="Wrap"/>
                </Grid>
            </TabItem>
            <TabItem Header="Texto lido pelo OCR">
                <Border Style="{StaticResource CardStyle}" Padding="12" Margin="12">
                    <TextBox x:Name="RawTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12" BorderThickness="0" Background="Transparent"/>
                </Border>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="18,0">
            <Grid>
                <TextBlock Text="Confira principalmente nome, CPF, nascimento, matrícula e filiação." Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Cancelar" Style="{StaticResource GhostButtonStyle}" IsCancel="True" Margin="0,0,8,0"/>
                    <Button Content="Confirmar e criar chaves" Style="{StaticResource PrimaryButtonStyle}" Click="Confirm_Click" IsDefault="True"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
