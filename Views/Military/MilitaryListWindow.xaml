<Window x:Class="SIGFUR.Wpf.Views.Military.MilitaryListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:SIGFUR.Wpf.Controls"
        mc:Ignorable="d"
        Title="SIGFUR — Lista de Militares"
        Width="1480" Height="860" MinWidth="960" MinHeight="600"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResize" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}"
        Icon="/Assets/sigfur.ico"
        Loaded="Window_Loaded" Closing="Window_Closing" PreviewKeyDown="Window_PreviewKeyDown">
<Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- Barra de título -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryDarkBrush}" BorderThickness="0" Padding="14,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Image Source="/Assets/sigfur.png" Width="28" Height="28" Stretch="Uniform" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="LISTA DE MILITARES" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Pesquisa, organização, documentos e dados do efetivo" FontSize="10" Foreground="#CFE3FF"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="278"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*" MinWidth="540"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="316"/>
            </Grid.ColumnDefinitions>

            <!-- Painel esquerdo -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Pesquisa e filtros" Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock Grid.Row="1" Text="Localize por nome, guerra, CPF, PREC, IDT, ano, contato ou anotação." Style="{StaticResource SubtleTextStyle}" TextWrapping="Wrap" Margin="0,3,0,12"/>
                    <TextBox x:Name="SearchBox" Grid.Row="2" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Ctrl+F para pesquisar" Margin="0,0,0,10"/>
                    <Grid Grid.Row="3" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Posto/Graduação" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding RankOptions}" SelectedItem="{Binding SelectedRank}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Ano" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding YearOptions}" SelectedItem="{Binding SelectedYear}"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Grid.Row="4" Margin="0,0,0,12">
                        <TextBlock Text="Ordenação" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding SortModes}" SelectedItem="{Binding SortMode}" Margin="0,0,0,9" ToolTip="Alterna entre a ordem manual salva, hierarquia por posto/graduação e nome."/>
                        <CheckBox Content="Somente favoritos" IsChecked="{Binding FavoritesOnly}" Margin="0,4"/>
                        <CheckBox Content="Somente Adido/Encostado" IsChecked="{Binding AttachedOnly}" Margin="0,4"/>
                        <CheckBox Content="Sem Auxílio-Transporte" IsChecked="{Binding MissingTransportOnly}" Margin="0,4"/>
                    </StackPanel>
                    <Separator Grid.Row="5" Margin="0,0,0,12"/>
                    <ScrollViewer Grid.Row="6" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Text="Militar selecionado" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,8"/>
                            <Button Style="{StaticResource PrimaryButtonStyle}" Content="Abrir carteira" Click="OpenWallet_Click" Margin="0,0,0,7"/>
                            <Button Style="{StaticResource SidebarActionButtonStyle}" Content="Editar cadastro" Click="Edit_Click"/>
                            <Button Style="{StaticResource SidebarActionButtonStyle}" Content="Favoritar ou desfavoritar" Click="Favorite_Click"/>
                            <Button Style="{StaticResource SidebarActionButtonStyle}" Content="Anotação interna" Click="Note_Click"/>
                            <Button Style="{StaticResource SidebarActionButtonStyle}" Content="Cor de destaque" Click="Color_Click"/>

                            <TextBlock Text="Documentos e pagamentos" Style="{StaticResource SectionTitleStyle}" Margin="0,10,0,8"/>
                            <Button Style="{StaticResource SidebarActionButtonStyle}" Content="Gerar documentação" Click="GenerateDocuments_Click"/>
                            <Button Style="{StaticResource SidebarActionButtonStyle}" Content="Central de contracheques" ToolTip="Escolha arquivos, baixe, abra ou trabalhe em lote." Click="PaystubTools_Click"/>
                            <Button x:Name="LatestPaystubButton" Style="{StaticResource SidebarActionButtonStyle}" Content="Último contracheque" ToolTip="Baixa agora o contracheque mais recente disponível e abre o PDF salvo na pasta do militar." Click="OpenLatestPaystub_Click"/>
                            <Button Style="{StaticResource SidebarActionButtonStyle}" Content="Copiar formato P/G NOME CPF" Click="CopyFormat_Click"/>
                            <Button Style="{StaticResource SidebarActionButtonStyle}" Content="Quantitativo da relação" Click="Quantity_Click"/>

                            <TextBlock Text="Organização" Style="{StaticResource SectionTitleStyle}" Margin="0,10,0,8"/>
                            <Button Style="{StaticResource SidebarActionButtonStyle}" Content="Mover para cima" Click="MoveUp_Click"/>
                            <Button Style="{StaticResource SidebarActionButtonStyle}" Content="Mover para baixo" Click="MoveDown_Click"/>
                            <Button Style="{StaticResource SidebarActionButtonStyle}" Content="Restaurar ordem hierárquica" Click="ResetOrder_Click"/>
                            <Button Style="{StaticResource SidebarActionButtonStyle}" Content="Transferir para licenciados/transferidos" Click="Transfer_Click"/>
                            <Button Style="{StaticResource SidebarActionButtonStyle}" Content="Alterar P/G em lote" Click="Promote_Click"/>
                            <Button Style="{StaticResource SidebarActionButtonStyle}" Content="Abrir lixeira" Click="Trash_Click"/>
                            <Button Style="{StaticResource SidebarActionButtonStyle}" Content="Desfazer última exclusão" Click="UndoDelete_Click"/>
                        </StackPanel>
                    </ScrollViewer>
                    <StackPanel Grid.Row="7" Margin="0,12,0,0">
                        <Button Style="{StaticResource DangerButtonStyle}" Content="Excluir militar" Click="Delete_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Centro -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                        <StackPanel><TextBlock Text="EFETIVO" Style="{StaticResource MetricCaptionStyle}"/><TextBlock Text="{Binding TotalCount}" Style="{StaticResource MetricValueStyle}"/></StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}">
                        <StackPanel><TextBlock Text="VISÍVEIS" Style="{StaticResource MetricCaptionStyle}"/><TextBlock Text="{Binding FilteredCount}" Style="{StaticResource MetricValueStyle}"/></StackPanel>
                    </Border>
                    <Border Grid.Column="4" Style="{StaticResource MetricCardStyle}">
                        <StackPanel><TextBlock Text="FAVORITOS" Style="{StaticResource MetricCaptionStyle}"/><TextBlock Text="{Binding FavoriteCount}" Style="{StaticResource MetricValueStyle}"/></StackPanel>
                    </Border>
                    <Border Grid.Column="6" Style="{StaticResource WarningMetricCardStyle}">
                        <StackPanel><TextBlock Text="SEM AT" Style="{StaticResource MetricCaptionStyle}"/><TextBlock Text="{Binding MissingTransportCount}" Style="{StaticResource MetricValueStyle}"/></StackPanel>
                    </Border>
                    <Border Grid.Column="8" Style="{StaticResource SoftMetricCardStyle}">
                        <StackPanel><TextBlock Text="SEM FOTO" Style="{StaticResource MetricCaptionStyle}"/><TextBlock Text="{Binding MissingPhotoCount}" Style="{StaticResource MetricValueStyle}"/></StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="10" Margin="0,0,0,10">
                    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <Border Background="{DynamicResource PrimarySoftBrush}" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1" CornerRadius="10" Padding="12,9" Margin="0,0,0,9">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="AUDITORIA DE CONTRACHEQUES" FontWeight="Bold" Foreground="{DynamicResource PrimaryDarkBrush}"/><TextBlock Text="Leitura de contracheques: militar, competência, rubrica, descrição e valor recebido — com rastreio para conferência." Foreground="{DynamicResource MutedBrush}" FontSize="11" TextWrapping="Wrap"/></StackPanel>
                                <Button Grid.Column="1" Content="Abrir auditoria" Style="{StaticResource PrimaryButtonStyle}" Click="PaystubAudit_Click" Margin="18,0,0,0"/>
                            </Grid>
                        </Border>
                        <WrapPanel Grid.Row="1">
                            <Button Style="{StaticResource PrimaryButtonStyle}" Content="＋ Novo militar" Click="New_Click" Margin="0,0,7,7"/>
                            <Button Style="{StaticResource ToolbarActionButtonStyle}" Content="Atualizar efetivo" Click="Refresh_Click"/>
                            <Button Style="{StaticResource ToolbarActionButtonStyle}" Content="Importar" Click="Import_Click"/>
                            <Button Style="{StaticResource ToolbarActionButtonStyle}" Content="Exportar ▾" Click="ExportOptions_Click">
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Relação de militares (Excel, CSV ou TXT)" Click="Export_Click"/>
                                        <MenuItem Header="Relação especial — Pré/PNR/Pensão/Laranjeira" Click="ExportBenefits_Click"/>
                                        <MenuItem Header="Contracheques do mês" Click="ExportPaystubs_Click"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                            <Button x:Name="ShowMarkedButton" Style="{StaticResource ToolbarActionButtonStyle}" Content="Mostrar marcados" Click="ShowMarked_Click"/>
                            <Button Style="{StaticResource ToolbarActionButtonStyle}" Content="Limpar marcações" Click="ClearMarked_Click"/>
                            <Button Style="{StaticResource ToolbarActionButtonStyle}" Content="Configurar colunas" Click="Columns_Click"/>
                            <Button Style="{StaticResource ToolbarActionButtonStyle}" Content="Legenda de cores" Click="ColorLegend_Click" ToolTip="Cores automáticas por posto/graduação; soldados são diferenciados pelo ano de formação."/>
                        </WrapPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="10" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="210"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="MINHAS LISTAS" Style="{StaticResource MetricCaptionStyle}"/>
                            <TextBlock Text="Salve listas ou importe posições" Style="{StaticResource SubtleTextStyle}" FontSize="10"/>
                        </StackPanel>
                        <ComboBox x:Name="SavedListsCombo" Grid.Column="2" DisplayMemberPath="DisplayLabel" VerticalAlignment="Center" ToolTip="Relações salvas"/>
                        <WrapPanel Grid.Column="4" VerticalAlignment="Center">
                            <Button Style="{StaticResource SecondaryButtonStyle}" Content="Abrir" Click="OpenSavedList_Click" Margin="0,0,7,0"/>
                            <Button Style="{StaticResource SecondaryButtonStyle}" Content="Importar posições" Click="ImportSavedPositions_Click" Margin="0,0,7,0" ToolTip="Escolha o ordem_custom.json salvo pelo Listar Militares em Python. Somente a posição das linhas será importada."/>
                            <Button Style="{StaticResource PrimaryButtonStyle}" Content="+ Salvar lista" Click="SaveNewList_Click" Margin="0,0,7,0"/>
                            <Button Style="{StaticResource SecondaryButtonStyle}" Content="Atualizar lista" Click="UpdateSavedList_Click" Margin="0,0,7,0"/>
                            <Button Style="{StaticResource SecondaryButtonStyle}" Content="Excluir lista" Click="DeleteSavedList_Click" Margin="0,0,7,0"/>
                            <Button Style="{StaticResource GhostButtonStyle}" Content="Relação completa" Click="ShowAllList_Click" Margin="0,0,12,0"/>
                            <CheckBox x:Name="LockOrderCheck" Content="Travar ordem" IsChecked="{Binding OrderLocked}" Checked="LockOrderCheck_Changed" Unchecked="LockOrderCheck_Changed" VerticalAlignment="Center" ToolTip="Impede arrastar e mover militares sem querer."/>
                        </WrapPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0">
                    <DataGrid x:Name="MilitaryGrid" ItemsSource="{Binding Military}" SelectedItem="{Binding SelectedMilitary}"
                              SelectionMode="Extended" SelectionUnit="FullRow" IsReadOnly="True"
                              MouseDoubleClick="MilitaryGrid_MouseDoubleClick" SelectionChanged="MilitaryGrid_SelectionChanged"
                              PreviewMouseRightButtonDown="MilitaryGrid_PreviewMouseRightButtonDown"
                              PreviewMouseLeftButtonDown="MilitaryGrid_PreviewMouseLeftButtonDown"
                              PreviewMouseMove="MilitaryGrid_PreviewMouseMove"
                              Drop="MilitaryGrid_Drop" DragOver="MilitaryGrid_DragOver" DragLeave="MilitaryGrid_DragLeave" AllowDrop="True">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Abrir carteira" Click="OpenWallet_Click"/>
                                <MenuItem Header="Editar" Click="Edit_Click"/>
                                <MenuItem Header="Favoritar / desfavoritar" Click="Favorite_Click"/>
                                <MenuItem Header="Anotação" Click="Note_Click"/>
                                <MenuItem Header="Cor de destaque…" Click="Color_Click"/>
                                <MenuItem Header="Copiar no padrão da relação" Click="CopyFormat_Click"/>
                                <MenuItem Header="Quantidade / resumo" Click="Quantity_Click"/>
                                <Separator/>
                                <MenuItem Header="Gerar documentos">
                                    <MenuItem Header="Auxílio-Transporte" Click="GenerateTransportDocument_Click"/>
                                    <MenuItem Header="Pecuniária" Click="GeneratePecuniaryDocument_Click"/>
                                    <MenuItem Header="Correios / etiqueta" Click="GeneratePostalDocument_Click"/>
                                    <MenuItem Header="Cópia autêntica de pagamento" Click="GeneratePaymentCopyDocument_Click"/>
                                    <MenuItem Header="Adiantamento natalino" Click="GenerateChristmasDocument_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Capa do processo" Click="GenerateCoverDocument_Click"/>
                                    <MenuItem Header="Requerimento / Informação EA" Click="GenerateEaRequestDocument_Click"/>
                                    <MenuItem Header="Pensão Judicial — ficha" Click="GeneratePensionWorksheetDocument_Click"/>
                                    <MenuItem Header="Índice remissivo" Click="GenerateIndexDocument_Click"/>
                                    <MenuItem Header="Grat Rep — DIEx" Click="GenerateGratDiexDocument_Click"/>
                                    <MenuItem Header="Grat Rep — mapa" Click="GenerateGratMapDocument_Click"/>
                                </MenuItem>
                                <MenuItem Header="Contracheques — seleção ou todos">
                                    <MenuItem Header="Abrir contracheques salvos" Click="Paystubs_Click"/>
                                    <MenuItem Header="Abrir último contracheque" Click="OpenLatestPaystub_Click"/>
                                    <MenuItem Header="Exportar contracheque do mês" Click="ExportPaystubs_Click"/>
                                    <MenuItem Header="Baixar contracheque automático" Click="DownloadSelectedPaystub_Click"/>
                                    <MenuItem Header="Baixar contracheque do mês em lote" Click="DownloadMonthlyPaystubs_Click"/>
                                    <MenuItem Header="Contracheque pessoa de fora" Click="ExternalPaystub_Click"/>
                                    <MenuItem Header="Auditoria dos contracheques" Click="PaystubAudit_Click"/>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Marcar / desmarcar Adido/Encostado" Click="Attached_Click"/>
                                <MenuItem Header="Transferir para LT" Click="Transfer_Click"/>
                                <MenuItem Header="Alterar P/G em lote" Click="Promote_Click"/>
                                <Separator/>
                                <MenuItem Header="Copiar CPF" Click="CopyCpf_Click"/>
                                <MenuItem Header="Copiar PREC-CP" Click="CopyPrec_Click"/>
                                <MenuItem Header="Copiar IDT" Click="CopyIdt_Click"/>
                                <MenuItem Header="Copiar dados completos" Click="CopySummary_Click"/>
                                <MenuItem Header="Copiar formato" Click="CopyFormat_Click"/>
                                <Separator/>
                                <MenuItem Header="Importar militares" Click="Import_Click"/>
                                <MenuItem Header="Exportar militares" Click="Export_Click"/>
                                <MenuItem Header="Exportar relação especial — Pré/PNR/Pensão/Laranjeira" Click="ExportBenefits_Click"/>
                                <MenuItem Header="Escolher colunas" Click="Columns_Click"/>
                                <Separator/>
                                <MenuItem Header="Excluir" Click="Delete_Click"/>
                                <MenuItem Header="Abrir lixeira" Click="Trash_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.RowStyle>
                            <Style TargetType="{x:Type DataGridRow}" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                <Setter Property="Background" Value="{Binding RowColor, Converter={StaticResource HexColorToBrush}}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMarkedForBatch, Mode=OneWay}" Value="True">
                                        <Setter Property="Background" Value="#E8F5E9"/>
                                        <Setter Property="Foreground" Value="#1B5E20"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/></Trigger>
                                    <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="{DynamicResource PrimarySoftBrush}"/><Setter Property="Foreground" Value="{DynamicResource PrimaryDarkBrush}"/></Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn x:Name="ColMarked" Header="Marcar" Width="58" IsReadOnly="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsMarkedForBatch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Click="MarkCheckBox_Click"
                                                  Focusable="False"
                                                  ToolTip="Marcar para ações em lote; a marca permanece ao pesquisar"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn x:Name="ColFavorite" Header="Favorito" Width="44">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding FavoriteGlyph, Mode=OneWay}" Click="Star_Click" ToolTip="Favoritar / desfavoritar" Style="{StaticResource GhostButtonStyle}" Padding="0" MinWidth="30" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn x:Name="ColRank" Header="P/G" Binding="{Binding ShortRank, Mode=OneWay}" Width="82"/>
                            <DataGridTextColumn x:Name="ColYear" Header="Ano" Binding="{Binding FormationYear}" Width="65"/>
                            <DataGridTemplateColumn x:Name="ColName" Header="Nome completo" Width="2*" MinWidth="270">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <controls:HighlightedNameTextBlock FullName="{Binding Name, Mode=OneWay}"
                                                                          WarName="{Binding WarName, Mode=OneWay}"
                                                                          TextWrapping="NoWrap"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn x:Name="ColCpf" Header="CPF" Binding="{Binding FormattedCpf, Mode=OneWay}" Width="126"/>
                            <DataGridTextColumn x:Name="ColPrec" Header="PREC-CP" Binding="{Binding PrecCp}" Width="108"/>
                            <DataGridTextColumn x:Name="ColIdt" Header="IDT" Binding="{Binding MilitaryId}" Width="112"/>
                            <DataGridTextColumn x:Name="ColPhone" Header="Telefone" Binding="{Binding Phone}" Width="128" Visibility="Collapsed"/>
                            <DataGridTextColumn x:Name="ColEmail" Header="E-mail" Binding="{Binding Email}" Width="190" Visibility="Collapsed"/>
                            <DataGridTextColumn x:Name="ColAddress" Header="Endereço" Binding="{Binding Address}" Width="260" Visibility="Collapsed"/>
                            <DataGridTextColumn x:Name="ColTransport" Header="Auxílio-Transporte" Binding="{Binding TransportStatus, Mode=OneWay}" Width="142"/>
                            <DataGridTextColumn x:Name="ColService" Header="Tempo de serviço" Binding="{Binding ServiceTimeText, Mode=OneWay}" Width="150" Visibility="Collapsed"/>
                            <DataGridTextColumn x:Name="ColPnr" Header="PNR" Binding="{Binding PnrStatus, Mode=OneWay}" Width="58" Visibility="Collapsed"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <!-- Painel de seleção -->
            <Border Grid.Column="4" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Background="{DynamicResource PrimarySurfaceBrush}" Padding="16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="MILITAR SELECIONADO" Style="{StaticResource MetricCaptionStyle}"/>
                                <TextBlock x:Name="MarkedCountText" Grid.Column="1" Text="0 marcados" FontSize="10" FontWeight="SemiBold" Foreground="#D7E9FF"/>
                            </Grid>
                            <TextBlock Text="{Binding SelectedMilitary.ShortRank, FallbackValue='Selecione um militar'}" MouseLeftButtonDown="CopyTextBlock_DoubleClick" ToolTip="Clique para copiar" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryDarkBrush}" Margin="0,6,0,0"/>
                            <controls:HighlightedNameTextBlock FullName="{Binding SelectedMilitary.Name, Mode=OneWay}"
                                                               WarName="{Binding SelectedMilitary.WarName, Mode=OneWay}"
                                                               Tag="{Binding SelectedMilitary.Name}"
                                                               MouseLeftButtonDown="CopyTextBlock_DoubleClick"
                                                               ToolTip="Clique para copiar o nome completo"
                                                               FontSize="17" Foreground="{DynamicResource TextBrush}"
                                                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                            <TextBlock Tag="{Binding SelectedMilitary.WarName}" MouseLeftButtonDown="CopyTextBlock_DoubleClick"
                                       ToolTip="Clique para copiar o nome de guerra" Foreground="{DynamicResource MutedBrush}" Margin="0,4,0,0">
                                <Run Text="Nome de guerra: "/><Run Text="{Binding SelectedMilitary.WarName, FallbackValue=—, Mode=OneWay}" FontWeight="Bold"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="1" Margin="16,16,16,10">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="112"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Width="100" Height="122" CornerRadius="12" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" ClipToBounds="True">
                            <Grid>
                                <TextBlock Text="SEM FOTO" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource SubtleTextBrush}" FontWeight="SemiBold"/>
                                <Image Source="{Binding SelectedMilitary.PhotoPath}" Stretch="UniformToFill"/>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="CPF" Style="{StaticResource CaptionTextStyle}"/>
                            <TextBlock Text="{Binding SelectedMilitary.FormattedCpf, FallbackValue=—}" MouseLeftButtonDown="CopyTextBlock_DoubleClick" ToolTip="Clique para copiar" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,2,0,8"/>
                            <TextBlock Text="PREC-CP" Style="{StaticResource CaptionTextStyle}"/>
                            <TextBlock Text="{Binding SelectedMilitary.PrecCp, FallbackValue=—}" MouseLeftButtonDown="CopyTextBlock_DoubleClick" ToolTip="Clique para copiar" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,2,0,7"/>
                            <TextBlock Text="IDT" Style="{StaticResource CaptionTextStyle}"/>
                            <TextBlock Text="{Binding SelectedMilitary.MilitaryId, FallbackValue=—}" MouseLeftButtonDown="CopyTextBlock_DoubleClick" ToolTip="Clique para copiar" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,2,0,7"/>
                            <TextBlock Text="Situação" Style="{StaticResource CaptionTextStyle}"/>
                            <TextBlock Text="{Binding SelectedMilitary.TransportStatus, FallbackValue=—}" MouseLeftButtonDown="CopyTextBlock_DoubleClick" ToolTip="Clique para copiar" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,2,0,8"/>
                            <TextBlock Text="Tempo de serviço" Style="{StaticResource CaptionTextStyle}"/>
                            <TextBlock Text="{Binding SelectedMilitary.ServiceTimeText, FallbackValue='Data de praça não informada'}" MouseLeftButtonDown="CopyTextBlock_DoubleClick" ToolTip="Clique para copiar" FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="16,4,16,8">
                        <StackPanel>
                            <TextBlock Text="Dados de contato" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,8"/>
                            <TextBlock Text="Telefone" Style="{StaticResource CaptionTextStyle}"/>
                            <TextBlock Text="{Binding SelectedMilitary.Phone, FallbackValue='Não informado'}" MouseLeftButtonDown="CopyTextBlock_DoubleClick" ToolTip="Clique para copiar" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" Margin="0,2,0,8"/>
                            <TextBlock Text="E-mail" Style="{StaticResource CaptionTextStyle}"/>
                            <TextBlock Text="{Binding SelectedMilitary.Email, FallbackValue='Não informado'}" MouseLeftButtonDown="CopyTextBlock_DoubleClick" ToolTip="Clique para copiar" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" Margin="0,2,0,12"/>
                            <TextBlock Text="Endereço" Style="{StaticResource CaptionTextStyle}"/>
                            <TextBlock Text="{Binding SelectedMilitary.Address, FallbackValue='Não informado'}" MouseLeftButtonDown="CopyTextBlock_DoubleClick" ToolTip="Clique para copiar" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" Margin="0,2,0,12"/>
                            <TextBlock Text="Anotação" Style="{StaticResource SectionTitleStyle}" Margin="0,4,0,7"/>
                            <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="8" Padding="10" MinHeight="72">
                                <TextBlock Text="{Binding SelectedMilitary.Annotation, FallbackValue='Sem anotação'}" TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}"
                                           MouseLeftButtonDown="CopyTextBlock_DoubleClick" ToolTip="Clique para copiar"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                    <Grid Grid.Row="3" Margin="16,8,16,16">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource SecondaryButtonStyle}" Content="Copiar dados" Click="CopySummary_Click"/>
                        <Button Grid.Column="2" Style="{StaticResource PrimaryButtonStyle}" Content="Abrir carteira" Click="OpenWallet_Click"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="1" Background="{DynamicResource OverlayBrush}" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" Panel.ZIndex="100">
            <Border Width="440" Padding="28" CornerRadius="18" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderStrongBrush}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <Image Source="/Assets/sigfur.png" Width="78" Height="78" Stretch="Uniform" HorizontalAlignment="Center"/>
                    <TextBlock Text="SIGFUR trabalhando em segundo plano" Style="{StaticResource SectionTitleStyle}" FontSize="19" HorizontalAlignment="Center" Margin="0,14,0,5"/>
                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource SubtleTextStyle}" TextAlignment="Center" TextWrapping="Wrap"/>
                    <ProgressBar IsIndeterminate="True" Height="8" Margin="0,18,0,0"/>
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.Row="2" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="14,0">
            <Grid>
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}"/>
                <ProgressBar HorizontalAlignment="Right" Width="150" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
