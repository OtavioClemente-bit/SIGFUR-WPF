<Window x:Class="SIGFUR.Wpf.Views.Military.MilitaryEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIGFUR — Editar Militar" Width="1120" Height="780" MinWidth="900" MinHeight="620"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResize" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico"
        Loaded="Window_Loaded">
<Grid>
        <Grid.RowDefinitions><RowDefinition Height="46"/><RowDefinition Height="*"/><RowDefinition Height="66"/></Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="14,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Image Source="/Assets/sigfur.png" Width="28" Height="28" Stretch="Uniform" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="CADASTRO DO MILITAR" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="Cadastro e edição" FontSize="10" Foreground="{DynamicResource MutedBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="18">
                <Grid.ColumnDefinitions><ColumnDefinition Width="250"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <!-- Foto e resumo -->
                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource CardStyle}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Foto do militar" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,12"/>
                            <Border Height="285" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="13" ClipToBounds="True">
                                <Grid>
                                    <TextBlock Text="SEM FOTO" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource SubtleTextBrush}" FontWeight="SemiBold"/>
                                    <Image x:Name="PhotoPreview" Source="{Binding Military.PhotoPath}" Stretch="UniformToFill"/>
                                </Grid>
                            </Border>
                            <Button Style="{StaticResource SecondaryButtonStyle}" Content="Selecionar foto…" Click="ChoosePhoto_Click" Margin="0,12,0,0"/>
                            <Button Style="{StaticResource GhostButtonStyle}" Content="Remover foto" Click="RemovePhoto_Click" Margin="0,7,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SoftCardStyle}" Padding="14" Margin="0,14,0,0">
                        <StackPanel>
                            <TextBlock Text="Orientações" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,7"/>
                            <TextBlock Text="• Campos obrigatórios ou inválidos podem ficar vermelhos enquanto você digita.&#x0a;• CPF, PREC-CP e IDT são validados contra duplicidade.&#x0a;• Datas podem ser informadas em dd/mm/aaaa.&#x0a;• Telefone, e-mail e CEP são conferidos antes de salvar." TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" LineHeight="20"/>
                            <CheckBox x:Name="LiveValidationCheck" Content="Destacar inválidos em vermelho" IsChecked="True" Checked="ValidationMode_Changed" Unchecked="ValidationMode_Changed" Margin="0,12,0,0"/>
                            <TextBlock x:Name="ValidationSummaryText" Text="" TextWrapping="Wrap" Foreground="#B3261E" FontSize="11" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Formulário -->
                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Identificação" Style="{StaticResource PageTitleStyle}" FontSize="22"/>
                            <TextBlock Text="Dados essenciais do cadastro e identificação militar." Style="{StaticResource SubtleTextStyle}" Margin="0,3,0,16"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="Posto/Graduação *" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><ComboBox x:Name="RankBox" ItemsSource="{Binding Ranks}" IsEditable="True" Text="{Binding Military.Rank, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Text="Ano de formação" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><TextBox x:Name="FormationYearBox" Text="{Binding Military.FormationYear, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                            </Grid>
                            <TextBlock Text="Nome completo *" Style="{StaticResource CaptionTextStyle}" Margin="0,13,0,4"/>
                            <TextBox x:Name="NameBox" Text="{Binding Military.Name, UpdateSourceTrigger=PropertyChanged}" CharacterCasing="Upper"/>
                            <Grid Margin="0,13,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="Nome de guerra *" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><TextBox x:Name="WarNameBox" Text="{Binding Military.WarName, UpdateSourceTrigger=PropertyChanged}" CharacterCasing="Upper"/></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Text="CPF *" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><TextBox x:Name="CpfBox" Text="{Binding Military.Cpf, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                            </Grid>
                            <Grid Margin="0,13,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="PREC-CP *" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><TextBox x:Name="PrecBox" Text="{Binding Military.PrecCp, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Text="IDT militar *" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><TextBox x:Name="MilitaryIdBox" Text="{Binding Military.MilitaryId, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                            </Grid>
                            <Grid Margin="0,13,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="Data de nascimento" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><TextBox x:Name="BirthDateBox" Text="{Binding Military.BirthDate, UpdateSourceTrigger=PropertyChanged}" ToolTip="dd/mm/aaaa"/></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Text="Data de praça" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><TextBox x:Name="EnlistmentDateBox" Text="{Binding Military.EnlistmentDate, UpdateSourceTrigger=PropertyChanged}" ToolTip="dd/mm/aaaa"/></StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Contato e endereço" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,14"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="Telefone" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><TextBox x:Name="PhoneBox" Text="{Binding Military.Phone, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Text="E-mail" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><TextBox x:Name="EmailBox" Text="{Binding Military.Email, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                            </Grid>
                            <TextBlock Text="Endereço" Style="{StaticResource CaptionTextStyle}" Margin="0,13,0,4"/>
                            <TextBox x:Name="AddressBox" Text="{Binding Military.Address, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="72" VerticalContentAlignment="Top"/>
                            <TextBlock Text="CEP" Style="{StaticResource CaptionTextStyle}" Margin="0,13,0,4"/>
                            <TextBox x:Name="ZipCodeBox" Text="{Binding Military.ZipCode, UpdateSourceTrigger=PropertyChanged}" Width="220" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Dados bancários" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,14"/>
                            <TextBlock Text="Banco" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="BankBox" ItemsSource="{Binding Banks}" IsEditable="True" Text="{Binding Military.Bank, UpdateSourceTrigger=PropertyChanged}"/>
                            <Grid Margin="0,13,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="Agência" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><TextBox x:Name="AgencyBox" Text="{Binding Military.Agency, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Text="Conta" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><TextBox x:Name="AccountBox" Text="{Binding Military.Account, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Benefícios e situações financeiras" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,14"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="Recebe Pré-Escolar" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><ComboBox x:Name="PreSchoolCombo" ItemsSource="{Binding YesNo}" SelectedItem="{Binding Military.ReceivesPreSchool}"/></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Text="Valor Pré-Escolar" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><TextBox x:Name="PreSchoolValueBox" Text="{Binding Military.PreSchoolValue, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                            </Grid>
                            <Grid Margin="0,13,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="Recebe Auxílio-Transporte" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><ComboBox x:Name="TransportCombo" ItemsSource="{Binding YesNo}" SelectedItem="{Binding Military.ReceivesTransportAid}"/></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Text="Valor Auxílio-Transporte" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><TextBox x:Name="TransportAidValueBox" Text="{Binding Military.TransportAidValue, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                            </Grid>
                            <Grid Margin="0,13,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="Possui PNR" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><ComboBox x:Name="PnrCombo" ItemsSource="{Binding YesNo}" SelectedItem="{Binding Military.HasPnr}"/></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Text="Pensão alimentícia" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><ComboBox x:Name="AlimonyCombo" ItemsSource="{Binding YesNo}" SelectedItem="{Binding Military.Alimony}"/></StackPanel>
                                <StackPanel Grid.Column="4"><TextBlock Text="Valor da pensão" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><TextBox x:Name="AlimonyValueBox" Text="{Binding Military.AlimonyValue, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                            </Grid>
                            <CheckBox Content="Militar Adido/Encostado — bloquear Auxílio-Transporte" IsChecked="{Binding Military.IsAttached}" Margin="0,16,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="1" Background="{DynamicResource OverlayBrush}" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" Panel.ZIndex="100">
            <Border Width="410" Padding="26" CornerRadius="18" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderStrongBrush}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <Image Source="/Assets/sigfur.png" Width="72" Height="72" Stretch="Uniform" HorizontalAlignment="Center"/>
                    <TextBlock Text="Preparando cadastro" Style="{StaticResource SectionTitleStyle}" FontSize="19" HorizontalAlignment="Center" Margin="0,14,0,5"/>
                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource SubtleTextStyle}" TextAlignment="Center" TextWrapping="Wrap"/>
                    <ProgressBar IsIndeterminate="True" Height="8" Margin="0,18,0,0"/>
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.Row="2" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="18,10">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource MutedBrush}"/>
                    <ProgressBar Width="210" HorizontalAlignment="Left" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" Margin="0,5,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Cancelar" Click="Cancel_Click" Margin="0,0,9,0"/>
                    <Button Style="{StaticResource PrimaryButtonStyle}" Content="Salvar alterações" Click="Save_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
