<Window x:Class="SIGFUR.Wpf.Views.Military.MilitaryExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIGFUR — Exportar militares" Width="760" Height="720" MinWidth="640" MinHeight="560"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResize" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="78"/><RowDefinition Height="*"/><RowDefinition Height="64"/></Grid.RowDefinitions>
        <Border Background="{DynamicResource PrimaryBrush}" Padding="20,0">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="EXPORTAR RELAÇÃO" Foreground="White" FontWeight="Bold" FontSize="19"/>
                    <TextBlock x:Name="ScopeSummary" Foreground="#D7E9FF" Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions><ColumnDefinition Width="245"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Border Style="{StaticResource CardStyle}" Padding="16">
                <StackPanel>
                    <TextBlock Text="Origem dos dados" Style="{StaticResource SectionTitleStyle}"/>
                    <RadioButton x:Name="SelectedOnlyRadio" Content="Somente selecionados" Margin="0,12,0,5" Checked="Scope_Changed"/>
                    <RadioButton x:Name="VisibleRadio" Content="Todos os visíveis na tabela" Margin="0,5" Checked="Scope_Changed"/>
                    <Separator Margin="0,14"/>
                    <TextBlock Text="Formato do arquivo" Style="{StaticResource SectionTitleStyle}"/>
                    <ComboBox x:Name="FormatCombo" Margin="0,10,0,0" SelectionChanged="Format_Changed">
                        <ComboBoxItem Content="Excel (.xlsx)"/>
                        <ComboBoxItem Content="CSV (.csv)"/>
                        <ComboBoxItem Content="Texto tabulado (.txt)"/>
                    </ComboBox>
                    <Border Background="{DynamicResource PrimarySoftBrush}" CornerRadius="10" Padding="11" Margin="0,16,0,0">
                        <TextBlock Text="No Excel, o cabeçalho fica colorido, a tabela recebe filtros e o nome de guerra aparece em negrito dentro do nome completo." TextWrapping="Wrap" Foreground="{DynamicResource PrimaryDarkBrush}"/>
                    </Border>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <TextBlock Text="Campos da exportação" Style="{StaticResource SectionTitleStyle}"/>
                    <WrapPanel Grid.Row="1" Margin="0,10,0,10">
                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="Essenciais" Click="Essential_Click" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="Marcar todos" Click="All_Click" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource GhostButtonStyle}" Content="Desmarcar todos" Click="None_Click"/>
                    </WrapPanel>
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <UniformGrid x:Name="ColumnsPanel" Columns="2"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
        <Border Grid.Row="2" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="18,0">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Cancelar" Click="Cancel_Click" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource PrimaryButtonStyle}" Content="Exportar" Click="Export_Click" MinWidth="130"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
