<Window x:Class="SIGFUR.Wpf.Views.Military.PaystubExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exportar contracheques" Width="620" Height="390"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico">
    <Grid Margin="16">
        <Border Style="{StaticResource CardStyle}" Padding="22">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <TextBlock Text="Exportar contracheques salvos" Style="{StaticResource PageTitleStyle}" FontSize="21"/>
                <TextBlock x:Name="SummaryText" Grid.Row="1" Style="{StaticResource SubtleTextStyle}" Margin="0,4,0,16" TextWrapping="Wrap"/>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <StackPanel><TextBlock Text="Mês" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><ComboBox x:Name="MonthBox"/></StackPanel>
                    <StackPanel Grid.Column="2"><TextBlock Text="Ano" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><ComboBox x:Name="YearBox" IsEditable="True"/></StackPanel>
                </Grid>
                <TextBlock Grid.Row="3" Text="Pasta de destino" Style="{StaticResource CaptionTextStyle}" Margin="0,14,0,4"/>
                <Grid Grid.Row="4"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="FolderBox" IsReadOnly="True"/><Button Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}" Content="Escolher…" Click="ChooseFolder_Click"/></Grid>
                <Border Grid.Row="5" Background="{DynamicResource PrimarySurfaceBrush}" CornerRadius="9" Padding="12" Margin="0,15,0,0">
                    <TextBlock Text="A busca considera CPF, PREC-CP, IDT, nome e a referência mês/ano do arquivo. PDFs com outro mês explícito são rejeitados." TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}"/>
                </Border>
                <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Cancelar" IsCancel="True" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource PrimaryButtonStyle}" Content="Exportar" IsDefault="True" Click="Export_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
