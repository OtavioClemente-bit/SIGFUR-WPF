<Window x:Class="SIGFUR.Wpf.Views.QuickSearchWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SIGFUR.Wpf.Controls"
        Title="Consulta rápida — Carteira" Width="820" Height="560" MinWidth="680" MinHeight="460" WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel><TextBlock Text="Consulta rápida — Carteira" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryDarkBrush}"/><TextBlock Text="Pesquise por nome, nome de guerra, CPF ou posto/graduação." Foreground="{DynamicResource MutedBrush}" Margin="0,4,0,12"/></StackPanel>
        <TextBox x:Name="SearchBox" Grid.Row="1" TextChanged="SearchBox_TextChanged" KeyDown="SearchBox_KeyDown"/>
        <DataGrid x:Name="MilitaryGrid" Grid.Row="2" Margin="0,12,0,12" IsReadOnly="True" MouseDoubleClick="MilitaryGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="P/G" Binding="{Binding Rank}" Width="100"/>
                <DataGridTemplateColumn Header="Nome completo" Width="*"><DataGridTemplateColumn.CellTemplate><DataTemplate><controls:HighlightedNameTextBlock FullName="{Binding Name}" WarName="{Binding WarName}" TextWrapping="Wrap"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                <DataGridTextColumn Header="CPF" Binding="{Binding Cpf}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Fechar" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/><Button Content="Abrir carteira" IsDefault="True" Style="{StaticResource PrimaryButtonStyle}" Click="Open_Click"/></StackPanel>
    </Grid>
</Window>
