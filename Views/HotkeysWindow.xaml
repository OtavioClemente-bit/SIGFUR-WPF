<Window x:Class="SIGFUR.Wpf.Views.HotkeysWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gerenciar Atalhos" Width="800" Height="630" MinWidth="680" MinHeight="520" WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel><TextBlock Text="⌨️ Gerenciar Atalhos" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryDarkBrush}"/><TextBlock Text="Use formatos como Ctrl+N, Ctrl+Alt+E, F2 ou Alt+F4. Atalhos duplicados não são permitidos." Foreground="{DynamicResource MutedBrush}" Margin="0,4,0,12"/></StackPanel>
        <DataGrid x:Name="Grid" Grid.Row="1" IsReadOnly="False" AutoGenerateColumns="False">
            <DataGrid.Columns><DataGridTextColumn Header="Ação" Binding="{Binding Title}" IsReadOnly="True" Width="*"/><DataGridTextColumn Header="Atalho" Binding="{Binding HotKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="180"/></DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0"><Button Content="Restaurar padrões" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" Click="Defaults_Click"/><Button Content="Cancelar" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/><Button Content="Salvar" Style="{StaticResource PrimaryButtonStyle}" IsDefault="True" Click="Save_Click"/></StackPanel>
    </Grid>
</Window>
