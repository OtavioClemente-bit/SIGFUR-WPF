<Window x:Class="SIGFUR.Wpf.Views.CalendarDayEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agenda do dia" Height="660" Width="960"
        MinHeight="580" MinWidth="840"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}">
    <Window.Resources>
        <Style x:Key="EditorLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="EditorTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>
        <Style x:Key="EditorComboStyle" TargetType="ComboBox">
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}" Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="TitleText" Style="{StaticResource PageTitleStyle}" FontSize="18"/>
                    <TextBlock Text="Gerencie compromissos deste dia, marque serviço e registre observações com salvamento automático no calendário operacional." Margin="0,4,0,0" Style="{StaticResource PageSubtitleStyle}"/>
                </StackPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                    <Button Content="Marcar serviço" Click="QuickService_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="Novo evento" Click="NewEvent_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.12*"/>
                <ColumnDefinition Width="0.88*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="Registros do dia" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Clique em um item para editar os dados ao lado." Style="{StaticResource CaptionTextStyle}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <DataGrid x:Name="EventsGrid" Grid.Row="1" Margin="0,14,0,0" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="EventsGrid_SelectionChanged" HeadersVisibility="Column" RowHeaderWidth="0" GridLinesVisibility="Horizontal">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="MinHeight" Value="36"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tipo" Binding="{Binding Type}" Width="100"/>
                            <DataGridTextColumn Header="Título" Binding="{Binding Title}" Width="180"/>
                            <DataGridTextColumn Header="Descrição" Binding="{Binding Description}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="Editar / criar" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Cadastre um evento, serviço, pagamento ou observação para o dia selecionado." Style="{StaticResource CaptionTextStyle}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,16,0,0">
                        <TextBlock Text="Tipo" Style="{StaticResource EditorLabelStyle}"/>
                        <ComboBox x:Name="TypeCombo" SelectedIndex="0" Style="{StaticResource EditorComboStyle}">
                            <ComboBoxItem Content="Evento"/>
                            <ComboBoxItem Content="Serviço"/>
                            <ComboBoxItem Content="Pagamento"/>
                            <ComboBoxItem Content="Observação"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,14,0,0">
                        <TextBlock Text="Título" Style="{StaticResource EditorLabelStyle}"/>
                        <TextBox x:Name="TitleBox" Style="{StaticResource EditorTextBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,14,0,0">
                        <TextBlock Text="Descrição / detalhes" Style="{StaticResource EditorLabelStyle}"/>
                        <TextBox x:Name="DescriptionBox" Style="{StaticResource EditorTextBoxStyle}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="260" Padding="12,10"/>
                    </StackPanel>

                    <WrapPanel Grid.Row="4" Margin="0,18,0,0">
                        <Button Content="Salvar" Click="Save_Click" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="Excluir" Click="Delete_Click" Style="{StaticResource DangerButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="Limpar" Click="Clear_Click" Style="{StaticResource SecondaryButtonStyle}"/>
                    </WrapPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="14,12">
            <DockPanel LastChildFill="False">
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}"/>
                <Button Content="Fechar" DockPanel.Dock="Right" Click="Close_Click" Style="{StaticResource SecondaryButtonStyle}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
