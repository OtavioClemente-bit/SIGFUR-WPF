<Window x:Class="SIGFUR.Wpf.Views.Shared.SigfurDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIGFUR" Width="500" SizeToContent="Height" MaxHeight="720"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent" ShowInTaskbar="False"
        Icon="/Assets/sigfur.ico" KeyDown="Window_KeyDown">
    <Border Margin="18" Background="{DynamicResource SurfaceElevatedBrush}"
            BorderBrush="{DynamicResource BorderStrongBrush}" BorderThickness="1"
            CornerRadius="18">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="8" Opacity="0.28" Color="#20000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="HeaderBorder" CornerRadius="17,17,0,0" Padding="20,15"
                    Background="{DynamicResource PrimarySurfaceBrush}"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="IconBadge" Width="42" Height="42" CornerRadius="12"
                            Background="{DynamicResource PrimarySoftBrush}" Margin="0,0,13,0">
                        <TextBlock x:Name="IconText" Text="?" FontSize="21" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource PrimaryDarkBrush}"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="CaptionText" Text="SIGFUR" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryDarkBrush}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="CategoryText" Text="Confirmação do sistema" Margin="0,2,0,0"
                                   Style="{StaticResource CaptionTextStyle}"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="✕" Style="{StaticResource GhostButtonStyle}"
                            Width="34" Height="34" Padding="0" Click="Close_Click"
                            ToolTip="Fechar"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" MaxHeight="430" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="MessageText" Margin="24,22,24,20" FontSize="13"
                           LineHeight="21" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}"/>
            </ScrollViewer>

            <Border Grid.Row="2" Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,17,17" Padding="18,14">
                <StackPanel x:Name="ButtonsPanel" Orientation="Horizontal" HorizontalAlignment="Right"/>
            </Border>
        </Grid>
    </Border>
</Window>
