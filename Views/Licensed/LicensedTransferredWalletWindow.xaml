<Window x:Class="SIGFUR.Wpf.Views.Licensed.LicensedTransferredWalletWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SIGFUR.Wpf.Controls"
        Title="Carteira — Licenciado/Transferido" Width="1080" Height="780" MinWidth="900" MinHeight="650"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico" Loaded="Window_Loaded">
    <Grid Margin="18">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Style="{StaticResource CardStyle}" Padding="18" Margin="0,0,0,12">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="18"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <Border Width="96" Height="108" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="12" ClipToBounds="True"><Image x:Name="PhotoImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" MouseLeftButtonDown="PhotoImage_MouseLeftButtonDown" ToolTip="Duplo clique para abrir a foto"/></Border>
                <StackPanel Grid.Column="2" VerticalAlignment="Center"><TextBlock Text="CARTEIRA — LICENCIADO / TRANSFERIDO" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold" FontSize="12"/><WrapPanel Margin="0,4,0,3"><TextBlock x:Name="RankText" FontSize="22" FontWeight="SemiBold" Margin="0,0,8,0"/><controls:HighlightedNameTextBlock x:Name="NameText" FontSize="22"/></WrapPanel><TextBlock x:Name="IdentityText" FontSize="13"/><TextBlock x:Name="SituationText" Style="{StaticResource SubtleTextStyle}" Margin="0,4,0,0"/></StackPanel>
                <StackPanel Grid.Column="3"><Button Content="Editar cadastro" Style="{StaticResource PrimaryButtonStyle}" Click="Edit_Click" Margin="0,0,0,7"/><Button Content="Restaurar para ativos" Style="{StaticResource SecondaryButtonStyle}" Click="Restore_Click"/></StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="12">
            <TabControl x:Name="Tabs">
                <TabItem Header="Resumo"><ScrollViewer VerticalScrollBarVisibility="Auto"><Grid Margin="14"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <StackPanel><GroupBox Header="Identificação"><TextBlock x:Name="IdentificationText" Margin="14" TextWrapping="Wrap" LineHeight="24" MouseLeftButtonDown="InformationText_MouseLeftButtonDown"/></GroupBox><GroupBox Header="Contato e endereço" Margin="0,12,0,0"><TextBlock x:Name="ContactText" Margin="14" TextWrapping="Wrap" LineHeight="24" MouseLeftButtonDown="InformationText_MouseLeftButtonDown"/></GroupBox></StackPanel>
                    <StackPanel Grid.Column="2"><GroupBox Header="Dados bancários e datas"><TextBlock x:Name="BankDateText" Margin="14" TextWrapping="Wrap" LineHeight="24" MouseLeftButtonDown="InformationText_MouseLeftButtonDown"/></GroupBox><GroupBox Header="Benefícios e registros" Margin="0,12,0,0"><TextBlock x:Name="BenefitsText" Margin="14" TextWrapping="Wrap" LineHeight="24" MouseLeftButtonDown="InformationText_MouseLeftButtonDown"/></GroupBox></StackPanel>
                </Grid></ScrollViewer></TabItem>
                <TabItem Header="Contracheques"><Grid Margin="12"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><StackPanel Orientation="Horizontal" Margin="0,0,0,10"><Button Content="Abrir selecionado" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" Click="OpenPaystub_Click"/><Button Content="Abrir pasta" Style="{StaticResource GhostButtonStyle}" Margin="8,0,0,0" Click="OpenPaystubFolder_Click"/><Button Content="Excluir selecionado" Style="{StaticResource DangerButtonStyle}" Margin="8,0,0,0" Click="DeletePaystub_Click"/></StackPanel><DataGrid x:Name="PaystubGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" MouseDoubleClick="PaystubGrid_MouseDoubleClick"><DataGrid.Columns><DataGridTextColumn Header="Arquivo" Binding="{Binding FileName}" Width="*"/><DataGridTextColumn Header="Referência" Binding="{Binding Reference}" Width="130"/><DataGridTextColumn Header="Alterado em" Binding="{Binding ModifiedAt, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/><DataGridTextColumn Header="Tamanho" Binding="{Binding SizeText}" Width="100"/></DataGrid.Columns></DataGrid></Grid></TabItem>
                <TabItem Header="Ficha Financeira"><Grid Margin="12"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><WrapPanel Margin="0,0,0,10"><Button Content="Atualizar lista" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" Click="RefreshFinancialStatements_Click"/><Button Content="Abrir selecionada" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" Click="OpenFinancialStatement_Click"/><Button Content="Abrir pasta" Style="{StaticResource GhostButtonStyle}" Margin="8,0,0,0" Click="OpenFinancialStatementFolder_Click"/></WrapPanel><DataGrid x:Name="FinancialStatementGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" MouseDoubleClick="FinancialStatementGrid_MouseDoubleClick"><DataGrid.Columns><DataGridTextColumn Header="Arquivo" Binding="{Binding FileName}" Width="*"/><DataGridTextColumn Header="Referência" Binding="{Binding Reference}" Width="130"/><DataGridTextColumn Header="Alterado em" Binding="{Binding ModifiedAt, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/><DataGridTextColumn Header="Tamanho" Binding="{Binding SizeText}" Width="100"/></DataGrid.Columns></DataGrid></Grid></TabItem>
                <TabItem Header="Documentos"><Grid Margin="12"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><StackPanel Orientation="Horizontal" Margin="0,0,0,10"><Button Content="Adicionar documento" Style="{StaticResource PrimaryButtonStyle}" Click="AddDocument_Click"/><Button Content="Abrir" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" Click="OpenDocument_Click"/><Button Content="Reprocessar OCR" Style="{StaticResource GhostButtonStyle}" Margin="8,0,0,0" Click="ReprocessOcr_Click"/><Button Content="Abrir pasta" Style="{StaticResource GhostButtonStyle}" Margin="8,0,0,0" Click="OpenDocumentFolder_Click"/><Button Content="Remover registro" Style="{StaticResource DangerButtonStyle}" Margin="8,0,0,0" Click="RemoveDocument_Click"/></StackPanel><DataGrid x:Name="DocumentGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" MouseDoubleClick="DocumentGrid_MouseDoubleClick"><DataGrid.Columns><DataGridTextColumn Header="Tipo" Binding="{Binding Type}" Width="150"/><DataGridTextColumn Header="Título" Binding="{Binding Title}" Width="*"/><DataGridTextColumn Header="Salvo em" Binding="{Binding SavedAt}" Width="150"/><DataGridTextColumn Header="OCR" Binding="{Binding OcrStatus}" Width="120"/><DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="150"/></DataGrid.Columns></DataGrid></Grid></TabItem>
                <TabItem Header="Auxílio-Transporte"><Grid Margin="12"><Grid.ColumnDefinitions><ColumnDefinition Width="300"/><ColumnDefinition Width="16"/><ColumnDefinition/></Grid.ColumnDefinitions><DataGrid x:Name="FareGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"><DataGrid.Columns><DataGridTextColumn Header="#" Binding="{Binding Index}" Width="60"/><DataGridTextColumn Header="Tarifa" Binding="{Binding Display}" Width="*"/></DataGrid.Columns></DataGrid><Border Grid.Column="2" Style="{StaticResource SoftCardStyle}" Padding="18"><StackPanel><TextBlock Text="Último cálculo preservado" Style="{StaticResource SectionTitleStyle}"/><TextBlock x:Name="TransportSummaryText" Margin="0,12,0,0" FontSize="14" TextWrapping="Wrap" LineHeight="26"/></StackPanel></Border></Grid></TabItem>
            </TabControl>
        </Border>
        <Grid Grid.Row="2" Margin="0,12,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock x:Name="StatusText" VerticalAlignment="Center" Style="{StaticResource SubtleTextStyle}"/><Button Grid.Column="1" Content="Copiar dados" Style="{StaticResource GhostButtonStyle}" Click="Copy_Click"/><Button Grid.Column="3" Content="Exportar carteira ZIP" Style="{StaticResource SecondaryButtonStyle}" Click="Export_Click"/><Button Grid.Column="5" Content="Fechar" Style="{StaticResource PrimaryButtonStyle}" IsCancel="True"/></Grid>
    </Grid>
</Window>
