<Window x:Class="SIGFUR.Wpf.Views.Licensed.LicensedTransferredWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SIGFUR.Wpf.Controls"
        Title="SIGFUR — Licenciados / Transferidos" Width="1540" Height="880" MinWidth="1180" MinHeight="680"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico"
        Loaded="Window_Loaded" PreviewKeyDown="Window_PreviewKeyDown">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="66"/><RowDefinition Height="*"/><RowDefinition Height="34"/></Grid.RowDefinitions>
        <Border Background="{DynamicResource PrimaryDarkBrush}" Padding="20,0">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center"><TextBlock Text="LICENCIADOS / TRANSFERIDOS" Foreground="White" FontWeight="Bold" FontSize="18"/><TextBlock Text="Carteiras, documentos, contracheques CPEX/SIPPES e restauração ao efetivo" Foreground="{DynamicResource TextOnPrimaryMutedBrush}" FontSize="11"/></StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"><Button Content="Nova ficha" Style="{StaticResource LightOnDarkButtonStyle}" MinWidth="118" Padding="16,9" Click="New_Click"/></StackPanel>
            </Grid>
        </Border>
        <Grid Grid.Row="1" Margin="16"><Grid.ColumnDefinitions><ColumnDefinition Width="320"/><ColumnDefinition Width="14"/><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition Width="360"/></Grid.ColumnDefinitions>
            <Border Style="{StaticResource CardStyle}" Padding="16">
                <Border.Resources>
                    <Style x:Key="LicensedSideButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarActionButtonStyle}">
                        <Setter Property="MinHeight" Value="40"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Setter Property="Margin" Value="0,0,0,7"/>
                    </Style>
                </Border.Resources>
                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <TextBlock Text="Pesquisa e visualização" Style="{StaticResource SectionTitleStyle}"/>
                <StackPanel Grid.Row="1" Margin="0,10,0,0"><TextBlock Text="Nome, guerra, CPF, PREC, IDT, motivo, destino..." Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged"/></StackPanel>
                <CheckBox x:Name="ShowHiddenBox" Grid.Row="2" Content="Mostrar registros arquivados" Margin="0,12,0,12" Checked="ShowHiddenBox_Changed" Unchecked="ShowHiddenBox_Changed"/>
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"><StackPanel>
                    <TextBlock Text="Ficha selecionada" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,8"/>
                    <Button Content="Abrir carteira" Style="{StaticResource PrimaryButtonStyle}" Click="Wallet_Click" Margin="0,0,0,7"/>
                    <Button Content="Editar cadastro" Style="{StaticResource LicensedSideButtonStyle}" Click="Edit_Click"/>
                    <Button Content="Baixar contracheque CPEX/SIPPES" Style="{StaticResource LicensedSideButtonStyle}" Click="Paystub_Click" ToolTip="Baixa somente contracheques; não acessa ficha financeira."/>
                    <Button Content="Abrir contracheques salvos" Style="{StaticResource LicensedSideButtonStyle}" Click="OpenPaystubFolder_Click"/>
                    <Button Content="Copiar formato" Style="{StaticResource LicensedSideButtonStyle}" Click="CopyFormat_Click"/>
                    <Button Content="Arquivar / reexibir" Style="{StaticResource LicensedSideButtonStyle}" Click="ToggleVisible_Click"/>
                    <Button Content="Restaurar para lista principal" Style="{StaticResource LicensedSideButtonStyle}" Click="Restore_Click"/>
                    <Separator Margin="0,12"/>
                    <TextBlock Text="Dados e arquivos" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,8"/>
                    <Button Content="Exportar tabela..." Style="{StaticResource LicensedSideButtonStyle}" Click="ExportTable_Click" ToolTip="Escolha CSV ou Excel, registros e colunas."/>
                    <Button Content="Importar CSV/Excel" Style="{StaticResource LicensedSideButtonStyle}" Click="Import_Click"/>
                    <Button Content="Exportar carteira completa" Style="{StaticResource LicensedSideButtonStyle}" Click="ExportWallet_Click"/>
                </StackPanel></ScrollViewer>
                <Button Grid.Row="4" Content="Excluir definitivamente" Style="{StaticResource DangerButtonStyle}" Margin="0,12,0,0" Click="Delete_Click"/>
            </Grid></Border>

            <Grid Grid.Column="2"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <Border Style="{StaticResource MetricCardStyle}"><StackPanel><TextBlock Text="CADASTRADOS" Style="{StaticResource MetricCaptionStyle}"/><TextBlock x:Name="TotalText" Text="0" Style="{StaticResource MetricValueStyle}"/></StackPanel></Border>
                    <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}"><StackPanel><TextBlock Text="EXIBIDOS" Style="{StaticResource MetricCaptionStyle}"/><TextBlock x:Name="VisibleText" Text="0" Style="{StaticResource MetricValueStyle}"/></StackPanel></Border>
                    <Border Grid.Column="4" Style="{StaticResource SoftMetricCardStyle}"><StackPanel><TextBlock Text="SELECIONADOS" Style="{StaticResource MetricCaptionStyle}"/><TextBlock x:Name="SelectedText" Text="0" Style="{StaticResource MetricValueStyle}"/></StackPanel></Border>
                </Grid>
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="4"><DataGrid x:Name="MilitaryGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" SelectionMode="Extended" SelectionUnit="FullRow" SelectionChanged="MilitaryGrid_SelectionChanged" MouseDoubleClick="MilitaryGrid_MouseDoubleClick" Sorting="MilitaryGrid_Sorting">
                    <DataGrid.ContextMenu><ContextMenu><MenuItem Header="Abrir carteira" Click="Wallet_Click"/><MenuItem Header="Editar" Click="Edit_Click"/><Separator/><MenuItem Header="Baixar contracheque CPEX/SIPPES" Click="Paystub_Click"/><MenuItem Header="Abrir contracheques salvos" Click="OpenPaystubFolder_Click"/><Separator/><MenuItem Header="Copiar formato" Click="CopyFormat_Click"/><MenuItem Header="Arquivar / reexibir" Click="ToggleVisible_Click"/><MenuItem Header="Restaurar para ativos" Click="Restore_Click"/></ContextMenu></DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="P/G" Binding="{Binding ShortRank}" Width="85" SortMemberPath="Rank"/>
                        <DataGridTemplateColumn Header="Nome completo" Width="*" MinWidth="260" SortMemberPath="Name"><DataGridTemplateColumn.CellTemplate><DataTemplate><controls:HighlightedNameTextBlock FullName="{Binding Name}" WarName="{Binding WarName}" VerticalAlignment="Center" TextWrapping="Wrap"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                        <DataGridTextColumn Header="PREC-CP" Binding="{Binding FormattedPrecCp}" Width="125" SortMemberPath="PrecCp"/>
                        <DataGridTextColumn Header="CPF" Binding="{Binding FormattedCpf}" Width="135" SortMemberPath="Cpf"/>
                        <DataGridTextColumn Header="Motivo" Binding="{Binding Reason}" Width="140" SortMemberPath="Reason"/>
                        <DataGridTextColumn Header="Destino / OM" Binding="{Binding Destination}" Width="170" SortMemberPath="Destination"/>
                        <DataGridTextColumn Header="Ano" Binding="{Binding FormationYear}" Width="75" SortMemberPath="FormationYear"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="95" SortMemberPath="IsVisible"/>
                    </DataGrid.Columns>
                </DataGrid></Border>
            </Grid>

            <Border Grid.Column="4" Style="{StaticResource CardStyle}" Padding="16"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <TextBlock Text="Resumo da seleção" Style="{StaticResource SectionTitleStyle}"/>
                <Border Grid.Row="1" Height="150" MaxWidth="220" HorizontalAlignment="Center" Margin="0,12" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="12" ClipToBounds="True"><Image x:Name="PreviewImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/></Border>
                <StackPanel Grid.Row="2"><WrapPanel><TextBlock x:Name="SelectedRankText" FontSize="17" FontWeight="SemiBold" Margin="0,0,7,0" VerticalAlignment="Center"/><controls:HighlightedNameTextBlock x:Name="SelectedNameText" FontSize="17" TextWrapping="Wrap" MaxWidth="285"/></WrapPanel><TextBlock x:Name="SelectedIdentityText" Margin="0,5,0,0" TextWrapping="Wrap"/><Border Background="{DynamicResource PrimarySoftBrush}" CornerRadius="10" Padding="10" Margin="0,12,0,12"><TextBlock x:Name="SelectedSituationText" TextWrapping="Wrap"/></Border></StackPanel>
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"><TextBlock x:Name="SelectedDetailsText" TextWrapping="Wrap" LineHeight="24"/></ScrollViewer>
            </Grid></Border>
        </Grid>
        <Border Grid.Row="2" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0" Padding="16,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock x:Name="StatusText" VerticalAlignment="Center" Text="Pronto."/><TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{DynamicResource SubtleTextBrush}" Text="Duplo clique copia a célula  •  Esc limpa  •  Ctrl+F pesquisa  •  Enter abre a carteira"/></Grid></Border>
    </Grid>
</Window>
