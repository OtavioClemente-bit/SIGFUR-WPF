<Window x:Class="SIGFUR.Wpf.Views.Vacation.VacationBulletinReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIGFUR — Conferir férias publicadas" Width="1180" Height="720" MinWidth="920" MinHeight="560"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="84"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="54"/></Grid.RowDefinitions>
        <Border Background="{DynamicResource PrimaryGradientBrush}" Padding="24,0"><StackPanel VerticalAlignment="Center"><TextBlock Text="CONFERIR PUBLICAÇÕES DE FÉRIAS" Foreground="White" FontSize="23" FontWeight="Bold"/><TextBlock Text="Achados do Boletim Inteligente relacionados a férias. Revise antes de aplicar qualquer movimentação." Foreground="#DCEBFF" Margin="0,5,0,0"/></StackPanel></Border>
        <Border Grid.Row="1" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,12"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="1.5*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="90"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="SearchBox" ToolTip="Pesquisar militar, boletim ou contexto" TextChanged="SearchBox_TextChanged"/><ComboBox x:Name="PeriodBox" Grid.Column="2" DisplayMemberPath="FullLabel"/><ComboBox x:Name="DaysBox" Grid.Column="4" SelectedIndex="2"><ComboBoxItem Content="10"/><ComboBoxItem Content="15"/><ComboBoxItem Content="30"/></ComboBox><Button Grid.Column="5" Content="Atualizar índice" Style="{StaticResource SecondaryButtonStyle}" Click="Refresh_Click" Margin="10,0,0,0"/></Grid></Border>
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="16,12" Padding="10"><DataGrid x:Name="FindingsGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" SelectionMode="Extended" SelectionUnit="FullRow" MouseDoubleClick="FindingsGrid_MouseDoubleClick"><DataGrid.Columns><DataGridTextColumn Header="BI" Binding="{Binding Finding.Bulletin}" Width="80"/><DataGridTextColumn Header="Data" Binding="{Binding Finding.BulletinDate}" Width="95"/><DataGridTextColumn Header="P/G" Binding="{Binding Finding.Rank}" Width="90"/><DataGridTextColumn Header="Militar" Binding="{Binding Finding.DisplayMilitary}" Width="230"/><DataGridTextColumn Header="Detalhe / contexto" Binding="{Binding Summary}" Width="*"/><DataGridTextColumn Header="Cadastro" Binding="{Binding MatchStatus}" Width="120"/><DataGridTextColumn Header="Revisão" Binding="{Binding Finding.ReviewedText}" Width="90"/></DataGrid.Columns></DataGrid></Border>
        <Border Grid.Row="3" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="16,0"><Grid><TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}"/><StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"><Button Content="Abrir PDF" Style="{StaticResource SecondaryButtonStyle}" Click="OpenPdf_Click" Margin="0,0,8,0"/><Button Content="Marcar revisado" Style="{StaticResource SecondaryButtonStyle}" Click="MarkReviewed_Click" Margin="0,0,8,0"/><Button Content="Aplicar no período" Style="{StaticResource PrimaryButtonStyle}" Click="Apply_Click" Margin="0,0,8,0"/><Button Content="Fechar" Style="{StaticResource GhostButtonStyle}" Click="Close_Click"/></StackPanel></Grid></Border>
    </Grid>
</Window>
