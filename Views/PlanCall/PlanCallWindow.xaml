<Window x:Class="SIGFUR.Wpf.Views.PlanCall.PlanCallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SIGFUR.Wpf.Controls"
        Title="SIGFUR — Plano de Chamada" Width="1700" Height="960" MinWidth="1280" MinHeight="760"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="92"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="42"/></Grid.RowDefinitions>
        <Border Background="{DynamicResource PrimaryGradientBrush}" Padding="24,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="PLANO DE CHAMADA" Foreground="White" FontWeight="Bold" FontSize="24"/>
                    <TextBlock Text="Banco próprio criado pela planilha. O Listar Militares é consultado somente para conferir endereço e completar telefone ausente." Foreground="#DCEBFF" Margin="0,4,0,0"/>
                </StackPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                    <Button Content="＋ Novo" Style="{StaticResource LightOnDarkButtonStyle}" Click="New_Click" Margin="0,0,8,0"/>
                    <Button Content="Importar planilha" Style="{StaticResource LightOnDarkButtonStyle}" Click="Import_Click" Margin="0,0,8,0"/>
                    <Button Content="Completar telefones faltantes" Style="{StaticResource LightOnDarkButtonStyle}" Click="CopyAllPhones_Click" Margin="0,0,8,0"/>
                    <Button Content="Backup" Style="{StaticResource LightOnDarkButtonStyle}" Click="CreateRestorePoint_Click" Margin="0,0,8,0"/>
                    <Button Content="Restaurar" Style="{StaticResource LightOnDarkButtonStyle}" Click="Restore_Click" Margin="0,0,8,0"/>
                    <Button Content="Recarregar" Style="{StaticResource LightOnDarkButtonStyle}" Click="Reload_Click"/>
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="16,12,16,0" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="210"/><ColumnDefinition Width="12"/><ColumnDefinition Width="190"/><ColumnDefinition Width="12"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel><TextBlock Text="Pesquisar no Plano" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged" ToolTip="Nome, CPF, PREC-CP, telefone, endereço, CEP ou região"/></StackPanel>
                <StackPanel Grid.Column="2"><TextBlock Text="Ordenação" Style="{StaticResource CaptionTextStyle}"/><ComboBox x:Name="SortBox" SelectionChanged="SortBox_SelectionChanged"><ComboBoxItem Content="Hierarquia"/><ComboBoxItem Content="Nome"/><ComboBoxItem Content="Região"/><ComboBoxItem Content="Endereço divergente"/></ComboBox></StackPanel>
                <StackPanel Grid.Column="4"><TextBlock Text="Conferência" Style="{StaticResource CaptionTextStyle}"/><CheckBox x:Name="DifferencesOnlyBox" Content="Mostrar pendências de conferência" VerticalAlignment="Center" Margin="0,7,0,0" Checked="DifferencesOnlyBox_Changed" Unchecked="DifferencesOnlyBox_Changed"/></StackPanel>
                <WrapPanel Grid.Column="6" VerticalAlignment="Bottom"><CheckBox x:Name="GroupRegionBox" Content="Agrupar por região" VerticalAlignment="Center" Margin="0,0,12,7"/><Button Content="Excel" Style="{StaticResource PrimaryButtonStyle}" Click="ExportExcel_Click" Margin="0,0,8,0"/><Button Content="ODT" Style="{StaticResource SecondaryButtonStyle}" Click="ExportOdt_Click" Margin="0,0,8,0"/><Button Content="PDF" Style="{StaticResource SecondaryButtonStyle}" Click="ExportPdf_Click"/></WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="16,12,16,10">
            <Grid.ColumnDefinitions><ColumnDefinition Width="2.2*"/><ColumnDefinition x:Name="EditorGapColumn" Width="12"/><ColumnDefinition x:Name="EditorColumn" Width="1.05*"/></Grid.ColumnDefinitions>
            <Border Style="{StaticResource CardStyle}" Padding="14">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="EFETIVO DO LISTAR + DADOS DO PLANO" Style="{StaticResource SectionTitleStyle}"/><TextBlock x:Name="CountText" Grid.Column="1" Foreground="{DynamicResource MutedBrush}"/></Grid>
                    <Border Grid.Row="1" Background="{DynamicResource InfoSoftBrush}" CornerRadius="9" Padding="10" Margin="0,9,0,0"><TextBlock Text="Todo militar cadastrado no Listar aparece aqui. A planilha identifica a pessoa e grava telefone/endereço no banco próprio do Plano. O endereço é apenas comparado; nunca é copiado para o Listar." Foreground="{DynamicResource InfoBrush}" TextWrapping="Wrap"/></Border>
                    <DataGrid x:Name="RecordsGrid" Grid.Row="2" HorizontalScrollBarVisibility="Auto" Margin="0,10,0,0" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single" SelectionChanged="RecordsGrid_SelectionChanged" MouseDoubleClick="EditSelected_Click">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DifferenceStatus}" Value="DIVERGENTE"><Setter Property="Background" Value="{DynamicResource DangerSoftBrush}"/></DataTrigger><DataTrigger Binding="{Binding DifferenceStatus}" Value="SEM ENDEREÇO NO PLANO"><Setter Property="Background" Value="{DynamicResource WarningSoftBrush}"/></DataTrigger>
                                    <DataTrigger Binding="{Binding PhoneStatus}" Value="Pode completar o Listar"><Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/><Setter Property="BorderThickness" Value="0,0,4,0"/></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="P/G" Binding="{Binding ShortRank}" Width="86"/>
                            <DataGridTemplateColumn Header="Nome" Width="260"><DataGridTemplateColumn.CellTemplate><DataTemplate><controls:HighlightedNameTextBlock FullName="{Binding Name}" WarName="{Binding WarName}" TextWrapping="Wrap"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                            <DataGridTextColumn Header="Origem" Binding="{Binding RecordSource}" Width="135"/><DataGridTextColumn Header="Telefone" Binding="{Binding EffectivePhone}" Width="138"/>
                            <DataGridTextColumn Header="Endereço para conferência" Binding="{Binding EffectiveAddress}" Width="360"/>
                            <DataGridTextColumn Header="Região" Binding="{Binding Region}" Width="145"/>
                            <DataGridTextColumn Header="Endereço × Listar" Binding="{Binding DifferenceStatus}" Width="170"/>
                            <DataGridTextColumn Header="Telefone × Listar" Binding="{Binding PhoneStatus}" Width="175"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Expander x:Name="RecordExpander" Grid.Column="2" IsExpanded="True" Expanded="RecordExpander_Expanded" Collapsed="RecordExpander_Collapsed">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="REGISTRO DO PLANO" FontWeight="Bold"/>
                        <TextBlock Text="  • clique para recolher" Foreground="{DynamicResource MutedBrush}"/>
                    </StackPanel>
                </Expander.Header>
                <Border Style="{StaticResource CardStyle}" Padding="14">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                                <TextBlock x:Name="SelectedNameText" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,2"/>
                            <TextBlock x:Name="SelectedIdentifiersText" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,12"/>
    
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="115"/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="P/G" Style="{StaticResource CaptionTextStyle}"/><ComboBox x:Name="RankBox" IsEditable="True"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="Nome completo" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="NameBox"/></StackPanel></Grid>
                            <TextBlock Text="Nome de guerra" Style="{StaticResource CaptionTextStyle}" Margin="0,9,0,0"/><TextBox x:Name="WarNameBox"/>
                            <Grid Margin="0,9,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="CPF" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="CpfBox"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="PREC-CP" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="PrecBox"/></StackPanel></Grid>
                            <Grid Margin="0,9,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Telefone do Plano" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="PhoneBox"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="Telefone alternativo" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="AlternatePhoneBox"/></StackPanel></Grid>
                            <Separator Margin="0,14"/>
                            <TextBlock Text="Rua / Avenida" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="StreetBox"/>
                            <Grid Margin="0,9,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="0.45*"/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Número" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="NumberBox"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="Complemento" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="ComplementBox"/></StackPanel></Grid>
                            <TextBlock Text="Bairro" Style="{StaticResource CaptionTextStyle}" Margin="0,9,0,0"/><TextBox x:Name="DistrictBox"/>
                            <Grid Margin="0,9,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition Width="0.62*"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Cidade/UF" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="CityStateBox"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="CEP" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="ZipCodeBox"/></StackPanel></Grid>
                            <WrapPanel Margin="0,10,0,0"><Button Content="Consultar CEP" Style="{StaticResource SecondaryButtonStyle}" Click="LookupZip_Click" Margin="0,0,8,8"/><Button Content="Buscar pela rua" Style="{StaticResource SecondaryButtonStyle}" Click="LookupAddress_Click" Margin="0,0,8,8"/><Button Content="Padronizar" Style="{StaticResource GhostButtonStyle}" Click="NormalizeAddress_Click" Margin="0,0,0,8"/></WrapPanel>
    
                            <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="10" Padding="12" Margin="0,8,0,0">
                                <StackPanel><TextBlock Text="COMPARAÇÃO COM O LISTAR MILITARES" Style="{StaticResource CaptionTextStyle}"/><TextBlock x:Name="BasePhoneText" Margin="0,6,0,2" FontWeight="SemiBold"/><TextBlock x:Name="BaseAddressText" TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}"/></StackPanel>
                            </Border>
                            <WrapPanel Margin="0,14,0,0">
                                <Button Content="Salvar no Plano" Style="{StaticResource PrimaryButtonStyle}" Click="SaveSelected_Click" Margin="0,0,8,8"/>
                                <Button Content="Copiar telefone faltante → Listar" Style="{StaticResource SecondaryButtonStyle}" Click="CopyPhoneToBase_Click" Margin="0,0,8,8"/>
                                <Button Content="Abrir carteira" Style="{StaticResource SecondaryButtonStyle}" Click="OpenWallet_Click" Margin="0,0,8,8"/>
                                <Button Content="Excluir do Plano" Style="{StaticResource DangerButtonStyle}" Click="ClearOverride_Click" Margin="0,0,0,8"/>
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Expander>
        </Grid>

        <Border Grid.Row="3" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0" Padding="16,0">
            <Grid><TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}"/><ProgressBar x:Name="BusyBar" HorizontalAlignment="Right" Width="160" IsIndeterminate="True" Visibility="Collapsed"/></Grid>
        </Border>
    </Grid>
</Window>
