<Window x:Class="SIGFUR.Wpf.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIGFUR" Icon="/Assets/sigfur-loading.ico"
        Width="960" Height="600" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="True" Topmost="True">
    <Window.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="SpinnerRotate" Storyboard.TargetProperty="Angle"
                                     From="0" To="360" Duration="0:0:1.4" RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="PulseGlow" Storyboard.TargetProperty="Opacity"
                                     From="0.25" To="0.75" Duration="0:0:0.9" AutoReverse="True" RepeatBehavior="Forever"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Border x:Name="RootCard" Margin="18" CornerRadius="22"
                Background="{DynamicResource AppBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <Border.RenderTransform>
                <ScaleTransform x:Name="CardScale" ScaleX="0.97" ScaleY="0.97" CenterX="480" CenterY="300"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="38" ShadowDepth="10" Opacity="0.30" Color="{DynamicResource ShadowColor}"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="330"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Faixa institucional -->
                <Border Grid.Column="0" Background="{DynamicResource PrimaryGradientBrush}" CornerRadius="21,0,0,21" ClipToBounds="True">
                    <Grid>
                        <Ellipse Width="360" Height="360" Fill="#12FFFFFF" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-180,-170,0,0"/>
                        <Ellipse Width="300" Height="300" Fill="#0DFFFFFF" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-170,-150"/>
                        <Grid Margin="32,30">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <Border Width="78" Height="78" CornerRadius="20" Background="#22FFFFFF" BorderBrush="#35FFFFFF" BorderThickness="1" HorizontalAlignment="Left">
                                    <Grid>
                                        <Image Source="/Assets/sigfur-mark.png" Width="64" Height="64" Stretch="Uniform"
                                               SnapsToDevicePixels="True" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Grid>
                                </Border>
                                <TextBlock Text="SIGFUR" Foreground="White" FontSize="36" FontWeight="SemiBold" Margin="0,20,0,0"/>
                                <TextBlock Text="SISTEMA INTEGRADO DE GESTÃO DO FURRIEL" Foreground="{DynamicResource TextOnPrimaryMutedBrush}" FontSize="10" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                <TextBlock Text="Controle militar inteligente para o Furriel decidir rápido, conferir melhor e errar menos."
                                           Foreground="White" FontSize="22" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <TextBlock Text="Do cadastro ao boletim: dados organizados, pagamentos conferidos e documentos prontos para a rotina."
                                           Foreground="{DynamicResource TextOnPrimaryMutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,13,0,24"/>
                                <WrapPanel>
                                    <Border Background="#20FFFFFF" CornerRadius="8" Padding="10,6" Margin="0,0,8,8"><TextBlock Text="OPERAÇÃO REAL" Foreground="White" FontSize="9" FontWeight="SemiBold"/></Border>
                                    <Border Background="#20FFFFFF" CornerRadius="8" Padding="10,6" Margin="0,0,8,8"><TextBlock Text="CONTROLE" Foreground="White" FontSize="9" FontWeight="SemiBold"/></Border>
                                    <Border Background="#20FFFFFF" CornerRadius="8" Padding="10,6" Margin="0,0,8,8"><TextBlock Text="AUDITORIA" Foreground="White" FontSize="9" FontWeight="SemiBold"/></Border>
                                </WrapPanel>
                            </StackPanel>

                            <StackPanel Grid.Row="2">
                                <TextBlock x:Name="VersionText" Text="v6.1.11" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Edição Operacional 6.0" Foreground="{DynamicResource TextOnPrimaryMutedBrush}" FontSize="10" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Área operacional -->
                <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="0,21,21,0" Padding="38,32">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Inicializando o SIGFUR" FontSize="27" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Text="Preparando banco, conferências, documentos e painéis operacionais" Style="{StaticResource PageSubtitleStyle}" Margin="0,5,0,0"/>
                            </StackPanel>
                            <Grid HorizontalAlignment="Right" Width="58" Height="58">
                                <Ellipse x:Name="PulseGlow" Fill="{DynamicResource PrimarySoftBrush}" Opacity="0.45"/>
                                <Ellipse Width="43" Height="43" Stroke="{DynamicResource DividerBrush}" StrokeThickness="4"/>
                                <Ellipse Width="43" Height="43" Stroke="{DynamicResource PrimaryBrush}" StrokeThickness="4" StrokeDashArray="2,4" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                    <Ellipse.RenderTransform><RotateTransform x:Name="SpinnerRotate" CenterX="21.5" CenterY="21.5"/></Ellipse.RenderTransform>
                                </Ellipse>
                                <Ellipse Width="10" Height="10" Fill="{DynamicResource PrimaryBrush}"/>
                            </Grid>
                        </Grid>

                        <Border Grid.Row="1" Style="{StaticResource SoftCardStyle}" Padding="15" Margin="0,22,0,18">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="38" Height="38" CornerRadius="10" Background="{DynamicResource PrimarySoftBrush}" VerticalAlignment="Center">
                                    <TextBlock Text="" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource PrimaryDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock x:Name="StageText" Text="Preparando experiência..." FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock x:Name="DetailText" Text="Aplicando identidade visual e validando recursos WPF" Style="{StaticResource CaptionTextStyle}" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2">
                            <TextBlock Text="PROGRESSO DA INICIALIZAÇÃO" Foreground="{DynamicResource MutedBrush}" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Bottom"/>
                            <TextBlock x:Name="PercentText" Text="00%" HorizontalAlignment="Right" Foreground="{DynamicResource PrimaryDarkBrush}" FontSize="24" FontWeight="SemiBold"/>
                        </Grid>
                        <ProgressBar x:Name="Progress" Grid.Row="3" Minimum="0" Maximum="100" Value="0" Height="11" Margin="0,10,0,18"/>

                        <ItemsControl x:Name="StepsControl" Grid.Row="4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <Border Width="24" Height="24" CornerRadius="12" Background="{Binding Background}" VerticalAlignment="Top">
                                            <TextBlock Text="{Binding Marker}" Foreground="{Binding Color}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource SubtleTextBrush}" FontSize="10" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Grid.Row="5" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" CornerRadius="9" Padding="11,8" Margin="0,8,0,0">
                            <TextBlock x:Name="FooterText" Text="Aguarde enquanto o SIGFUR prepara a abertura com segurança."
                                       Foreground="{DynamicResource MutedBrush}" FontSize="10" TextWrapping="Wrap"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
