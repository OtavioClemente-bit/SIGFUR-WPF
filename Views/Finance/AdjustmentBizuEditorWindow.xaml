<Window x:Class="SIGFUR.Wpf.Views.Finance.AdjustmentBizuEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar regra do Bizu" Width="760" Height="650" MinWidth="680" MinHeight="560"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="Regra do Bizu" Style="{StaticResource PageTitleStyle}"/>
            <TextBlock Text="Defina exatamente quais direitos serão aplicados ao selecionar esta hipótese." Style="{StaticResource PageSubtitleStyle}" Margin="0,4,0,14"/>
        </StackPanel>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Título / hipótese" Style="{StaticResource SectionTitleStyle}"/>
                <TextBox x:Name="TitleBox" Margin="0,6,0,16"/>
                <TextBlock Text="Direitos" Style="{StaticResource SectionTitleStyle}"/>
                <Border Style="{StaticResource CardStyle}" Padding="14" Margin="0,6,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="210"/></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <TextBlock Text="Adicional de férias" VerticalAlignment="Center" Margin="0,4"/>
                        <ComboBox x:Name="VacationAdditionalBox" Grid.Column="1" Margin="0,4"><ComboBoxItem Content="Não alterar" Tag="N"/><ComboBoxItem Content="Faz jus" Tag="S"/><ComboBoxItem Content="Não faz jus" Tag="0"/></ComboBox>
                        <TextBlock Grid.Row="1" Text="Indenização de férias não gozadas" VerticalAlignment="Center" Margin="0,4"/>
                        <ComboBox x:Name="VacationIndemnityBox" Grid.Row="1" Grid.Column="1" Margin="0,4"><ComboBoxItem Content="Não alterar" Tag="N"/><ComboBoxItem Content="Faz jus" Tag="S"/><ComboBoxItem Content="Não faz jus" Tag="0"/></ComboBox>
                        <TextBlock Grid.Row="2" Text="Adicional natalino" VerticalAlignment="Center" Margin="0,4"/>
                        <ComboBox x:Name="ChristmasBox" Grid.Row="2" Grid.Column="1" Margin="0,4"><ComboBoxItem Content="Não alterar" Tag="N"/><ComboBoxItem Content="Faz jus" Tag="S"/><ComboBoxItem Content="Não faz jus" Tag="0"/></ComboBox>
                        <TextBlock Grid.Row="3" Text="Compensação pecuniária" VerticalAlignment="Center" Margin="0,4"/>
                        <ComboBox x:Name="PecuniaryBox" Grid.Row="3" Grid.Column="1" Margin="0,4"><ComboBoxItem Content="Não alterar" Tag="N"/><ComboBoxItem Content="Faz jus" Tag="S"/><ComboBoxItem Content="Não faz jus" Tag="0"/></ComboBox>
                    </Grid>
                </Border>
                <TextBlock Text="Fundamento legal" Style="{StaticResource SectionTitleStyle}"/>
                <TextBox x:Name="LegalBasisBox" Height="90" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,6,0,16"/>
                <TextBlock Text="Orientação / observação" Style="{StaticResource SectionTitleStyle}"/>
                <TextBox x:Name="ObservationBox" Height="130" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,6,0,0"/>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancelar" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="Salvar regra" IsDefault="True" Style="{StaticResource PrimaryButtonStyle}" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
