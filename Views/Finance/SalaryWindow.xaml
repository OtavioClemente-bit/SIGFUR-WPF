<Window x:Class="SIGFUR.Wpf.Views.Finance.SalaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIGFUR — Soldos por Posto/Graduação"
        Width="1240" Height="790" MinWidth="960" MinHeight="640"
        WindowStartupLocation="CenterOwner" Icon="/Assets/sigfur.ico"
        Background="{DynamicResource AppBackgroundBrush}"
        Loaded="Window_Loaded" PreviewKeyDown="Window_PreviewKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="76"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="38"/>
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource PrimaryDarkBrush}" Padding="22,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="SOLDOS POR POSTO/GRADUAÇÃO" Foreground="White" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="Edite a base usada nos cálculos e confira a referência oficial vigente em 2026" Foreground="{DynamicResource TextOnPrimaryMutedBrush}"/>
                </StackPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                    <Button Content="Pesquisar tabela oficial" Style="{StaticResource LightOnDarkButtonStyle}" Click="OfficialSearch_Click" Margin="0,0,8,0"/>
                    <Button Content="Abrir site oficial" Style="{StaticResource LightOnDarkButtonStyle}" Click="OfficialSite_Click"/>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <UniformGrid Columns="4" Margin="0,0,0,12">
                <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,6,0">
                    <StackPanel><TextBlock Text="REGISTROS VISÍVEIS" Style="{StaticResource MetricCaptionStyle}"/><TextBlock x:Name="VisibleCountText" Text="0" Style="{StaticResource MetricValueStyle}"/></StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}" Margin="6,0">
                    <StackPanel><TextBlock Text="CONFERIDOS COM 2026" Style="{StaticResource MetricCaptionStyle}"/><TextBlock x:Name="OfficialCountText" Text="0" Foreground="{DynamicResource SuccessBrush}" Style="{StaticResource MetricValueStyle}"/></StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}" Margin="6,0">
                    <StackPanel><TextBlock Text="DIFERENTES DA REFERÊNCIA" Style="{StaticResource MetricCaptionStyle}"/><TextBlock x:Name="DifferentCountText" Text="0" Foreground="{DynamicResource WarningBrush}" Style="{StaticResource MetricValueStyle}"/></StackPanel>
                </Border>
                <Border Style="{StaticResource SoftMetricCardStyle}" Margin="6,0,0,0">
                    <StackPanel><TextBlock Text="OCULTOS" Style="{StaticResource MetricCaptionStyle}"/><TextBlock x:Name="HiddenCountText" Text="0" Style="{StaticResource MetricValueStyle}"/></StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="15" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.2*"/><ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="1.1*"/><ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Posto/graduação" Style="{StaticResource CaptionTextStyle}"/>
                        <ComboBox x:Name="RankBox" IsEditable="True" IsTextSearchEnabled="True" SelectionChanged="RankBox_SelectionChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Soldo configurado (R$)" Style="{StaticResource CaptionTextStyle}"/>
                        <TextBox x:Name="SalaryBox" TextAlignment="Right" VerticalContentAlignment="Center" ToolTip="Aceita 4.177,00 ou 4177,00"/>
                    </StackPanel>
                    <WrapPanel Grid.Column="4" VerticalAlignment="Bottom">
                        <Button Content="Salvar" Style="{StaticResource PrimaryButtonStyle}" Click="Save_Click" Margin="0,0,8,0"/>
                        <Button Content="Novo posto" Style="{StaticResource SecondaryButtonStyle}" Click="New_Click" Margin="0,0,8,0"/>
                        <Button Content="Ocultar" Style="{StaticResource DangerButtonStyle}" Click="Hide_Click"/>
                    </WrapPanel>

                    <Grid Grid.Row="1" Grid.ColumnSpan="5" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Pesquisar na base configurada" Style="{StaticResource CaptionTextStyle}"/>
                            <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged" ToolTip="Posto, abreviação, valor ou status"/>
                        </StackPanel>
                        <CheckBox Grid.Column="2" x:Name="ShowHiddenBox" Content="Mostrar ocultos" VerticalAlignment="Bottom" Margin="0,0,14,8" Checked="ShowHidden_Changed" Unchecked="ShowHidden_Changed"/>
                        <Button Grid.Column="3" Content="Aplicar valores oficiais de 2026" Style="{StaticResource SecondaryButtonStyle}" Click="ApplyOfficial_Click" Margin="0,0,8,0" VerticalAlignment="Bottom"/>
                        <Button Grid.Column="4" Content="Exportar CSV" Style="{StaticResource SecondaryButtonStyle}" Click="Export_Click" VerticalAlignment="Bottom"/>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="4">
                <DataGrid x:Name="SalaryGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                          SelectionChanged="SalaryGrid_SelectionChanged" MouseDoubleClick="SalaryGrid_MouseDoubleClick" Sorting="SalaryGrid_Sorting">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Editar registro" Click="EditSelected_Click"/>
                            <MenuItem Header="Copiar posto/graduação" Click="CopyRank_Click"/>
                            <MenuItem Header="Copiar soldo" Click="CopySalary_Click"/>
                            <MenuItem Header="Copiar linha completa" Click="CopyRow_Click"/>
                            <Separator/>
                            <MenuItem Header="Ocultar / reexibir" Click="ToggleHidden_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusText}" Value="Conferido"><Setter Property="Background" Value="{DynamicResource SuccessSoftBrush}"/></DataTrigger>
                                <DataTrigger Binding="{Binding StatusText}" Value="Diferente da referência"><Setter Property="Background" Value="{DynamicResource WarningSoftBrush}"/></DataTrigger>
                                <DataTrigger Binding="{Binding StatusText}" Value="Sem valor"><Setter Property="Background" Value="{DynamicResource DangerSoftBrush}"/></DataTrigger>
                                <DataTrigger Binding="{Binding IsHidden}" Value="True"><Setter Property="Opacity" Value="0.55"/></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Posto/Graduação" Binding="{Binding Rank}" Width="2*" MinWidth="240" SortMemberPath="Rank"/>
                        <DataGridTextColumn Header="Abreviação" Binding="{Binding ShortRank}" Width="120" SortMemberPath="ShortRank"/>
                        <DataGridTextColumn Header="Soldo configurado" Binding="{Binding SalaryText}" Width="150" SortMemberPath="Salary"/>
                        <DataGridTextColumn Header="Referência oficial 2026" Binding="{Binding Official2026Text}" Width="170" SortMemberPath="Official2026"/>
                        <DataGridTextColumn Header="Diferença" Binding="{Binding DifferenceText}" Width="135" SortMemberPath="Difference"/>
                        <DataGridTextColumn Header="Situação" Binding="{Binding StatusText}" Width="180" SortMemberPath="StatusText"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0" Padding="16,0">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{DynamicResource SubtleTextBrush}" Text="Ctrl+S salvar  •  Ctrl+N novo  •  Ctrl+F pesquisar  •  Delete ocultar  •  F5 atualizar  •  duplo clique copia"/>
            </Grid>
        </Border>
    </Grid>
</Window>
