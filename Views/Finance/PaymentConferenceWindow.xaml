<Window x:Class="SIGFUR.Wpf.Views.Finance.PaymentConferenceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIGFUR — Conferência de Pagamento" Width="1540" Height="910" MinWidth="1180" MinHeight="720"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico"
        Loaded="Window_Loaded" PreviewKeyDown="Window_PreviewKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="84"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="38"/>
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource PrimaryGradientBrush}" Padding="22,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="CONFERÊNCIA DE PAGAMENTO" Foreground="White" FontSize="23" FontWeight="Bold"/>
                    <TextBlock Text="Cruza Aditamentos do Furriel com contracheques do mês: férias, auxílio-transporte, gratificação, habilitação e rubricas N/A/D." Foreground="#DCEBFF" Margin="0,4,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Background="#1EFFFFFF" CornerRadius="16" Padding="13,7" VerticalAlignment="Center">
                    <TextBlock x:Name="HeaderBadge" Text="Competência: —" Foreground="White" FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="16,14,16,10" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="112"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="95"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Mês" Style="{StaticResource CaptionTextStyle}"/>
                    <ComboBox x:Name="MonthBox" Height="34" SelectionChanged="MonthYear_Changed"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Ano" Style="{StaticResource CaptionTextStyle}"/>
                    <TextBox x:Name="YearBox" Height="34" VerticalContentAlignment="Center" TextChanged="YearBox_TextChanged"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Pasta dos contracheques do mês" Style="{StaticResource CaptionTextStyle}"/>
                    <TextBox x:Name="PaystubFolderBox" Height="34" VerticalContentAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="5" Content="Escolher pasta" Style="{StaticResource SecondaryButtonStyle}" Height="34" Margin="8,17,0,0" Click="ChoosePaystubFolder_Click"/>
                <StackPanel Grid.Column="7" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,1">
                    <CheckBox x:Name="RequirePrefixCheck" Content="Exigir prefixo da rubrica" IsChecked="True" Margin="0,0,14,0" ToolTip="A = atrasado, N = normal, D = desconto/anulação"/>
                    <CheckBox x:Name="VacationCheck" Content="Férias" IsChecked="True" Margin="0,0,10,0"/>
                    <CheckBox x:Name="TransportCheck" Content="AT" IsChecked="True" Margin="0,0,10,0"/>
                    <CheckBox x:Name="GratCheck" Content="Grat Rep" IsChecked="True" Margin="0,0,10,0"/>
                    <CheckBox x:Name="QualificationCheck" Content="Hab" IsChecked="True" Margin="0,0,10,0"/>
                    <CheckBox x:Name="OthersCheck" Content="Outros" IsChecked="True"/>
                </StackPanel>
                <Button Grid.Column="8" Content="Conferir" Style="{StaticResource PrimaryButtonStyle}" Height="36" MinWidth="115" Margin="8,17,0,0" Click="RunConference_Click"/>
                <Button Grid.Column="9" Content="Exportar CSV" Style="{StaticResource SecondaryButtonStyle}" Height="36" MinWidth="105" Margin="8,17,0,0" Click="ExportCsv_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="16,0,16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="440"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Margin="14,13,14,8">
                        <TextBlock Text="ADITAMENTOS DO FURRIEL" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock x:Name="BulletinCountText" Text="Carregando índice..." Foreground="{DynamicResource MutedBrush}" FontSize="10"/>
                    </StackPanel>
                    <WrapPanel Grid.Row="1" Margin="12,0,12,9">
                        <Button Content="Atualizar lista" Style="{StaticResource SecondaryButtonStyle}" Click="ReloadBulletins_Click" Margin="0,0,7,7"/>
                        <Button Content="Adicionar PDF" Style="{StaticResource SecondaryButtonStyle}" Click="AddPdf_Click" Margin="0,0,7,7"/>
                        <Button Content="Marcar todos" Style="{StaticResource GhostButtonStyle}" Click="SelectAll_Click" Margin="0,0,7,7"/>
                        <Button Content="Limpar" Style="{StaticResource GhostButtonStyle}" Click="ClearSelection_Click" Margin="0,0,7,7"/>
                    </WrapPanel>
                    <DataGrid Grid.Row="2" x:Name="BulletinsGrid" AutoGenerateColumns="False" CanUserAddRows="False" Margin="8,0" SelectionMode="Single" SelectionChanged="BulletinsGrid_SelectionChanged" MouseDoubleClick="BulletinsGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="✓" Binding="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="38"/>
                            <DataGridTextColumn Header="Nº" Binding="{Binding Bulletin}" Width="58" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Data" Binding="{Binding Date}" Width="86" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Itens" Binding="{Binding ExpectedItems}" Width="48" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Arquivo" Binding="{Binding OriginalName}" Width="*" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="12,8,12,12">
                        <Button Content="Abrir PDF" Style="{StaticResource PrimaryButtonStyle}" Click="OpenSelectedBulletin_Click"/>
                        <Button Content="Mostrar na pasta" Style="{StaticResource SecondaryButtonStyle}" Click="RevealSelectedBulletin_Click" Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="86"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/><ColumnDefinition Width="10"/>
                        <ColumnDefinition/><ColumnDefinition Width="10"/>
                        <ColumnDefinition/><ColumnDefinition Width="10"/>
                        <ColumnDefinition/><ColumnDefinition Width="10"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource InsetCardStyle}" Padding="12,9"><StackPanel><TextBlock Text="PUBLICADO" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource MutedBrush}"/><TextBlock x:Name="ExpectedSummaryText" Text="0" FontSize="25" FontWeight="Bold" Foreground="{DynamicResource PrimaryDarkBrush}"/><TextBlock Text="itens no aditamento" FontSize="9" Foreground="{DynamicResource SubtleTextBrush}"/></StackPanel></Border>
                    <Border Grid.Column="2" Style="{StaticResource InsetCardStyle}" Padding="12,9"><StackPanel><TextBlock Text="OK" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource MutedBrush}"/><TextBlock x:Name="OkSummaryText" Text="0" FontSize="25" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/><TextBlock Text="rubrica/valor encontrados" FontSize="9" Foreground="{DynamicResource SubtleTextBrush}"/></StackPanel></Border>
                    <Border Grid.Column="4" Style="{StaticResource InsetCardStyle}" Padding="12,9"><StackPanel><TextBlock Text="PENDÊNCIAS" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource MutedBrush}"/><TextBlock x:Name="PendingSummaryText" Text="0" FontSize="25" FontWeight="Bold" Foreground="{DynamicResource DangerBrush}"/><TextBlock Text="não achou ou divergiu" FontSize="9" Foreground="{DynamicResource SubtleTextBrush}"/></StackPanel></Border>
                    <Border Grid.Column="6" Style="{StaticResource InsetCardStyle}" Padding="12,9"><StackPanel><TextBlock Text="SEM PDF" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource MutedBrush}"/><TextBlock x:Name="MissingPdfSummaryText" Text="0" FontSize="25" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}"/><TextBlock Text="contracheque ausente" FontSize="9" Foreground="{DynamicResource SubtleTextBrush}"/></StackPanel></Border>
                    <Border Grid.Column="8" Style="{StaticResource InsetCardStyle}" Padding="12,9"><StackPanel><TextBlock Text="DIVERGENTE" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource MutedBrush}"/><TextBlock x:Name="DivergentSummaryText" Text="0" FontSize="25" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}"/><TextBlock Text="valor diferente" FontSize="9" Foreground="{DynamicResource SubtleTextBrush}"/></StackPanel></Border>
                </Grid>

                <TabControl Grid.Row="2">
                    <TabItem Header="Resultado da conferência">
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="10"/><RowDefinition Height="125"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <DataGrid x:Name="ResultsGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single" SelectionChanged="ResultsGrid_SelectionChanged" MouseDoubleClick="ResultsGrid_MouseDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="135"/>
                                    <DataGridTextColumn Header="Militar" Binding="{Binding Military}" Width="220"/>
                                    <DataGridTextColumn Header="CPF" Binding="{Binding Cpf}" Width="110"/>
                                    <DataGridTextColumn Header="Tipo" Binding="{Binding PaymentType}" Width="155"/>
                                    <DataGridTextColumn Header="Modo" Binding="{Binding PaymentMode}" Width="145"/>
                                    <DataGridTextColumn Header="Pref." Binding="{Binding ExpectedRubricPrefix}" Width="48"/>
                                    <DataGridTextColumn Header="Esperado" Binding="{Binding ExpectedAmountText}" Width="92"/>
                                    <DataGridTextColumn Header="Recebido" Binding="{Binding PaidAmountText}" Width="92"/>
                                    <DataGridTextColumn Header="Dif." Binding="{Binding DifferenceText}" Width="92"/>
                                    <DataGridTextColumn Header="Rubricas" Binding="{Binding RubricsFound}" Width="320"/>
                                    <DataGridTextColumn Header="Contracheque" Binding="{Binding PaystubFile}" Width="220"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBox Grid.Row="2" x:Name="ResultDetailBox" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Abrir contracheque" Style="{StaticResource PrimaryButtonStyle}" Click="OpenPaystub_Click"/>
                                <Button Content="Pasta do contracheque" Style="{StaticResource SecondaryButtonStyle}" Click="RevealPaystub_Click" Margin="8,0,0,0"/>
                                <Button Content="Abrir aditamento" Style="{StaticResource SecondaryButtonStyle}" Click="OpenBulletinFromResult_Click" Margin="8,0,0,0"/>
                                <Button Content="Copiar resumo" Style="{StaticResource GhostButtonStyle}" Click="CopySummary_Click" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Itens extraídos do aditamento">
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="10"/><RowDefinition Height="130"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <DataGrid x:Name="ExpectedGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single" SelectionChanged="ExpectedGrid_SelectionChanged" MouseDoubleClick="ExpectedGrid_MouseDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Boletim" Binding="{Binding Bulletin}" Width="75"/>
                                    <DataGridTextColumn Header="Pág." Binding="{Binding PageText}" Width="55"/>
                                    <DataGridTextColumn Header="Militar" Binding="{Binding IdentityText}" Width="240"/>
                                    <DataGridTextColumn Header="CPF" Binding="{Binding Cpf}" Width="115"/>
                                    <DataGridTextColumn Header="PREC" Binding="{Binding PrecCp}" Width="105"/>
                                    <DataGridTextColumn Header="Tipo" Binding="{Binding PaymentType}" Width="160"/>
                                    <DataGridTextColumn Header="Modo" Binding="{Binding PaymentMode}" Width="145"/>
                                    <DataGridTextColumn Header="Prefixo" Binding="{Binding ExpectedRubricPrefix}" Width="65"/>
                                    <DataGridTextColumn Header="Valor" Binding="{Binding ExpectedAmountText}" Width="95"/>
                                    <DataGridTextColumn Header="Banco" Binding="{Binding MatchStatus}" Width="150"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBox Grid.Row="2" x:Name="ExpectedDetailBox" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Abrir aditamento neste militar" Style="{StaticResource PrimaryButtonStyle}" Click="OpenExpectedBulletin_Click"/>
                            </StackPanel>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Rubricas achadas">
                        <DataGrid x:Name="RubricsGrid" Margin="0,10,0,0" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Militar" Binding="{Binding Military}" Width="230"/>
                                <DataGridTextColumn Header="Código" Binding="{Binding Code}" Width="90"/>
                                <DataGridTextColumn Header="Natureza" Binding="{Binding Nature}" Width="90"/>
                                <DataGridTextColumn Header="Descrição" Binding="{Binding Description}" Width="360"/>
                                <DataGridTextColumn Header="Valor" Binding="{Binding ValueText}" Width="100"/>
                                <DataGridTextColumn Header="PDF" Binding="{Binding PaystubPath}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="Regras usadas">
                        <ScrollViewer Margin="0,10,0,0" VerticalScrollBarVisibility="Auto">
                            <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{DynamicResource TextBrush}">
                                <Run Text="Regra principal: "/><Run FontWeight="Bold" Text="N"/><Run Text=" no início da rubrica indica lançamento normal; "/><Run FontWeight="Bold" Text="A"/><Run Text=" indica saque de atrasado; "/><Run FontWeight="Bold" Text="D"/><Run Text=" indica desconto, despesa a anular ou reversão.&#x0a;&#x0a;"/>
                                <Run Text="O SIGFUR lê o Aditamento do Furriel, procura os blocos de PAGAMENTO PESSOAL, separa cada publicação por item, extrai P/G, nome, PREC-CP, CPF e valores. Depois localiza o contracheque da competência escolhida e confere se existe rubrica compatível com o tipo publicado.&#x0a;&#x0a;"/>
                                <Run Text="Tipos reconhecidos automaticamente: férias, auxílio-transporte, gratificação de representação, adicional de habilitação, auxílio-alimentação e outros pagamentos. Em saque de atrasado, a conferência dá preferência a rubricas iniciadas por A. Em ordem/concessão/implantação, usa rubricas iniciadas por N.&#x0a;&#x0a;"/>
                                <Run Text="Quando o aditamento não trouxer valor fechado, o resultado será “ACHOU RUBRICA”. Quando houver valor, o sistema compara esperado x recebido e marca OK ou VALOR DIVERGENTE."/>
                            </TextBlock>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>

        <Border Grid.Row="3" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="16,0"><TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}" Text="Pronto."/><ProgressBar x:Name="BusyBar" Height="4" VerticalAlignment="Top" IsIndeterminate="True" Visibility="Collapsed"/></Grid>
        </Border>
    </Grid>
</Window>
