<Window x:Class="SIGFUR.Wpf.Views.Finance.AdjustmentAccountsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ajuste de Contas" Width="1500" Height="900" MinWidth="1180" MinHeight="720"
        WindowStartupLocation="CenterOwner" PreviewKeyDown="Window_PreviewKeyDown">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Ajuste de Contas" Style="{StaticResource PageTitleStyle}"/>
                <TextBlock Text="Cálculo, rubricas, imposto de renda e boletim." Style="{StaticResource PageSubtitleStyle}" Margin="0,3,0,12"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Button Content="Desfazer" Style="{StaticResource GhostButtonStyle}" Click="Undo_Click" Margin="0,0,8,0"/>
                <Button Content="Refazer" Style="{StaticResource GhostButtonStyle}" Click="Redo_Click" Margin="0,0,8,0"/>
                <Button Content="Consultar soldo oficial" ToolTip="Abre a fonte oficial em modo de consulta; não altera o cálculo" Style="{StaticResource GhostButtonStyle}" Click="OfficialSalary_Click" Margin="0,0,8,0"/>
                <Button Content="Calculadora" Style="{StaticResource GhostButtonStyle}" Click="Calculator_Click"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="14,12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="165"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Posto / graduação do cálculo" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryDarkBrush}" Margin="0,0,0,5"/>
                    <ComboBox x:Name="RankBox" IsEditable="True" SelectionChanged="RankBox_SelectionChanged"
                              MinHeight="38" FontSize="14" FontWeight="SemiBold" Padding="9,5"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Soldo-base (R$)" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryDarkBrush}" Margin="0,0,0,5"/>
                    <TextBox x:Name="SalaryBox" MinHeight="38" FontSize="14" FontWeight="SemiBold"
                             HorizontalContentAlignment="Right" VerticalContentAlignment="Center" Padding="9,5"/>
                </StackPanel>

                <TextBlock Grid.Column="3"
                           Text="O cálculo usa somente o posto/graduação e os parâmetros informados. A escolha dos militares acontece apenas na geração do boletim."
                           Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" Margin="18,0" MaxWidth="380"/>

                <Button Grid.Column="4" Content="Recalcular" Style="{StaticResource PrimaryButtonStyle}"
                        Click="Recalculate_Click" Margin="8,0,8,0" VerticalAlignment="Center"/>
                <Button Grid.Column="5" Content="Gerar boletim / escolher militares" Style="{StaticResource SecondaryButtonStyle}"
                        Click="GenerateBulletin_Click" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="2">
            <TabItem Header="Cálculo e rubricas">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="390"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,0,5,0">
                            <TextBlock Text="Parâmetros do cálculo" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MutedBrush}" Margin="2,0,0,9"/>

                            <Expander x:Name="PeriodsExpander" Header="Períodos do ajuste"
                                      Style="{StaticResource AccordionExpanderStyle}" IsExpanded="True"
                                      Expanded="SidebarExpander_Expanded">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="108"/></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <TextBlock Text="Dias do mês" VerticalAlignment="Center" Margin="0,5"/><TextBox x:Name="DaysInMonthBox" Grid.Column="1" HorizontalContentAlignment="Right" Margin="0,3"/>
                                    <TextBlock Grid.Row="1" Text="Dias trabalhados" VerticalAlignment="Center" Margin="0,5"/><TextBox x:Name="ServedDaysBox" Grid.Row="1" Grid.Column="1" HorizontalContentAlignment="Right" Margin="0,3"/>
                                    <TextBlock Grid.Row="2" Text="Avos de férias" VerticalAlignment="Center" Margin="0,5"/><TextBox x:Name="VacationMonthsBox" Grid.Row="2" Grid.Column="1" HorizontalContentAlignment="Right" Margin="0,3"/>
                                    <TextBlock Grid.Row="3" Text="Avos de 13º" VerticalAlignment="Center" Margin="0,5"/><TextBox x:Name="ChristmasMonthsBox" Grid.Row="3" Grid.Column="1" HorizontalContentAlignment="Right" Margin="0,3"/>
                                </Grid>
                            </Expander>

                            <Expander x:Name="BizuExpander" Header="Motivo do ajuste — direitos automáticos"
                                      Style="{StaticResource AccordionExpanderStyle}" IsExpanded="False"
                                      Expanded="SidebarExpander_Expanded">
                                <StackPanel>
                                    <ComboBox x:Name="BizuBox" DisplayMemberPath="Title" SelectionChanged="BizuBox_SelectionChanged" Margin="0,0,0,10"/>
                                    <Border Style="{StaticResource InsetCardStyle}" Margin="0,0,0,8">
                                        <TextBlock x:Name="BizuRightsText" TextWrapping="Wrap" FontWeight="SemiBold" LineHeight="20"/>
                                    </Border>
                                    <TextBlock x:Name="BizuBasisText" TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" Margin="0,6,0,0"/>
                                    <TextBlock x:Name="BizuObservationText" TextWrapping="Wrap" Margin="0,7,0,12"/>
                                    <WrapPanel>
                                        <Button Content="Guia completo / editar" Style="{StaticResource SecondaryButtonStyle}" Click="ManageBizu_Click" Margin="0,0,0,6"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Expander>

                            <Expander x:Name="RightsExpander" Header="Direitos do ajuste"
                                      Style="{StaticResource AccordionExpanderStyle}" IsExpanded="False" Visibility="Collapsed"
                                      Expanded="SidebarExpander_Expanded">
                                <StackPanel>
                                    <TextBlock Text="Escolha explicitamente a situação de cada direito." Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,9"/>

                                    <Border Style="{StaticResource InsetCardStyle}" Padding="12" Margin="0,0,0,9">
                                        <StackPanel>
                                            <TextBlock Text="Adicional de férias" FontWeight="SemiBold"/>
                                            <TextBlock Text="Adicional de 1/3 referente às férias." Style="{StaticResource CaptionTextStyle}" Margin="0,3,0,8"/>
                                            <ComboBox x:Name="VacationAdditionalEntitlementBox" SelectedIndex="1" MinHeight="36">
                                                <ComboBoxItem Content="Faz jus"/><ComboBoxItem Content="Não faz jus"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource InsetCardStyle}" Padding="12" Margin="0,0,0,9">
                                        <StackPanel>
                                            <TextBlock Text="Indenização de férias não gozadas" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            <TextBlock Text="Pagamento proporcional das férias que não foram usufruídas." Style="{StaticResource CaptionTextStyle}" Margin="0,3,0,8"/>
                                            <ComboBox x:Name="VacationIndemnityEntitlementBox" SelectedIndex="1" MinHeight="36">
                                                <ComboBoxItem Content="Faz jus"/><ComboBoxItem Content="Não faz jus"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource InsetCardStyle}" Padding="12" Margin="0,0,0,9">
                                        <StackPanel>
                                            <TextBlock Text="Adicional natalino" FontWeight="SemiBold"/>
                                            <TextBlock Text="13º salário calculado pelos avos informados." Style="{StaticResource CaptionTextStyle}" Margin="0,3,0,8"/>
                                            <ComboBox x:Name="ChristmasEntitlementBox" SelectedIndex="1" MinHeight="36">
                                                <ComboBoxItem Content="Faz jus"/><ComboBoxItem Content="Não faz jus"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource InsetCardStyle}" Padding="12" Margin="0,0,0,9">
                                        <StackPanel>
                                            <TextBlock Text="1ª parcela do adicional natalino" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            <TextBlock Text="Informe se a primeira parcela já foi paga para descontá-la do ajuste." Style="{StaticResource CaptionTextStyle}" Margin="0,3,0,8"/>
                                            <ComboBox x:Name="ReceivedChristmasStatusBox" SelectedIndex="1" MinHeight="36">
                                                <ComboBoxItem Content="Já recebeu"/><ComboBoxItem Content="Não recebeu"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource InsetCardStyle}" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="Compensação pecuniária" FontWeight="SemiBold"/>
                                            <TextBlock Text="Controle do direito à compensação pecuniária no caso concreto." Style="{StaticResource CaptionTextStyle}" Margin="0,3,0,8"/>
                                            <ComboBox x:Name="PecuniaryEntitlementBox" SelectedIndex="1" MinHeight="36">
                                                <ComboBoxItem Content="Faz jus"/><ComboBoxItem Content="Não faz jus"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Expander>

                            <Expander x:Name="ValuesExpander" Header="Percentuais e valores-base"
                                      Style="{StaticResource AccordionExpanderStyle}" IsExpanded="False"
                                      Expanded="SidebarExpander_Expanded">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Adicional de habilitação (%)" VerticalAlignment="Center" Margin="0,4"/><TextBox x:Name="QualificationBox" Grid.Column="1" HorizontalContentAlignment="Right" Margin="0,2"/>
                                    <TextBlock Grid.Row="1" Text="Adicional militar (%)" VerticalAlignment="Center" Margin="0,4"/><TextBox x:Name="MilitaryAdditionalBox" Grid.Row="1" Grid.Column="1" HorizontalContentAlignment="Right" Margin="0,2"/>
                                    <TextBlock Grid.Row="2" Text="Disponibilidade militar (%)" VerticalAlignment="Center" Margin="0,4"/><TextBox x:Name="AvailabilityBox" Grid.Row="2" Grid.Column="1" HorizontalContentAlignment="Right" Margin="0,2"/>
                                    <TextBlock Grid.Row="3" Text="Permanência (%)" VerticalAlignment="Center" Margin="0,4"/><TextBox x:Name="PermanenceBox" Grid.Row="3" Grid.Column="1" HorizontalContentAlignment="Right" Margin="0,2"/>
                                    <TextBlock Grid.Row="4" Text="Pré-escolar (R$)" VerticalAlignment="Center" Margin="0,4"/><TextBox x:Name="PreSchoolBox" Grid.Row="4" Grid.Column="1" HorizontalContentAlignment="Right" Margin="0,2"/>
                                    <TextBlock Grid.Row="5" Text="Salário-família (R$)" VerticalAlignment="Center" Margin="0,4"/><TextBox x:Name="FamilySalaryBox" Grid.Row="5" Grid.Column="1" HorizontalContentAlignment="Right" Margin="0,2"/>
                                    <TextBlock Grid.Row="6" Text="FUSEx (%)" VerticalAlignment="Center" Margin="0,4"/><TextBox x:Name="FusexBox" Grid.Row="6" Grid.Column="1" HorizontalContentAlignment="Right" Margin="0,2"/>
                                    <TextBlock Grid.Row="7" Text="Pensão militar (%)" VerticalAlignment="Center" Margin="0,4"/><TextBox x:Name="MilitaryPensionBox" Grid.Row="7" Grid.Column="1" HorizontalContentAlignment="Right" Margin="0,2"/>
                                    <TextBlock Grid.Row="8" Text="PNR (%)" VerticalAlignment="Center" Margin="0,4"/><TextBox x:Name="PnrBox" Grid.Row="8" Grid.Column="1" HorizontalContentAlignment="Right" Margin="0,2"/>
                                    <TextBlock Grid.Row="9" Text="FUSEx dependente (R$)" VerticalAlignment="Center" Margin="0,4"/><TextBox x:Name="FusexDependentBox" Grid.Row="9" Grid.Column="1" HorizontalContentAlignment="Right" Margin="0,2"/>
                                    <TextBlock Grid.Row="10" Text="Despesa médica FUSEx (R$)" VerticalAlignment="Center" Margin="0,4"/><TextBox x:Name="FusexMedicalBox" Grid.Row="10" Grid.Column="1" HorizontalContentAlignment="Right" Margin="0,2"/>
                                    <TextBlock Grid.Row="11" Text="Pensão alimentícia (R$)" VerticalAlignment="Center" Margin="0,4"/><TextBox x:Name="AlimonyBox" Grid.Row="11" Grid.Column="1" HorizontalContentAlignment="Right" Margin="0,2"/>
                                </Grid>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <Border Style="{StaticResource CardStyle}" Padding="10" Margin="0,0,0,10">
                            <WrapPanel>
                                <Button Content="Adicionar rubrica" Style="{StaticResource PrimaryButtonStyle}" Click="AddSippes_Click" Margin="0,0,8,6"/>
                                <Button Content="Adicionar manual" Style="{StaticResource SecondaryButtonStyle}" Click="AddManual_Click" Margin="0,0,8,6"/>
                                <Button Content="Editar" Style="{StaticResource SecondaryButtonStyle}" Click="EditRubric_Click" Margin="0,0,8,6"/>
                                <Button Content="Duplicar" Style="{StaticResource SecondaryButtonStyle}" Click="DuplicateRubric_Click" Margin="0,0,8,6"/>
                                <Button Content="Incluir / excluir" Style="{StaticResource GhostButtonStyle}" Click="ToggleRubric_Click" Margin="0,0,8,6"/>
                                <Button Content="Copiar valor" Style="{StaticResource GhostButtonStyle}" Click="CopyValue_Click" Margin="0,0,8,6"/>
                                <Button Content="Remover" Style="{StaticResource DangerButtonStyle}" Click="RemoveRubric_Click" Margin="0,0,8,6"/>
                                <Button Content="Restaurar rubricas" Style="{StaticResource GhostButtonStyle}" Click="RestoreRubrics_Click" Margin="0,0,8,6"/>
                                <Button Content="Ajuda" Style="{StaticResource GhostButtonStyle}" Click="Help_Click" Margin="0,0,0,6"/>
                            </WrapPanel>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
                            <DataGrid x:Name="RubricsGrid" ItemsSource="{Binding CalculatedRows}" IsReadOnly="False" CanUserAddRows="False" SelectionMode="Extended" MouseDoubleClick="RubricsGrid_MouseDoubleClick" CellEditEnding="RubricsGrid_CellEditEnding">
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Editar (F2)" Click="EditRubric_Click"/>
                                        <MenuItem Header="Incluir / excluir (Espaço)" Click="ToggleRubric_Click"/>
                                        <Separator/>
                                        <MenuItem Header="Duplicar como personalizada" Click="DuplicateRubric_Click"/>
                                        <MenuItem Header="Remover (Delete)" Click="RemoveRubric_Click"/>
                                        <Separator/>
                                        <MenuItem Header="Copiar valor proporcional" Click="CopyValue_Click"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="{DynamicResource SuccessSoftBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Reference}" Value="D"><Setter Property="Background" Value="{DynamicResource DangerSoftBrush}"/></DataTrigger>
                                            <DataTrigger Binding="{Binding IsIncluded}" Value="False"><Setter Property="Opacity" Value="0.48"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="Usar" Binding="{Binding IsIncluded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="55"/>
                                    <DataGridTextColumn Header="Código" Binding="{Binding Code}" Width="88" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Descrição" Binding="{Binding Description}" Width="*" MinWidth="270" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Tipo" Binding="{Binding ReferenceText}" Width="105" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Base" Binding="{Binding Base}" Width="70" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Regra" Binding="{Binding KindText}" Width="82" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Integral" Binding="{Binding FullValueText}" SortMemberPath="FullValue" Width="120" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Proporcional" Binding="{Binding ProportionalValueText}" SortMemberPath="ProportionalValue" Width="130" IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                        <Grid Grid.Row="2" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border Style="{StaticResource SoftCardStyle}" Padding="12" Margin="0,0,8,0"><StackPanel><TextBlock Text="Rendimentos" Foreground="{DynamicResource MutedBrush}"/><TextBlock x:Name="EarningsText" FontSize="20" FontWeight="Bold"/></StackPanel></Border>
                            <Border Grid.Column="1" Style="{StaticResource SoftCardStyle}" Padding="12" Margin="0,0,8,0"><StackPanel><TextBlock Text="Descontos" Foreground="{DynamicResource MutedBrush}"/><TextBlock x:Name="DiscountsText" FontSize="20" FontWeight="Bold"/></StackPanel></Border>
                            <Border Grid.Column="2" Style="{StaticResource SoftCardStyle}" Padding="12" Margin="0,0,8,0"><StackPanel><TextBlock Text="Líquido" Foreground="{DynamicResource MutedBrush}"/><TextBlock x:Name="NetText" FontSize="20" FontWeight="Bold"/></StackPanel></Border>
                            <Border Grid.Column="3" Style="{StaticResource SoftCardStyle}" Padding="12"><StackPanel><TextBlock Text="Base anual" Foreground="{DynamicResource MutedBrush}"/><TextBlock x:Name="AnnualBaseText" FontSize="20" FontWeight="Bold"/></StackPanel></Border>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Imposto de renda">
                <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="0,12" MaxWidth="900" HorizontalAlignment="Left">
                    <Border Style="{StaticResource CardStyle}" Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Imposto de Renda — tabela mensal 2026" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="O cálculo separa a base mensal, férias e adicional natalino. Rendimentos isentos e deduções legais são tratados individualmente." TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" Margin="0,5,0,14"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="170"/></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                <TextBlock Text="Dependentes para IR" VerticalAlignment="Center" Margin="0,5"/><TextBox x:Name="IncomeTaxDependentsBox" Grid.Column="1" HorizontalContentAlignment="Right" Margin="0,3"/>
                                <CheckBox x:Name="IncomeTaxReducerCheck" Grid.Row="1" Grid.ColumnSpan="2" Content="Aplicar redutor mensal de 2026" Margin="0,7"/>
                                <CheckBox x:Name="MonthlyIncomeTaxCheck" Grid.Row="2" Grid.ColumnSpan="2" Content="Calcular IR mensal (AD0010)" Margin="0,7"/>
                                <CheckBox x:Name="VacationIncomeTaxCheck" Grid.Row="3" Grid.ColumnSpan="2" Content="Calcular IR sobre férias (AD0015)" Margin="0,7"/>
                                <CheckBox x:Name="ChristmasIncomeTaxCheck" Grid.Row="4" Grid.ColumnSpan="2" Content="Calcular IR sobre adicional natalino (AD0028)" Margin="0,7"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}" Padding="18">
                        <StackPanel>
                            <TextBlock Text="Deduções na base mensal" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,8"/>
                            <CheckBox x:Name="DeductMedicalCheck" Content="Deduzir despesa médica FUSEx" Margin="0,5"/>
                            <CheckBox x:Name="DeductDependentCheck" Content="Deduzir desconto de dependente FUSEx" Margin="0,5"/>
                            <CheckBox x:Name="DeductAlimonyCheck" Content="Deduzir pensão alimentícia" Margin="0,5"/>
                            <CheckBox x:Name="DeductPnrCheck" Content="Deduzir ocupação de PNR" Margin="0,5"/>
                            <TextBlock Text="A pensão militar e o FUSEx de 3% são deduzidos automaticamente. A dedução por dependente usa R$ 189,59 por dependente." TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel></ScrollViewer>
            </TabItem>

            <TabItem Header="Conferência">
                <Grid Margin="0,12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Style="{StaticResource CardStyle}" Padding="18">
                        <StackPanel>
                            <TextBlock Text="Valores integrais" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock x:Name="FullSummaryText" FontFamily="Consolas" TextWrapping="Wrap" Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="18">
                        <StackPanel>
                            <TextBlock Text="Valores proporcionais" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock x:Name="ProportionalSummaryText" FontFamily="Consolas" TextWrapping="Wrap" Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <TextBlock x:Name="StatusText" Text="Carregando…" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Salvar configuração" Style="{StaticResource SecondaryButtonStyle}" Click="Save_Click" Margin="0,0,8,0"/>
                <Button Content="Fechar" IsCancel="True" Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
