<Window x:Class="SIGFUR.Wpf.Views.Finance.BankInconsistencyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIGFUR — Inconsistência Bancária" Width="1120" Height="780" MinWidth="900" MinHeight="650"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="86"/><RowDefinition Height="*"/><RowDefinition Height="46"/></Grid.RowDefinitions>
        <Border Background="{DynamicResource PrimaryGradientBrush}" Padding="24,0">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center"><TextBlock Text="INCONSISTÊNCIA BANCÁRIA" Foreground="White" FontWeight="Bold" FontSize="24"/><TextBlock Text="CPEX e lançamentos criticados do SINFOPPES" Foreground="#DCEBFF" Margin="0,4,0,0"/></StackPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Center"><Button Content="Abrir pasta" Style="{StaticResource LightOnDarkButtonStyle}" Click="OpenFolder_Click" Margin="0,0,8,0"/><Button Content="Fechar navegador" Style="{StaticResource LightOnDarkButtonStyle}" Click="CloseBrowser_Click"/></WrapPanel>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabs" Grid.Row="1" Margin="16,12,16,10">
            <TabItem Header="CPEX — Inconsistências">
                <Grid Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="1.25*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="0.9*"/></Grid.ColumnDefinitions>
                    <Border Style="{StaticResource CardStyle}" Padding="18">
                        <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <TextBlock Text="PARÂMETROS DA CONSULTA" Style="{StaticResource SectionTitleStyle}"/>
                            <Grid Grid.Row="1" Margin="0,14,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="Sistema" Style="{StaticResource CaptionTextStyle}"/><ComboBox x:Name="CpexSystemBox" IsEditable="True"><ComboBoxItem Content="SIPPES"/><ComboBoxItem Content="SIAPPES"/></ComboBox></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Text="Ano" Style="{StaticResource CaptionTextStyle}"/><ComboBox x:Name="CpexYearBox" IsEditable="True"/></StackPanel>
                            </Grid>
                            <Grid Grid.Row="2" Margin="0,12,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="Mês" Style="{StaticResource CaptionTextStyle}"/><ComboBox x:Name="CpexMonthBox"/></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Text="Região Militar" Style="{StaticResource CaptionTextStyle}"/><ComboBox x:Name="CpexRegionBox" IsEditable="True"/></StackPanel>
                            </Grid>
                            <Grid Grid.Row="3" Margin="0,12,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="CODOM" Style="{StaticResource CaptionTextStyle}"/><ComboBox x:Name="CpexCodomBox" IsEditable="True"/></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Text="Tipo do relatório" Style="{StaticResource CaptionTextStyle}"/><ComboBox x:Name="CpexReportTypeBox" IsEditable="True"><ComboBoxItem Content="Erro Ag/Conta"/><ComboBoxItem Content="Falta de apresentação"/></ComboBox></StackPanel>
                            </Grid>
                            <StackPanel Grid.Row="4" Margin="0,12,0,0"><TextBlock Text="Pasta de saída" Style="{StaticResource CaptionTextStyle}"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="CpexOutputBox"/><Button Grid.Column="1" Content="..." Style="{StaticResource SecondaryButtonStyle}" Click="BrowseCpexOutput_Click" Margin="8,0,0,0"/></Grid></StackPanel>
                            <WrapPanel Grid.Row="5" Margin="0,14,0,0"><CheckBox x:Name="CpexSpreadsheetCheck" Content="Baixar planilha" Margin="0,0,16,8"/><CheckBox x:Name="CpexOpenPdfCheck" Content="Abrir PDF" Margin="0,0,16,8"/><CheckBox x:Name="CpexHeadlessCheck" Content="Segundo plano" Margin="0,0,16,8"/><CheckBox x:Name="CpexKeepOpenCheck" Content="Manter navegador aberto" Margin="0,0,0,8"/></WrapPanel>
                            <WrapPanel Grid.Row="6" Margin="0,16,0,0"><Button Content="Consultar e salvar" Style="{StaticResource PrimaryButtonStyle}" Click="RunCpex_Click" Margin="0,0,8,0"/><Button Content="Abrir site" Style="{StaticResource SecondaryButtonStyle}" Click="OpenCpexSite_Click" Margin="0,0,8,0"/><Button Content="Abrir último PDF" Style="{StaticResource GhostButtonStyle}" Click="OpenLastCpexPdf_Click"/></WrapPanel>
                        </Grid>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="18"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="EXECUÇÃO" Style="{StaticResource SectionTitleStyle}"/><TextBox x:Name="CpexLogBox" Grid.Row="1" Margin="0,14,0,0" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top"/></Grid></Border>
                </Grid>
            </TabItem>

            <TabItem Header="SINFOPPES — Lançamentos Criticados">
                <Grid Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="1.25*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="0.9*"/></Grid.ColumnDefinitions>
                    <Border Style="{StaticResource CardStyle}" Padding="18">
                        <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <TextBlock Text="ACESSO E FILTROS" Style="{StaticResource SectionTitleStyle}"/>
                            <Grid Grid.Row="1" Margin="0,14,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="CPF" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="SinfCpfBox"/></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Text="Senha" Style="{StaticResource CaptionTextStyle}"/><PasswordBox x:Name="SinfPasswordBox"/></StackPanel>
                            </Grid>
                            <Grid Grid.Row="2" Margin="0,12,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="Ano" Style="{StaticResource CaptionTextStyle}"/><ComboBox x:Name="SinfYearBox" IsEditable="True"/></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Text="Mês" Style="{StaticResource CaptionTextStyle}"/><ComboBox x:Name="SinfMonthBox"/></StackPanel>
                                <StackPanel Grid.Column="4"><TextBlock Text="Corrida" Style="{StaticResource CaptionTextStyle}"/><ComboBox x:Name="SinfRunBox"><ComboBoxItem Content="1ª CORRIDA"/><ComboBoxItem Content="2ª CORRIDA"/><ComboBoxItem Content="3ª CORRIDA"/></ComboBox></StackPanel>
                            </Grid>
                            <StackPanel Grid.Row="3" Margin="0,12,0,0"><TextBlock Text="Pasta de saída" Style="{StaticResource CaptionTextStyle}"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="SinfOutputBox"/><Button Grid.Column="1" Content="..." Style="{StaticResource SecondaryButtonStyle}" Click="BrowseSinfOutput_Click" Margin="8,0,0,0"/></Grid></StackPanel>
                            <WrapPanel Grid.Row="4" Margin="0,14,0,0"><CheckBox x:Name="SinfSaveCpfCheck" Content="Salvar CPF" Margin="0,0,16,8"/><CheckBox x:Name="SinfSavePasswordCheck" Content="Salvar senha" Margin="0,0,16,8"/><CheckBox x:Name="SinfOpenPdfCheck" Content="Abrir PDF" Margin="0,0,16,8"/><CheckBox x:Name="SinfHeadlessCheck" Content="Segundo plano" Margin="0,0,16,8"/><CheckBox x:Name="SinfKeepOpenCheck" Content="Manter navegador aberto" Margin="0,0,0,8"/></WrapPanel>
                            <WrapPanel Grid.Row="5" Margin="0,16,0,0"><Button Content="Gerar relatório" Style="{StaticResource PrimaryButtonStyle}" Click="RunSinfoppes_Click" Margin="0,0,8,0"/><Button Content="Abrir site" Style="{StaticResource SecondaryButtonStyle}" Click="OpenSinfSite_Click" Margin="0,0,8,0"/><Button Content="Abrir último PDF" Style="{StaticResource GhostButtonStyle}" Click="OpenLastSinfPdf_Click"/></WrapPanel>
                        </Grid>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="18"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="EXECUÇÃO" Style="{StaticResource SectionTitleStyle}"/><TextBox x:Name="SinfLogBox" Grid.Row="1" Margin="0,14,0,0" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top"/></Grid></Border>
                </Grid>
            </TabItem>

            <TabItem Header="Relatórios salvos">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Border Style="{StaticResource CardStyle}" Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="PDFS GERADOS" Style="{StaticResource SectionTitleStyle}"/><TextBlock x:Name="SavedReportsSummaryText" Text="Selecione dois ou mais relatórios para abrir e comparar." Foreground="{DynamicResource SubtleTextBrush}" Margin="0,4,0,0"/></StackPanel>
                            <WrapPanel Grid.Column="1" VerticalAlignment="Center"><Button Content="Atualizar" Style="{StaticResource SecondaryButtonStyle}" Click="RefreshReports_Click" Margin="0,0,8,0"/><Button Content="Abrir selecionado(s)" Style="{StaticResource PrimaryButtonStyle}" Click="OpenReports_Click" Margin="0,0,8,0"/><Button Content="Abrir pasta" Style="{StaticResource GhostButtonStyle}" Click="OpenReportsFolder_Click"/></WrapPanel>
                        </Grid>
                    </Border>
                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="4" Margin="0,10,0,0">
                        <DataGrid x:Name="SavedReportsGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Extended" SelectionUnit="FullRow" MouseDoubleClick="SavedReportsGrid_MouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Origem" Binding="{Binding Source}" Width="145"/>
                                <DataGridTextColumn Header="Arquivo" Binding="{Binding Name}" Width="*" MinWidth="320"/>
                                <DataGridTextColumn Header="Competência" Binding="{Binding Competence}" Width="125"/>
                                <DataGridTextColumn Header="Gerado em" Binding="{Binding ModifiedText}" Width="150"/>
                                <DataGridTextColumn Header="Tamanho" Binding="{Binding SizeText}" Width="90"/>
                                <DataGridTextColumn Header="Pasta" Binding="{Binding Folder}" Width="260"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                    <TextBlock Grid.Row="2" Margin="4,8,0,0" Foreground="{DynamicResource SubtleTextBrush}" Text="Ctrl ou Shift seleciona vários PDFs. O botão abre todos para conferência lado a lado."/>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0" Padding="16,0">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="220"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock x:Name="StatusText" VerticalAlignment="Center"/><ProgressBar x:Name="Progress" Grid.Column="1" Height="7" Minimum="0" Maximum="100" VerticalAlignment="Center"/><Button Grid.Column="2" x:Name="CancelButton" Content="Cancelar" Style="{StaticResource DangerButtonStyle}" Click="Cancel_Click" Margin="12,0,0,0" IsEnabled="False"/></Grid>
        </Border>
    </Grid>
</Window>
