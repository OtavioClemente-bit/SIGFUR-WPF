<Window x:Class="SIGFUR.Wpf.Views.Finance.SippesRubricPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Selecionar rubrica SIPPES"
        Width="1080" Height="720" MinWidth="860" MinHeight="540"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Catálogo de Rubricas SIPPES" Style="{StaticResource PageTitleStyle}"/>
            <TextBlock Text="As 1.800 rubricas do catálogo do código Python foram preservadas. Pesquise por código, descrição, tipo ou natureza." Style="{StaticResource PageSubtitleStyle}" Margin="0,4,0,14"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="170"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Buscar" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="SearchBox" Grid.Column="1" TextChanged="Filter_Changed"/>
                <TextBlock Grid.Column="2" Text="Filtro" VerticalAlignment="Center" Margin="16,0,8,0"/>
                <ComboBox x:Name="FilterBox" Grid.Column="3" SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="Todos" IsSelected="True"/>
                    <ComboBoxItem Content="Receita"/>
                    <ComboBoxItem Content="Despesa"/>
                    <ComboBoxItem Content="AR"/>
                    <ComboBoxItem Content="AD"/>
                    <ComboBoxItem Content="DR"/>
                    <ComboBoxItem Content="DD"/>
                    <ComboBoxItem Content="NR"/>
                    <ComboBoxItem Content="ND"/>
                    <ComboBoxItem Content="FR"/>
                    <ComboBoxItem Content="FD"/>
                    <ComboBoxItem Content="ER"/>
                    <ComboBoxItem Content="ED"/>
                </ComboBox>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid x:Name="RubricsGrid" ItemsSource="{Binding Items}" MouseDoubleClick="RubricsGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Código" Binding="{Binding Code}" Width="100"/>
                    <DataGridTextColumn Header="Descrição oficial" Binding="{Binding Description}" Width="*" MinWidth="360"/>
                    <DataGridTextColumn Header="Tipo" Binding="{Binding RubricType}" Width="140"/>
                    <DataGridTextColumn Header="Natureza" Binding="{Binding Nature}" Width="130"/>
                    <DataGridTextColumn Header="Efeito" Binding="{Binding EffectText}" Width="160"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <TextBlock x:Name="ResultCountText" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="Usar rubrica selecionada" IsDefault="True" Style="{StaticResource PrimaryButtonStyle}" Click="Select_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
