<Window x:Class="SIGFUR.Wpf.Views.Finance.GratificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SIGFUR.Wpf.Controls"
        Title="SIGFUR — Gratificação de Representação (2%)"
        Width="1480" Height="900" MinWidth="1080" MinHeight="720"
        WindowStartupLocation="CenterOwner" Icon="/Assets/sigfur.ico"
        Background="{DynamicResource AppBackgroundBrush}"
        Loaded="Window_Loaded" Closing="Window_Closing" PreviewKeyDown="Window_PreviewKeyDown">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="76"/><RowDefinition Height="*"/><RowDefinition Height="38"/></Grid.RowDefinitions>
        <Border Background="{DynamicResource PrimaryDarkBrush}" Padding="22,0">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="GRATIFICAÇÃO DE REPRESENTAÇÃO (2%)" Foreground="White" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="Cálculo legal por horário real, boletim, SisBol, planilha, DIEx e mapa" Foreground="{DynamicResource TextOnPrimaryMutedBrush}"/>
                </StackPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                    <Border Background="#22FFFFFF" CornerRadius="9" Padding="11,7" Margin="0,0,10,0">
                        <TextBlock Text="SisBol: prepare na janela principal" Foreground="White" FontWeight="SemiBold"/>
                    </Border>
                    <Button Content="Consultar soldos" Style="{StaticResource LightOnDarkButtonStyle}" Click="OpenSalaries_Click" MinWidth="128"/>
                </WrapPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="14">
            <TabItem Header="Gratificação 2%">
                <Grid Margin="10">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Border Style="{StaticResource CardStyle}" Padding="14" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="1.4*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="1.6*"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Local do deslocamento" Style="{StaticResource CaptionTextStyle}"/>
                                <TextBox x:Name="DestinationBox" TextChanged="MainForm_Changed" SpellCheck.IsEnabled="True"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Finalidade" Style="{StaticResource CaptionTextStyle}"/>
                                <TextBox x:Name="PurposeBox" TextChanged="MainForm_Changed" SpellCheck.IsEnabled="True"/>
                            </StackPanel>

                            <Grid Grid.Row="1" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="8"/><ColumnDefinition Width="85"/><ColumnDefinition Width="18"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="8"/><ColumnDefinition Width="85"/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="Saída" Style="{StaticResource CaptionTextStyle}"/><DatePicker x:Name="DepartureDatePicker" SelectedDateChanged="MainForm_Changed" Width="135"/></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Text="Hora" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="DepartureTimeBox" Text="06:00" TextAlignment="Center" TextChanged="MainForm_Changed" ToolTip="Use o horário real da saída. A fração igual ou superior a 8h conta como mais 1 dia."/></StackPanel>
                                <StackPanel Grid.Column="4"><TextBlock Text="Retorno" Style="{StaticResource CaptionTextStyle}"/><DatePicker x:Name="ReturnDatePicker" SelectedDateChanged="MainForm_Changed" Width="135"/></StackPanel>
                                <StackPanel Grid.Column="6"><TextBlock Text="Hora" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="ReturnTimeBox" Text="21:00" TextAlignment="Center" TextChanged="MainForm_Changed" ToolTip="Use o horário real do retorno. Sobra menor que 8h não gera novo dia indenizável."/></StackPanel>
                            </Grid>
                            <Grid Grid.Row="1" Grid.Column="2" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="BI nº / data" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="BulletinBox" TextChanged="MainForm_Changed"/></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Text="Assunto específico no SisBol" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="SisbolSubjectBox" TextChanged="MainForm_Changed"/></StackPanel>
                            </Grid>
                            <Border Grid.Row="2" Grid.ColumnSpan="3" Background="{DynamicResource PrimarySurfaceBrush}" CornerRadius="9" Padding="11" Margin="0,11,0,0">
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock x:Name="PeriodSummaryText" Text="Informe o período." TextWrapping="Wrap"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                                        <TextBlock Text="Código específico (opcional):" VerticalAlignment="Center" Style="{StaticResource CaptionTextStyle}" Margin="0,0,7,0"/>
                                        <TextBox x:Name="SisbolCodeBox" Width="115" TextChanged="MainForm_Changed"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource CardStyle}" Padding="12">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock Text="Militares disponíveis" Style="{StaticResource SectionTitleStyle}"/><TextBox x:Name="AvailableSearchBox" Margin="0,8,0,10" TextChanged="AvailableSearch_Changed" ToolTip="Nome, nome de guerra, CPF, PREC-CP ou posto"/></StackPanel>
                                    <WrapPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="12,0,0,10"><Button Content="Adicionar selecionados" Style="{StaticResource PrimaryButtonStyle}" Click="AddSelected_Click" Margin="0,0,7,0"/><Button Content="Adicionar todos visíveis" Style="{StaticResource SecondaryButtonStyle}" Click="AddAll_Click"/></WrapPanel>
                                </Grid>
                                <DataGrid Grid.Row="1" x:Name="AvailableGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Extended" MouseDoubleClick="AvailableGrid_MouseDoubleClick" Sorting="MilitaryGrid_Sorting">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="P/G" Binding="{Binding ShortRank}" Width="100" SortMemberPath="Rank"/>
                                        <DataGridTemplateColumn Header="Nome completo" Width="*" MinWidth="280" SortMemberPath="Name"><DataGridTemplateColumn.CellTemplate><DataTemplate><controls:HighlightedNameTextBlock FullName="{Binding Name}" WarName="{Binding WarName}" VerticalAlignment="Center"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                        <DataGridTextColumn Header="CPF" Binding="{Binding FormattedCpf}" Width="135" SortMemberPath="Cpf"/>
                                        <DataGridTextColumn Header="PREC-CP" Binding="{Binding PrecCp}" Width="120" SortMemberPath="PrecCp"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="12">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock Text="Militares selecionados" Style="{StaticResource SectionTitleStyle}"/><TextBlock x:Name="SelectedCountText" Text="0 militar(es)" Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,10"/></StackPanel>
                                    <WrapPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="12,0,0,10"><Button Content="Remover" Style="{StaticResource DangerButtonStyle}" Click="RemoveSelected_Click" Margin="0,0,7,0"/><Button Content="Limpar" Style="{StaticResource SecondaryButtonStyle}" Click="ClearSelected_Click"/></WrapPanel>
                                </Grid>
                                <DataGrid Grid.Row="1" x:Name="SelectedGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Extended" Sorting="ParticipantGrid_Sorting">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="P/G" Binding="{Binding Military.ShortRank}" Width="95" SortMemberPath="Military.Rank"/>
                                        <DataGridTemplateColumn Header="Nome completo" Width="*" MinWidth="250" SortMemberPath="Military.Name"><DataGridTemplateColumn.CellTemplate><DataTemplate><controls:HighlightedNameTextBlock FullName="{Binding Military.Name}" WarName="{Binding Military.WarName}" VerticalAlignment="Center"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Soldo" Binding="{Binding SalaryText}" Width="115" SortMemberPath="Salary"/>
                                        <DataGridTextColumn Header="2%/dia" Binding="{Binding DailyRateText}" Width="105" SortMemberPath="DailyRate"/>
                                        <DataGridTextColumn Header="Dias" Binding="{Binding Days}" Width="60" SortMemberPath="Days"/>
                                        <DataGridTextColumn Header="Total" Binding="{Binding TotalText}" Width="120" SortMemberPath="Total"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="13" Margin="0,12,0,0">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="MILITARES" Style="{StaticResource MetricCaptionStyle}"/><TextBlock x:Name="TotalParticipantsText" Text="0" Style="{StaticResource MetricValueStyle}"/></StackPanel>
                            <StackPanel Grid.Column="1"><TextBlock Text="DIAS INDENIZÁVEIS" Style="{StaticResource MetricCaptionStyle}"/><TextBlock x:Name="DaysText" Text="0" Style="{StaticResource MetricValueStyle}"/></StackPanel>
                            <StackPanel Grid.Column="2"><TextBlock Text="DURAÇÃO REAL" Style="{StaticResource MetricCaptionStyle}"/><TextBlock x:Name="DurationText" Text="—" FontSize="16" FontWeight="SemiBold"/></StackPanel>
                            <StackPanel Grid.Column="3"><TextBlock Text="TOTAL GERAL" Style="{StaticResource MetricCaptionStyle}"/><TextBlock x:Name="GrandTotalText" Text="R$ 0,00" Foreground="{DynamicResource SuccessBrush}" Style="{StaticResource MetricValueStyle}"/></StackPanel>
                            <WrapPanel Grid.Column="4" VerticalAlignment="Center">
                                <Button Content="Exportar CSV" Style="{StaticResource SecondaryButtonStyle}" Click="ExportCsv_Click" Margin="0,0,7,0"/>
                                <Button Content="Exportar Excel" Style="{StaticResource SecondaryButtonStyle}" Click="ExportXlsx_Click" Margin="0,0,7,0"/>
                                <Button Content="Gerar boletim" Style="{StaticResource PrimaryButtonStyle}" Click="GenerateBulletin_Click"/>
                            </WrapPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Solicitação — DIEx e Mapa">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <Border Style="{StaticResource CardStyle}" Padding="15" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <StackPanel><TextBlock Text="Natureza" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="RequestNatureBox" TextChanged="RequestForm_Changed" SpellCheck.IsEnabled="True"/></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Text="Local do evento" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="RequestLocationBox" TextChanged="RequestForm_Changed"/></StackPanel>
                                <StackPanel Grid.Row="1" Margin="0,10,0,0"><TextBlock Text="Descrição" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="RequestDescriptionBox" TextChanged="RequestForm_Changed" SpellCheck.IsEnabled="True"/></StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,10,0,0"><TextBlock Text="Enquadramento" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="RequestLegalBasisBox" TextChanged="RequestForm_Changed" SpellCheck.IsEnabled="True"/></StackPanel>
                                <StackPanel Grid.Row="2" Margin="0,10,0,0"><TextBlock Text="Documento autorizador" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="RequestAuthorizingDocumentBox" TextChanged="RequestForm_Changed"/></StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,10,0,0"><TextBlock Text="BI da relação nominal" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="RequestBulletinBox" TextChanged="RequestForm_Changed"/></StackPanel>
                                <Grid Grid.Row="3" Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="8"/><ColumnDefinition Width="80"/><ColumnDefinition Width="18"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="8"/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock Text="Início" Style="{StaticResource CaptionTextStyle}"/><DatePicker x:Name="RequestStartDatePicker" Width="135" SelectedDateChanged="RequestForm_Changed"/></StackPanel>
                                    <StackPanel Grid.Column="2"><TextBlock Text="Hora" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="RequestStartTimeBox" TextAlignment="Center" TextChanged="RequestForm_Changed"/></StackPanel>
                                    <StackPanel Grid.Column="4"><TextBlock Text="Fim" Style="{StaticResource CaptionTextStyle}"/><DatePicker x:Name="RequestEndDatePicker" Width="135" SelectedDateChanged="RequestForm_Changed"/></StackPanel>
                                    <StackPanel Grid.Column="6"><TextBlock Text="Hora" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="RequestEndTimeBox" TextAlignment="Center" TextChanged="RequestForm_Changed"/></StackPanel>
                                </Grid>
                                <Grid Grid.Row="3" Grid.Column="2" Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock Text="Responsável / contato" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="RequestContactBox" TextChanged="RequestForm_Changed"/></StackPanel>
                                    <StackPanel Grid.Column="2"><TextBlock Text="RITEX" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="RequestRitexBox" TextChanged="RequestForm_Changed"/></StackPanel>
                                </Grid>
                                <Grid Grid.Row="4" Grid.ColumnSpan="3" Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock Text="E-mail" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="RequestEmailBox" TextChanged="RequestForm_Changed"/></StackPanel>
                                    <StackPanel Grid.Column="2"><TextBlock Text="Assinatura / autoridade" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="RequestAuthorityBox" TextChanged="RequestForm_Changed"/></StackPanel>
                                    <StackPanel Grid.Column="4"><TextBlock Text="Cidade do Quartel" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="RequestCityBox" TextChanged="RequestForm_Changed"/></StackPanel>
                                </Grid>
                                <Grid Grid.Row="5" Grid.ColumnSpan="3" Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition Width="250"/><ColumnDefinition Width="10"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock Text="Organização Militar" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="RequestOrganizationBox" TextChanged="RequestForm_Changed"/></StackPanel>
                                    <StackPanel Grid.Column="2"><TextBlock Text="Dias indenizáveis" Style="{StaticResource CaptionTextStyle}"/>
                                        <Grid MinHeight="40" ToolTip="Use − e + para ajustar. O valor inicial é calculado pelo período.">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="110"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                                            <Button Content="−" Click="RequestDaysMinus_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="0" FontSize="18"/>
                                            <Border Grid.Column="1" Margin="10,0" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="2" CornerRadius="7">
                                                <TextBlock x:Name="RequestDaysText" Text="0" TextAlignment="Center" HorizontalAlignment="Stretch" VerticalAlignment="Center" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                                            </Border>
                                            <Button Grid.Column="2" Content="+" Click="RequestDaysPlus_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="0" FontSize="18"/>
                                        </Grid>
                                    </StackPanel>
                                    <Button Grid.Column="4" Content="Salvar comandante e OM como padrão" Style="{StaticResource SecondaryButtonStyle}" Click="SaveInstitutionalProfile_Click" VerticalAlignment="Bottom" MinWidth="220"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,0,12">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="390"/></Grid.RowDefinitions>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock Text="Efetivo por posto/graduação" Style="{StaticResource SectionTitleStyle}"/><TextBlock Text="A tabela foi dividida em duas colunas para caber melhor. Use − e + para alterar o efetivo." Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,9"/></StackPanel>
                                    <Button Grid.Column="1" Content="Recarregar soldos" Style="{StaticResource SecondaryButtonStyle}" Click="ReloadEffective_Click" VerticalAlignment="Bottom" Margin="12,0,0,9"/>
                                </Grid>
                                <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <DataGrid x:Name="EffectiveLeftGrid" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single" RowHeaderWidth="0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="P/G" Binding="{Binding ShortRank}" Width="*" MinWidth="105" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="2%/dia" Binding="{Binding DailyRateText}" Width="100" IsReadOnly="True"/>
                                            <DataGridTemplateColumn Header="Efetivo" Width="150"><DataGridTemplateColumn.CellTemplate><DataTemplate><Grid Margin="2"><Grid.ColumnDefinitions><ColumnDefinition Width="38"/><ColumnDefinition Width="58"/><ColumnDefinition Width="38"/></Grid.ColumnDefinitions><Button Content="−" Tag="{Binding}" Click="EffectiveMinus_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="5,2" FontSize="16" FontWeight="Bold"/><TextBlock Grid.Column="1" Text="{Binding Quantity}" TextAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/><Button Grid.Column="2" Content="+" Tag="{Binding}" Click="EffectivePlus_Click" Style="{StaticResource PrimaryButtonStyle}" Padding="5,2" FontSize="16" FontWeight="Bold"/></Grid></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Dias" Binding="{Binding Days}" Width="60" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="Subtotal" Binding="{Binding SubtotalText}" Width="115" IsReadOnly="True"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <DataGrid Grid.Column="2" x:Name="EffectiveRightGrid" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single" RowHeaderWidth="0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="P/G" Binding="{Binding ShortRank}" Width="*" MinWidth="105" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="2%/dia" Binding="{Binding DailyRateText}" Width="100" IsReadOnly="True"/>
                                            <DataGridTemplateColumn Header="Efetivo" Width="150"><DataGridTemplateColumn.CellTemplate><DataTemplate><Grid Margin="2"><Grid.ColumnDefinitions><ColumnDefinition Width="38"/><ColumnDefinition Width="58"/><ColumnDefinition Width="38"/></Grid.ColumnDefinitions><Button Content="−" Tag="{Binding}" Click="EffectiveMinus_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="5,2" FontSize="16" FontWeight="Bold"/><TextBlock Grid.Column="1" Text="{Binding Quantity}" TextAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/><Button Grid.Column="2" Content="+" Tag="{Binding}" Click="EffectivePlus_Click" Style="{StaticResource PrimaryButtonStyle}" Padding="5,2" FontSize="16" FontWeight="Bold"/></Grid></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Dias" Binding="{Binding Days}" Width="60" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="Subtotal" Binding="{Binding SubtotalText}" Width="115" IsReadOnly="True"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource CardStyle}" Padding="14">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock x:Name="RequestSummaryText" Text="Informe o período e o efetivo." TextWrapping="Wrap" VerticalAlignment="Center"/>
                                <WrapPanel Grid.Column="1" Margin="16,0,0,0">
                                    <Button Content="Gerar DIEx" Style="{StaticResource PrimaryButtonStyle}" Click="GenerateDiex_Click" Margin="0,0,8,0" MinWidth="112"/>
                                    <Button Content="Gerar Mapa" Style="{StaticResource SecondaryButtonStyle}" Click="GenerateMap_Click" Margin="0,0,8,0" MinWidth="112"/>
                                    <Button Content="Gerar DIEx + Mapa" Style="{StaticResource SecondaryButtonStyle}" Click="GenerateBoth_Click" MinWidth="150"/>
                                </WrapPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0" Padding="16,0">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{DynamicResource SubtleTextBrush}" Text="Ctrl+F pesquisar  •  Ctrl+A adicionar visíveis  •  Delete remover  •  Ctrl+G gerar boletim  •  F5 atualizar"/>
            </Grid>
        </Border>
    </Grid>
</Window>
