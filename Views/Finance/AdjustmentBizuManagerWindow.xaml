<Window x:Class="SIGFUR.Wpf.Views.Finance.AdjustmentBizuManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bizu — Efeitos pecuniários" Width="1180" Height="760" MinWidth="940" MinHeight="600"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="Bizu de Ajuste de Contas" Style="{StaticResource PageTitleStyle}"/>
            <TextBlock Text="Hipóteses, direitos e fundamentos do ajuste de contas." Style="{StaticResource PageSubtitleStyle}" Margin="0,4,0,14"/>
        </StackPanel>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Border Style="{StaticResource CardStyle}" Padding="0">
                <DataGrid x:Name="RulesGrid" ItemsSource="{Binding Rules}" SelectionChanged="RulesGrid_SelectionChanged" MouseDoubleClick="RulesGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Hipótese" Binding="{Binding Title}" Width="*" MinWidth="300"/>
                        <DataGridTextColumn Header="Férias" Binding="{Binding VacationAdditionalText}" Width="105"/>
                        <DataGridTextColumn Header="Indenização" Binding="{Binding VacationIndemnityText}" Width="105"/>
                        <DataGridTextColumn Header="13º" Binding="{Binding ChristmasAdditionalText}" Width="105"/>
                        <DataGridTextColumn Header="Pecuniária" Binding="{Binding PecuniaryText}" Width="105"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel>
                    <TextBlock x:Name="RuleTitleText" Text="Selecione uma regra" Style="{StaticResource SectionTitleStyle}" TextWrapping="Wrap"/>
                    <TextBlock Text="Fundamento" FontWeight="SemiBold" Margin="0,18,0,5"/>
                    <TextBlock x:Name="LegalBasisText" Text="—" TextWrapping="Wrap"/>
                    <TextBlock Text="Orientação" FontWeight="SemiBold" Margin="0,18,0,5"/>
                    <TextBlock x:Name="ObservationText" Text="—" TextWrapping="Wrap"/>
                    <TextBlock Text="Origem" FontWeight="SemiBold" Margin="0,18,0,5"/>
                    <TextBlock x:Name="OriginText" Text="—" TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}"/>
                </StackPanel></ScrollViewer>
            </Border>
        </Grid>
        <Grid Grid.Row="2" Margin="0,14,0,0">
            <StackPanel Orientation="Horizontal">
                <Button Content="Nova regra" Style="{StaticResource SecondaryButtonStyle}" Click="Add_Click" Margin="0,0,8,0"/>
                <Button Content="Editar" Style="{StaticResource SecondaryButtonStyle}" Click="Edit_Click" Margin="0,0,8,0"/>
                <Button Content="Excluir" Style="{StaticResource DangerButtonStyle}" Click="Delete_Click" Margin="0,0,8,0"/>
                <Button Content="Restaurar padrões" Style="{StaticResource GhostButtonStyle}" Click="Restore_Click"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Fechar" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="Usar regra selecionada" Style="{StaticResource PrimaryButtonStyle}" Click="Use_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
