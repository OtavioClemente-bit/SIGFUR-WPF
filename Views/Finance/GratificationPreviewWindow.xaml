<Window x:Class="SIGFUR.Wpf.Views.Finance.GratificationPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:SIGFUR.Wpf.Services"
        Title="SIGFUR — Prévia da Gratificação de Representação"
        Width="1120" Height="780" MinWidth="860" MinHeight="580"
        WindowStartupLocation="CenterOwner" Icon="/Assets/sigfur.ico"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="14">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Style="{StaticResource CardStyle}" Padding="14" Margin="0,0,0,10">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                <StackPanel><TextBlock Text="Assunto específico no SisBol" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="SubjectBox"/></StackPanel>
                <StackPanel Grid.Column="2"><TextBlock Text="Código específico (opcional)" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="CodeBox"/></StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="4">
            <FlowDocumentScrollViewer x:Name="PreviewViewer" VerticalScrollBarVisibility="Auto" IsToolBarVisible="False"/>
        </Border>
        <TextBlock Grid.Row="2" x:Name="StatusText" Margin="4,9,4,7" TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}"/>
        <WrapPanel Grid.Row="3" HorizontalAlignment="Right">
            <CheckBox x:Name="IncludeConsequencesCheck" Content="Incluir consequência" IsChecked="True" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="ConsequencesTextBox" Width="460" MinHeight="44" MaxHeight="86" Text="{x:Static services:SisbolTexts.GratificationConsequencesText}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top" Padding="8,5" Margin="0,0,12,0" ToolTip="Texto editável enviado ao campo Texto de Fechamento do SisBol."/>
            <Button Content="Copiar para Word/SisBol" Style="{StaticResource PrimaryButtonStyle}" Click="Copy_Click" Margin="0,0,8,0"/>
            <Button Content="Salvar TXT" Style="{StaticResource SecondaryButtonStyle}" Click="Save_Click" Margin="0,0,8,0"/>
            <Button Content="Enviar ao SisBol" Style="{StaticResource PrimaryButtonStyle}" Click="Send_Click" Margin="0,0,8,0"/>
            <Button Content="Fechar" Style="{StaticResource SecondaryButtonStyle}" IsCancel="True"/>
        </WrapPanel>
    </Grid>
</Window>
