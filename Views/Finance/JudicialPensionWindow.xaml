<Window x:Class="SIGFUR.Wpf.Views.Finance.JudicialPensionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:SIGFUR.Wpf.Services"
        Title="SIGFUR — Pensão Judicial" Width="1480" Height="920" MinWidth="1120" MinHeight="720"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="86"/><RowDefinition Height="*"/><RowDefinition Height="42"/></Grid.RowDefinitions>
        <Border Background="{DynamicResource PrimaryGradientBrush}" Padding="24,0">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center"><TextBlock Text="PENSÃO JUDICIAL" Foreground="White" FontWeight="Bold" FontSize="24"/><TextBlock Text="Cálculo administrativo, IRRF 2026, histórico, documento e texto para boletim — tudo nativo em C#." Foreground="#DCEBFF" Margin="0,4,0,0"/></StackPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Center"><Button Content="Novo cálculo" Style="{StaticResource LightOnDarkButtonStyle}" Click="NewCalculation_Click" Margin="0,0,8,0"/><Button Content="Salvar cálculo" Style="{StaticResource LightOnDarkButtonStyle}" Click="SaveCalculation_Click" Margin="0,0,8,0"/><Button Content="Copiar resumo" Style="{StaticResource LightOnDarkButtonStyle}" Click="CopySummary_Click" Margin="0,0,8,0"/><Button Content="Gerar Word" Style="{StaticResource LightOnDarkButtonStyle}" Click="ExportWord_Click"/></WrapPanel>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabs" Grid.Row="1" Margin="16,12,16,10" SelectionChanged="MainTabs_SelectionChanged">
            <TabItem Header="Cálculo">
                <Grid Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="1.35*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="0.8*"/></Grid.ColumnDefinitions>
                    <Border Style="{StaticResource CardStyle}" Padding="4">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="10">
                            <Border Style="{StaticResource CardStyle}" Padding="14" Margin="0,0,0,10">
                                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <TextBlock Text="MILITAR E SOLDO" Style="{StaticResource SectionTitleStyle}"/>
                                    <Grid Grid.Row="1" Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="1*"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Militar" Style="{StaticResource CaptionTextStyle}"/><ComboBox x:Name="MilitaryBox" IsEditable="True" IsTextSearchEnabled="True" DisplayMemberPath="DisplayName" SelectionChanged="MilitaryBox_SelectionChanged"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="Posto/Graduação" Style="{StaticResource CaptionTextStyle}"/><ComboBox x:Name="RankBox" IsEditable="True" SelectionChanged="RankBox_SelectionChanged"/></StackPanel></Grid>
                                    <Grid Grid.Row="2" Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="10"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="1*"/></Grid.ColumnDefinitions><CheckBox x:Name="ManualSalaryBox" Content="Usar soldo manual" VerticalAlignment="Center" Checked="InputChanged" Unchecked="InputChanged"/><StackPanel Grid.Column="2"><TextBlock Text="Soldo manual" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="ManualSalaryText" TextChanged="InputChanged"/></StackPanel><StackPanel Grid.Column="4"><TextBlock Text="Soldo utilizado" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="SalaryUsedText" IsReadOnly="True" FontWeight="SemiBold"/></StackPanel></Grid>
                                </Grid>
                            </Border>

                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Border Style="{StaticResource CardStyle}" Padding="14"><StackPanel><TextBlock Text="RECEITAS" Style="{StaticResource SectionTitleStyle}"/>
                                    <Grid Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Text="Adic. Habilitação (%)"/><TextBox x:Name="QualificationText" Grid.Column="1" TextChanged="InputChanged"/></Grid>
                                    <Grid Margin="0,7,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Text="Adicional Militar (%)"/><TextBox x:Name="MilitaryAdditionalText" Grid.Column="1" TextChanged="InputChanged"/></Grid>
                                    <Grid Margin="0,7,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Text="Ad C Disp Mil (%)"/><TextBox x:Name="AvailabilityText" Grid.Column="1" TextChanged="InputChanged"/></Grid>
                                    <Grid Margin="0,7,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Text="Adic. Permanência (%)"/><TextBox x:Name="PermanenceText" Grid.Column="1" TextChanged="InputChanged"/></Grid>
                                    <Grid Margin="0,7,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Text="Pré-Escolar (R$)"/><TextBox x:Name="PreSchoolText" Grid.Column="1" TextChanged="InputChanged"/></Grid>
                                    <Grid Margin="0,7,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Text="Salário-Família (R$)"/><TextBox x:Name="FamilySalaryText" Grid.Column="1" TextChanged="InputChanged"/></Grid>
                                </StackPanel></Border>

                                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="14"><StackPanel><TextBlock Text="DESCONTOS OBRIGATÓRIOS" Style="{StaticResource SectionTitleStyle}"/>
                                    <Grid Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Text="FUSEX (%) — vencimentos"/><TextBox x:Name="FusexText" Grid.Column="1" TextChanged="InputChanged"/></Grid>
                                    <Grid Margin="0,7,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Text="Pensão Mil. 10,5% (%)"/><TextBox x:Name="Pension105Text" Grid.Column="1" TextChanged="InputChanged"/></Grid>
                                    <Grid Margin="0,7,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Text="Pensão Mil. 1,5% (%)"/><TextBox x:Name="Pension15Text" Grid.Column="1" TextChanged="InputChanged"/></Grid>
                                    <Grid Margin="0,7,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Text="Desc. Dep. FUSEX (R$)"/><TextBox x:Name="FusexDependentText" Grid.Column="1" TextChanged="InputChanged"/></Grid>
                                    <Grid Margin="0,7,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Text="Desp. Méd. FUSEX (R$)"/><TextBox x:Name="FusexMedicalText" Grid.Column="1" TextChanged="InputChanged"/></Grid>
                                    <Grid Margin="0,7,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Text="PNR (%) — soldo"/><TextBox x:Name="PnrText" Grid.Column="1" TextChanged="InputChanged"/></Grid>
                                    <Grid Margin="0,7,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Text="Pensão judicial existente"/><TextBox x:Name="ExistingAlimonyText" Grid.Column="1" TextChanged="InputChanged"/></Grid>
                                    <Grid Margin="0,7,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Text="Outra pensão judicial"/><TextBox x:Name="OtherAlimonyText" Grid.Column="1" TextChanged="InputChanged"/></Grid>
                                </StackPanel></Border>
                            </Grid>

                            <Border Style="{StaticResource CardStyle}" Padding="14" Margin="0,10,0,0"><StackPanel><TextBlock Text="IMPOSTO DE RENDA" Style="{StaticResource SectionTitleStyle}"/>
                                <WrapPanel Margin="0,10,0,0"><RadioButton x:Name="AutomaticIrBox" Content="IRRF automático — tabela mensal 2026" GroupName="IR" Checked="InputChanged" Margin="0,0,20,0"/><RadioButton x:Name="ManualIrBox" Content="IRRF manual" GroupName="IR" Checked="InputChanged"/></WrapPanel>
                                <Grid Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Dependentes IR" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="DependentsText" TextChanged="InputChanged"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="IR manual" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="ManualIrText" TextChanged="InputChanged"/></StackPanel><StackPanel Grid.Column="4"><TextBlock Text="Base IR calculada" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="IrBaseText" IsReadOnly="True"/></StackPanel></Grid>
                                <WrapPanel Margin="0,10,0,0"><CheckBox x:Name="DeductMedicalBox" Content="Deduzir despesa médica FUSEX" Checked="InputChanged" Unchecked="InputChanged" Margin="0,0,16,6"/><CheckBox x:Name="DeductDependentFusexBox" Content="Deduzir dependente FUSEX" Checked="InputChanged" Unchecked="InputChanged" Margin="0,0,16,6"/><CheckBox x:Name="DeductAlimonyBox" Content="Deduzir pensão judicial" Checked="InputChanged" Unchecked="InputChanged" Margin="0,0,16,6"/><CheckBox x:Name="DeductPnrBox" Content="Deduzir PNR" Checked="InputChanged" Unchecked="InputChanged" Margin="0,0,16,6"/><CheckBox x:Name="IrReducerBox" Content="Aplicar redutor 2026" Checked="InputChanged" Unchecked="InputChanged" Margin="0,0,0,6"/></WrapPanel>
                            </StackPanel></Border>

                            <Border Style="{StaticResource CardStyle}" Padding="14" Margin="0,10,0,0"><StackPanel><TextBlock Text="PENSÃO JUDICIAL" Style="{StaticResource SectionTitleStyle}"/>
                                <WrapPanel Margin="0,10,0,0"><RadioButton x:Name="PercentagePensionBox" Content="Percentual" GroupName="PJ" Checked="InputChanged" Margin="0,0,20,0"/><RadioButton x:Name="FixedPensionBox" Content="Valor fixo" GroupName="PJ" Checked="InputChanged"/></WrapPanel>
                                <Grid Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Base" Style="{StaticResource CaptionTextStyle}"/><ComboBox x:Name="PensionBaseBox" SelectionChanged="InputChanged"><ComboBoxItem Content="BASE — Receita menos descontos" Tag="BASE"/><ComboBoxItem Content="RECEITA — Total de receitas" Tag="RECEITA"/><ComboBoxItem Content="SOLDO" Tag="SOLDO"/></ComboBox></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="Percentual (%)" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="PensionPercentText" TextChanged="InputChanged"/></StackPanel><StackPanel Grid.Column="4"><TextBlock Text="Valor fixo" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="FixedPensionText" TextChanged="InputChanged"/></StackPanel></Grid>
                            </StackPanel></Border>

                            <Border Style="{StaticResource CardStyle}" Padding="14" Margin="0,10,0,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="180"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock Text="RUBRICAS EXTRAS" Style="{StaticResource SectionTitleStyle}"/>
                                <DataGrid x:Name="ExtrasGrid" Grid.Row="1" Margin="0,10,0,0" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single" MouseDoubleClick="EditExtra_Click"><DataGrid.Columns><DataGridCheckBoxColumn Header="Inclui" Binding="{Binding IsIncluded}" Width="60"/><DataGridTextColumn Header="Tipo" Binding="{Binding TypeLabel}" Width="90"/><DataGridTextColumn Header="Descrição" Binding="{Binding Description}" Width="*"/><DataGridTextColumn Header="Valor" Binding="{Binding Value, StringFormat=N2}" Width="110"/><DataGridCheckBoxColumn Header="Tributa IR" Binding="{Binding IsTaxable}" Width="85"/></DataGrid.Columns></DataGrid>
                                <WrapPanel Grid.Row="2" Margin="0,10,0,0"><Button Content="Adicionar receita" Style="{StaticResource PrimaryButtonStyle}" Click="AddRevenue_Click" Margin="0,0,8,0"/><Button Content="Adicionar desconto" Style="{StaticResource SecondaryButtonStyle}" Click="AddDiscount_Click" Margin="0,0,8,0"/><Button Content="Editar" Style="{StaticResource GhostButtonStyle}" Click="EditExtra_Click" Margin="0,0,8,0"/><Button Content="Incluir/ignorar" Style="{StaticResource GhostButtonStyle}" Click="ToggleExtraIncluded_Click" Margin="0,0,8,0"/><Button Content="Tributável/não tributável" Style="{StaticResource GhostButtonStyle}" Click="ToggleExtraTaxable_Click" Margin="0,0,8,0"/><Button Content="Remover" Style="{StaticResource DangerButtonStyle}" Click="RemoveExtra_Click"/></WrapPanel>
                            </Grid></Border>
                        </StackPanel></ScrollViewer>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="14"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <TextBlock Text="RESUMO DO CÁLCULO" Style="{StaticResource SectionTitleStyle}"/>
                        <UniformGrid Grid.Row="1" Columns="2" Margin="0,12,0,0"><StackPanel Margin="0,0,8,8"><TextBlock Text="Receitas" Style="{StaticResource CaptionTextStyle}"/><TextBlock x:Name="EarningsResultText" FontSize="17" FontWeight="SemiBold"/></StackPanel><StackPanel Margin="8,0,0,8"><TextBlock Text="Descontos obrigatórios" Style="{StaticResource CaptionTextStyle}"/><TextBlock x:Name="DiscountsResultText" FontSize="17" FontWeight="SemiBold"/></StackPanel></UniformGrid>
                        <UniformGrid Grid.Row="2" Columns="2"><StackPanel Margin="0,0,8,8"><TextBlock Text="Base da pensão" Style="{StaticResource CaptionTextStyle}"/><TextBlock x:Name="PensionBaseResultText" FontSize="17" FontWeight="SemiBold"/></StackPanel><StackPanel Margin="8,0,0,8"><TextBlock Text="Pensão Judicial" Style="{StaticResource CaptionTextStyle}"/><TextBlock x:Name="PensionResultText" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/></StackPanel></UniformGrid>
                        <StackPanel Grid.Row="3" Margin="0,4,0,10"><TextBlock Text="Líquido após a pensão" Style="{StaticResource CaptionTextStyle}"/><TextBlock x:Name="NetResultText" FontSize="20" FontWeight="Bold"/></StackPanel>
                        <Border Grid.Row="4" Background="{DynamicResource InfoSoftBrush}" CornerRadius="8" Padding="10" Margin="0,0,0,10"><TextBlock Text="Estimativa administrativa: confira a decisão judicial, o contracheque real e a incidência tributária antes de implantar." TextWrapping="Wrap"/></Border>
                        <TextBox x:Name="CalculationDetailBox" Grid.Row="5" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"/>
                    </Grid></Border>
                </Grid>
            </TabItem>

            <TabItem Header="Boletim">
                <Grid Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="0.9*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="1.1*"/></Grid.ColumnDefinitions>
                    <Border Style="{StaticResource CardStyle}" Padding="14"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel><TextBlock Text="DADOS PARA O BOLETIM" Style="{StaticResource SectionTitleStyle}"/>
                        <Border Background="{DynamicResource InfoSoftBrush}" CornerRadius="10" Padding="10" Margin="0,10,0,2">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="OCR preparado para decisão/ofício: anexa o arquivo na carteira do militar, salva as chaves extraídas e permite puxar essas chaves para preencher os campos." TextWrapping="Wrap" VerticalAlignment="Center"/>
                                <WrapPanel Grid.Column="1" Margin="12,0,0,0">
                                    <Button Content="Anexar/OCR" Style="{StaticResource SecondaryButtonStyle}" Click="ImportPensionDocumentOcr_Click" Margin="0,0,8,0"/>
                                    <Button Content="Puxar OCR" Style="{StaticResource SecondaryButtonStyle}" Click="ApplyLatestPensionOcr_Click"/>
                                </WrapPanel>
                            </Grid>
                        </Border>
                        <TextBlock Text="Modalidade" Style="{StaticResource CaptionTextStyle}" Margin="0,10,0,0"/><ComboBox x:Name="BulletinModeBox" SelectionChanged="BulletinInputChanged"><ComboBoxItem Content="IMPLANTAÇÃO"/><ComboBoxItem Content="ATUALIZAÇÃO"/><ComboBoxItem Content="DESCONTO DE ATRASADOS"/><ComboBoxItem Content="EXCLUSÃO"/></ComboBox>
                        <TextBlock Text="Número do processo/decisão *" Style="{StaticResource CaptionTextStyle}" Margin="0,9,0,0"/><TextBox x:Name="ProcessNumberBox" TextChanged="BulletinInputChanged"/>
                        <TextBlock Text="Tipo e origem da decisão *" Style="{StaticResource CaptionTextStyle}" Margin="0,9,0,0"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions><ComboBox x:Name="DecisionTypeBox" IsEditable="True" SelectionChanged="BulletinInputChanged"><ComboBoxItem Content="Acórdão"/><ComboBoxItem Content="Liminar"/><ComboBoxItem Content="Sentença"/><ComboBoxItem Content="Transitado em Julgado"/><ComboBoxItem Content="Tutela Antecipada"/></ComboBox><TextBox x:Name="DecisionOriginBox" Grid.Column="2" ToolTip="Vara/órgão que prolatou a decisão" TextChanged="BulletinInputChanged"/></Grid>
                        <TextBlock Text="Data da decisão *" Style="{StaticResource CaptionTextStyle}" Margin="0,9,0,0"/><TextBox x:Name="DecisionDateBox" TextChanged="BulletinInputChanged"/>
                        <TextBlock Text="Resumo da decisão judicial *" Style="{StaticResource CaptionTextStyle}" Margin="0,9,0,0"/><TextBox x:Name="DecisionSummaryBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="58" MaxLength="250" TextChanged="BulletinInputChanged"/>
                        <TextBlock Text="Autor(a) da ação / CPF *" Style="{StaticResource CaptionTextStyle}" Margin="0,9,0,0"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions><TextBox x:Name="PlaintiffNameBox" TextChanged="BulletinInputChanged"/><TextBox x:Name="PlaintiffCpfBox" Grid.Column="2" TextChanged="BulletinInputChanged"/></Grid>
                        <TextBlock Text="Ofício de recebimento *" Style="{StaticResource CaptionTextStyle}" Margin="0,9,0,0"/><TextBox x:Name="ReceivingLetterBox" TextChanged="BulletinInputChanged"/>
                        <TextBlock Text="Localidade, tribunal e natureza da ação *" Style="{StaticResource CaptionTextStyle}" Margin="0,9,0,0"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition/></Grid.ColumnDefinitions><TextBox x:Name="DecisionLocalityBox" TextChanged="BulletinInputChanged"/><TextBox x:Name="CourtBox" Grid.Column="2" TextChanged="BulletinInputChanged"/><TextBox x:Name="ActionNatureBox" Grid.Column="4" TextChanged="BulletinInputChanged"/></Grid>
                        <TextBlock Text="Alimentado(a) / beneficiário(a) *" Style="{StaticResource CaptionTextStyle}" Margin="0,9,0,0"/><TextBox x:Name="BeneficiaryNameBox" TextChanged="BulletinInputChanged"/>
                        <TextBlock Text="CPF do alimentado(a) *" Style="{StaticResource CaptionTextStyle}" Margin="0,9,0,0"/><TextBox x:Name="BeneficiaryCpfBox" TextChanged="BulletinInputChanged"/>
                        <TextBlock Text="Detentor da guarda / CPF *" Style="{StaticResource CaptionTextStyle}" Margin="0,9,0,0"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions><TextBox x:Name="GuardianNameBox" TextChanged="BulletinInputChanged"/><TextBox x:Name="GuardianCpfBox" Grid.Column="2" TextChanged="BulletinInputChanged"/></Grid>
                        <TextBlock Text="Parentesco e tipo de pensão *" Style="{StaticResource CaptionTextStyle}" Margin="0,9,0,0"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions><TextBox x:Name="RelationshipBox" TextChanged="BulletinInputChanged"/><ComboBox x:Name="PensionTypeBox" Grid.Column="2" IsEditable="True" SelectionChanged="BulletinInputChanged"><ComboBoxItem Content="Pensão Judicial"/><ComboBoxItem Content="Pensão Extrajudicial"/></ComboBox></Grid>
                        <TextBlock Text="Regra de cálculo / valor judicial *" Style="{StaticResource CaptionTextStyle}" Margin="0,9,0,0"/><TextBox x:Name="CalculationRuleBox" TextChanged="BulletinInputChanged"/>
                        <TextBlock Text="Incidências: férias / natalino / compensação *" Style="{StaticResource CaptionTextStyle}" Margin="0,9,0,0"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition/></Grid.ColumnDefinitions><ComboBox x:Name="VacationIncidenceBox" IsEditable="True" SelectionChanged="BulletinInputChanged"><ComboBoxItem Content="Incide"/><ComboBoxItem Content="Não incide"/></ComboBox><ComboBox x:Name="ChristmasIncidenceBox" Grid.Column="2" IsEditable="True" SelectionChanged="BulletinInputChanged"><ComboBoxItem Content="Incide"/><ComboBoxItem Content="Não incide"/></ComboBox><ComboBox x:Name="CompensationIncidenceBox" Grid.Column="4" IsEditable="True" SelectionChanged="BulletinInputChanged"><ComboBoxItem Content="Incide"/><ComboBoxItem Content="Não incide"/></ComboBox></Grid>
                        <TextBlock Text="Pensões anteriores / base concorrente *" Style="{StaticResource CaptionTextStyle}" Margin="0,9,0,0"/><TextBox x:Name="PreviousPensionsBox" TextChanged="BulletinInputChanged"/>
                        <Grid Margin="0,9,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="0.4*"/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Banco *" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="BankCodeBox" TextChanged="BulletinInputChanged"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="Nome do banco *" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="BankNameBox" TextChanged="BulletinInputChanged"/></StackPanel></Grid>
                        <Grid Margin="0,9,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Agência *" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="AgencyBox" TextChanged="BulletinInputChanged"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="Conta *" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="AccountBox" TextChanged="BulletinInputChanged"/></StackPanel></Grid>
                        <TextBlock Text="Operação CAIXA, se houver" Style="{StaticResource CaptionTextStyle}" Margin="0,9,0,0"/><TextBox x:Name="BankOperationBox" TextChanged="BulletinInputChanged"/>
                        <TextBlock Text="Rubrica *" Style="{StaticResource CaptionTextStyle}" Margin="0,9,0,0"/><TextBox x:Name="RubricBox" TextChanged="BulletinInputChanged"/>
                        <TextBlock Text="Mês/Ano de referência" Style="{StaticResource CaptionTextStyle}" Margin="0,9,0,0"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions><TextBox x:Name="ReferenceMonthBox" ToolTip="Ex.: JUN" TextChanged="BulletinInputChanged"/><TextBox x:Name="ReferenceYearBox" Grid.Column="2" ToolTip="Ex.: 2026 ou 26" TextChanged="BulletinInputChanged"/></Grid>
                        <TextBlock Text="Valor total do desconto de atrasados" Style="{StaticResource CaptionTextStyle}" Margin="0,9,0,0"/><TextBox x:Name="ArrearsTotalValueBox" TextChanged="BulletinInputChanged"/>
                        <TextBlock Text="Exclusão: motivo, justificativa e data de encerramento" Style="{StaticResource CaptionTextStyle}" Margin="0,9,0,0"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition/></Grid.ColumnDefinitions><ComboBox x:Name="ExclusionReasonBox" IsEditable="True" SelectionChanged="BulletinInputChanged"><ComboBoxItem Content="Ordem Judicial"/><ComboBoxItem Content="Óbito do Alimentado"/></ComboBox><TextBox x:Name="ExclusionJustificationBox" Grid.Column="2" MaxLength="250" TextChanged="BulletinInputChanged"/><TextBox x:Name="PensionEndDateBox" Grid.Column="4" ToolTip="Data de encerramento" TextChanged="BulletinInputChanged"/></Grid>
                        <TextBlock Text="Fundamento legal" Style="{StaticResource CaptionTextStyle}" Margin="0,9,0,0"/><TextBox x:Name="LegalBasisBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" TextChanged="BulletinInputChanged"/>
                        <TextBlock Text="Representação" Style="{StaticResource CaptionTextStyle}" Margin="0,9,0,0"/><TextBox x:Name="RepresentationBox" TextChanged="BulletinInputChanged"/>
                        <TextBlock Text="Observação" Style="{StaticResource CaptionTextStyle}" Margin="0,9,0,0"/><TextBox x:Name="BulletinObservationBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" TextChanged="BulletinInputChanged"/>
                    </StackPanel></ScrollViewer></Border>
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <TextBlock Text="TEXTO DO BOLETIM" Style="{StaticResource SectionTitleStyle}"/>
                            <Grid Grid.Row="1" Margin="0,10,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions><TextBlock Text="Assunto específico" VerticalAlignment="Center" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="BulletinSubjectBox" Grid.Column="2" TextChanged="BulletinInputChanged"/></Grid>
                            <RichTextBox x:Name="BulletinPreviewBox" Grid.Row="2" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Padding="12" FontFamily="Times New Roman" FontSize="13.333"/>
                            <WrapPanel Grid.Row="3" HorizontalAlignment="Right" Margin="0,10,0,0">
                                <CheckBox x:Name="IncludeConsequencesCheck" Content="Incluir consequência" IsChecked="True" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox x:Name="ConsequencesTextBox" Width="460" MinHeight="44" MaxHeight="86" Text="{x:Static services:SisbolTexts.JudicialPensionConsequencesText}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top" Padding="8,5" Margin="0,0,12,0" ToolTip="Texto editável enviado ao campo Texto de Fechamento do SisBol."/>
                                <Button Content="Gerar / atualizar boletim" Style="{StaticResource SecondaryButtonStyle}" Click="RefreshBulletin_Click" Margin="0,0,8,0"/>
                                <Button Content="Copiar" Style="{StaticResource SecondaryButtonStyle}" Click="CopyBulletin_Click" Margin="0,0,8,0"/>
                                <Button Content="Enviar ao SISBOL" Style="{StaticResource PrimaryButtonStyle}" Click="SendBulletinToSisbol_Click"/>
                            </WrapPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Histórico">
                <Border Style="{StaticResource CardStyle}" Padding="14" Margin="0,10,0,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock Text="CÁLCULOS SALVOS" Style="{StaticResource SectionTitleStyle}"/><DataGrid x:Name="HistoryGrid" Grid.Row="1" Margin="0,10,0,10" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"><DataGrid.Columns><DataGridTextColumn Header="Data" Binding="{Binding CreatedAt, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/><DataGridTextColumn Header="P/G" Binding="{Binding Rank}" Width="100"/><DataGridTextColumn Header="Militar" Binding="{Binding MilitaryName}" Width="*"/><DataGridTextColumn Header="Soldo" Binding="{Binding Salary, StringFormat=N2}" Width="120"/><DataGridTextColumn Header="Pensão" Binding="{Binding PensionValue, StringFormat=N2}" Width="130"/><DataGridTextColumn Header="%" Binding="{Binding PensionPercent, StringFormat=N2}" Width="80"/><DataGridTextColumn Header="Base" Binding="{Binding CalculationBase}" Width="150"/></DataGrid.Columns></DataGrid><Button Grid.Row="2" HorizontalAlignment="Right" Content="Atualizar histórico" Style="{StaticResource SecondaryButtonStyle}" Click="ReloadHistory_Click"/></Grid></Border>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0" Padding="16,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock x:Name="StatusText" VerticalAlignment="Center"/><ProgressBar x:Name="BusyBar" Grid.Column="1" Width="180" Height="5" IsIndeterminate="True" Visibility="Collapsed"/></Grid></Border>
    </Grid>
</Window>
