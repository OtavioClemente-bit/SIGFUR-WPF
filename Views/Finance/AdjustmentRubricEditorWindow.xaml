<Window x:Class="SIGFUR.Wpf.Views.Finance.AdjustmentRubricEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar rubrica" Width="720" Height="560" MinWidth="650" MinHeight="520"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Rubrica do Ajuste de Contas" Style="{StaticResource PageTitleStyle}"/>
            <TextBlock Text="Use o catálogo oficial do SIPPES ou edite manualmente. O tipo define como o valor será calculado." Style="{StaticResource PageSubtitleStyle}" Margin="0,4,0,14"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="18">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="190"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Código" VerticalAlignment="Center" Margin="0,0,12,12"/>
                <Grid Grid.Column="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox x:Name="CodeBox" TextChanged="CodeBox_TextChanged" LostFocus="CodeBox_LostFocus"/>
                    <Button Grid.Column="1" Content="Pesquisar SIPPES…" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" Click="SearchSippes_Click"/>
                </Grid>

                <TextBlock Grid.Row="1" Text="Descrição" VerticalAlignment="Center" Margin="0,0,12,12"/>
                <TextBox x:Name="DescriptionBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="2" Text="Efeito / sinal" VerticalAlignment="Center" Margin="0,0,12,12"/>
                <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="125"/></Grid.ColumnDefinitions>
                    <ComboBox x:Name="ReferenceBox" SelectionChanged="ReferenceBox_SelectionChanged">
                        <ComboBoxItem Content="R — Rendimento" Tag="R"/>
                        <ComboBoxItem Content="D — Desconto" Tag="D"/>
                    </ComboBox>
                    <ComboBox x:Name="SignBox" Grid.Column="2">
                        <ComboBoxItem Content="+ Crédito" Tag="+"/>
                        <ComboBoxItem Content="− Débito" Tag="-"/>
                    </ComboBox>
                </Grid>

                <TextBlock Grid.Row="3" Text="Base de proporcionalidade" VerticalAlignment="Center" Margin="0,0,12,12"/>
                <ComboBox x:Name="BaseBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,12">
                    <ComboBoxItem Content="DIA — proporcional aos dias servidos" Tag="DIA"/>
                    <ComboBoxItem Content="MÊS — proporcional aos meses de referência" Tag="MES"/>
                </ComboBox>

                <TextBlock Grid.Row="4" Text="Tipo de cálculo" VerticalAlignment="Center" Margin="0,0,12,12"/>
                <ComboBox x:Name="KindBox" Grid.Row="4" Grid.Column="1" Margin="0,0,0,12" SelectionChanged="KindBox_SelectionChanged">
                    <ComboBoxItem Content="Valor fixo (R$)" Tag="FIXO"/>
                    <ComboBoxItem Content="Percentual do soldo (%)" Tag="PERC_SOLDO"/>
                    <ComboBoxItem Content="Percentual dos vencimentos (%)" Tag="PERC_VENC"/>
                    <ComboBoxItem Content="Adicional de férias (1/3)" Tag="FORM_FER_PROP"/>
                    <ComboBoxItem Content="Indenização de férias" Tag="FORM_FER_NGOZ"/>
                    <ComboBoxItem Content="Adicional natalino total" Tag="FORM_NAT_TOTAL"/>
                    <ComboBoxItem Content="1ª parcela do natalino" Tag="FORM_NAT_1P"/>
                    <ComboBoxItem Content="Devolução da 1ª parcela" Tag="FORM_NAT_DESC1"/>
                </ComboBox>

                <TextBlock Grid.Row="5" Text="Valor / percentual" VerticalAlignment="Center" Margin="0,0,12,12"/>
                <TextBox x:Name="ValueBox" Grid.Row="5" Grid.Column="1" Margin="0,0,0,12"/>

                <CheckBox x:Name="IncludedCheck" Grid.Row="6" Grid.Column="1" Content="Incluir no cálculo" IsChecked="True"/>

                <Border Grid.Row="7" Grid.ColumnSpan="2" Background="{DynamicResource PrimarySurfaceBrush}" CornerRadius="8" Padding="12" Margin="0,14,0,0">
                    <TextBlock x:Name="OfficialInfoText" Text="Digite um código para consultar automaticamente o catálogo SIPPES." Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap"/>
                </Border>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancelar" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="Salvar rubrica" IsDefault="True" Style="{StaticResource PrimaryButtonStyle}" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
