<Window x:Class="SIGFUR.Wpf.Views.Tools.PrintQueueWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="SIGFUR — Fila de Impressão" Width="1080" Height="720" MinWidth="880" MinHeight="580" WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico" AllowDrop="True" DragOver="Window_DragOver" Drop="Window_Drop">
<Grid Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
<Border Style="{StaticResource CardStyle}" Padding="18" Margin="0,0,0,12"><StackPanel><TextBlock Text="FILA DE IMPRESSÃO EM LOTE" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryDarkBrush}"/><TextBlock Text="Organize a ordem, escolha a impressora e envie arquivos sem abrir um por um." Foreground="{DynamicResource MutedBrush}" Margin="0,4,0,0"/></StackPanel></Border>
<Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,0,12"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="90"/><ColumnDefinition Width="12"/><ColumnDefinition Width="110"/><ColumnDefinition Width="12"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Impressora" Style="{StaticResource CaptionTextStyle}"/><ComboBox x:Name="PrinterBox" IsEditable="True"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="Cópias" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="CopiesBox" Text="1" TextAlignment="Center"/></StackPanel><StackPanel Grid.Column="4"><TextBlock Text="Intervalo (s)" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="DelayBox" Text="1,2" TextAlignment="Center"/></StackPanel><Button Grid.Column="6" Content="Atualizar impressoras" VerticalAlignment="Bottom" Style="{StaticResource SecondaryButtonStyle}" Click="RefreshPrinters_Click"/></Grid></Border>
<Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0"><Grid><DataGrid x:Name="QueueGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" SelectionMode="Extended"><DataGrid.RowStyle><Style TargetType="DataGridRow"><Style.Triggers><DataTrigger Binding="{Binding Status}" Value="Enviado"><Setter Property="Background" Value="{DynamicResource SuccessSoftBrush}"/></DataTrigger><DataTrigger Binding="{Binding HasError}" Value="True"><Setter Property="Background" Value="{DynamicResource DangerSoftBrush}"/><Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/></DataTrigger></Style.Triggers></Style></DataGrid.RowStyle><DataGrid.Columns><DataGridTextColumn Header="#" Binding="{Binding Order}" Width="50"/><DataGridTextColumn Header="Arquivo" Binding="{Binding Name}" Width="*"/><DataGridTextColumn Header="Tipo" Binding="{Binding Extension}" Width="75"/><DataGridTextColumn Header="Tamanho" Binding="{Binding SizeText}" Width="100"/><DataGridTextColumn Header="Situação" Binding="{Binding Status}" Width="260"/></DataGrid.Columns></DataGrid><Border x:Name="DropHint" IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#DDF8FAFC" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="20,12"><TextBlock Text="Arraste arquivos ou uma pasta para esta área" Foreground="{DynamicResource MutedBrush}" FontWeight="SemiBold"/></Border></Grid></Border>
<Grid Grid.Row="3" Margin="0,12,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><WrapPanel><Button Content="＋ Adicionar arquivos" Style="{StaticResource PrimaryButtonStyle}" Click="AddFiles_Click" Margin="0,0,8,8"/><Button Content="Adicionar pasta" Style="{StaticResource SecondaryButtonStyle}" Click="AddFolder_Click" Margin="0,0,8,8"/><Button Content="↑" Style="{StaticResource SecondaryButtonStyle}" Click="MoveUp_Click" Margin="0,0,6,8"/><Button Content="↓" Style="{StaticResource SecondaryButtonStyle}" Click="MoveDown_Click" Margin="0,0,8,8"/><Button Content="Remover" Style="{StaticResource DangerButtonStyle}" Click="Remove_Click" Margin="0,0,8,8"/><Button Content="Marcar pendente" Style="{StaticResource SecondaryButtonStyle}" Click="MarkPending_Click" Margin="0,0,8,8"/><Button Content="Limpar" Style="{StaticResource GhostButtonStyle}" Click="Clear_Click" Margin="0,0,8,8"/><Button Content="Abrir local" Style="{StaticResource SecondaryButtonStyle}" Click="OpenLocation_Click" Margin="0,0,8,8"/></WrapPanel><StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top"><CheckBox x:Name="OnlySelectedBox" Content="Somente selecionados" VerticalAlignment="Center" Margin="0,0,12,8"/><Button Content="Parar após o atual" Style="{StaticResource SecondaryButtonStyle}" Click="Stop_Click" Margin="0,0,8,8"/><Button Content="Imprimir fila" Style="{StaticResource PrimaryButtonStyle}" Click="Print_Click" Margin="0,0,0,8"/></StackPanel></Grid>
<Border Grid.Row="4" Style="{StaticResource CardStyle}" Padding="11" Margin="0,2,0,0"><Grid><TextBlock x:Name="QueueStatusText" Text="Pronto. 0 arquivo(s) na fila."/><ProgressBar x:Name="QueueProgress" HorizontalAlignment="Right" Width="210" Height="7" Minimum="0" Maximum="1"/></Grid></Border>
</Grid></Window>
