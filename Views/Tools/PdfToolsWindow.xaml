<Window x:Class="SIGFUR.Wpf.Views.Tools.PdfToolsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIGFUR — Ferramentas PDF" Width="1160" Height="780" MinWidth="940" MinHeight="640"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico">
    <Grid Margin="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Style="{StaticResource CardStyle}" Padding="18" Margin="0,0,0,12">
            <Grid>
                <StackPanel>
                    <TextBlock Text="CENTRAL DE FERRAMENTAS PDF" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryDarkBrush}"/>
                    <TextBlock Text="Converter, comprimir, juntar, extrair, girar e proteger arquivos localmente — sem enviar documentos para sites externos." Foreground="{DynamicResource MutedBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                <Button Content="Revalidar recursos" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource SecondaryButtonStyle}" Click="Refresh_Click"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="1">
            <TabItem Header="Converter">
                <Grid Margin="16">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <StackPanel><TextBlock Text="ARQUIVOS PARA CONVERTER" Style="{StaticResource SectionTitleStyle}"/><TextBlock Text="Word, Excel, PowerPoint, ODT, texto, CSV, imagens e PDFs. Imagens são convertidas nativamente; documentos de escritório usam LibreOffice." Style="{StaticResource SubtleTextStyle}" Margin="0,4,0,0" TextWrapping="Wrap"/></StackPanel>
                    <ListBox x:Name="ConvertList" Grid.Row="1" Margin="0,12" SelectionMode="Extended"/>
                    <WrapPanel Grid.Row="2"><Button Content="＋ Adicionar arquivos" Style="{StaticResource PrimaryButtonStyle}" Click="AddConvert_Click" Margin="0,0,8,0"/><Button Content="Remover selecionados" Style="{StaticResource SecondaryButtonStyle}" Click="RemoveConvert_Click" Margin="0,0,8,0"/><Button Content="Limpar lista" Style="{StaticResource GhostButtonStyle}" Click="ClearConvert_Click"/></WrapPanel>
                    <Grid Grid.Row="3" Margin="0,14,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Pasta de saída" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="ConvertOutputBox"/></StackPanel><WrapPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="10,0,0,0"><Button Content="Escolher pasta" Style="{StaticResource SecondaryButtonStyle}" Click="ChooseConvertOutput_Click" Margin="0,0,8,0"/><Button Content="Converter para PDF" Style="{StaticResource PrimaryButtonStyle}" Click="Convert_Click"/></WrapPanel></Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Comprimir">
                <Grid Margin="16"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="230"/></Grid.ColumnDefinitions>
                    <StackPanel><TextBlock Text="COMPACTAR PDF" Style="{StaticResource SectionTitleStyle}"/><TextBlock Text="O original não é sobrescrito. A compactação usa Ghostscript e informa claramente quando o recurso não está instalado." Style="{StaticResource SubtleTextStyle}" Margin="0,4,0,16" TextWrapping="Wrap"/><TextBlock Text="PDF de entrada" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="CompressInputBox" Margin="0,0,0,10"/><TextBlock Text="PDF de saída" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="CompressOutputBox" Margin="0,0,0,10"/><TextBlock Text="Qualidade" Style="{StaticResource CaptionTextStyle}"/><ComboBox x:Name="QualityBox" SelectedIndex="1"><ComboBoxItem Content="Máxima compressão" Tag="/screen"/><ComboBoxItem Content="Equilibrado" Tag="/ebook"/><ComboBoxItem Content="Alta qualidade" Tag="/printer"/><ComboBoxItem Content="Pré-impressão" Tag="/prepress"/></ComboBox></StackPanel>
                    <StackPanel Grid.Column="2"><Button Content="Escolher entrada" Style="{StaticResource SecondaryButtonStyle}" Click="ChooseCompressInput_Click" Margin="0,48,0,8"/><Button Content="Escolher saída" Style="{StaticResource SecondaryButtonStyle}" Click="ChooseCompressOutput_Click" Margin="0,0,0,18"/><Button Content="Comprimir PDF" Style="{StaticResource PrimaryButtonStyle}" Click="Compress_Click"/></StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Juntar">
                <Grid Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <StackPanel><TextBlock Text="JUNTAR PDFs NA ORDEM DA LISTA" Style="{StaticResource SectionTitleStyle}"/><TextBlock Text="Selecione os arquivos e organize a sequência antes de gerar o PDF único." Style="{StaticResource SubtleTextStyle}" Margin="0,4,0,0"/></StackPanel>
                    <ListBox x:Name="MergeList" Grid.Row="1" Margin="0,12" SelectionMode="Extended"/>
                    <WrapPanel Grid.Row="2"><Button Content="＋ Adicionar PDFs" Style="{StaticResource PrimaryButtonStyle}" Click="AddMerge_Click" Margin="0,0,8,0"/><Button Content="↑" Style="{StaticResource SecondaryButtonStyle}" Click="MergeUp_Click" Margin="0,0,6,0"/><Button Content="↓" Style="{StaticResource SecondaryButtonStyle}" Click="MergeDown_Click" Margin="0,0,8,0"/><Button Content="Remover" Style="{StaticResource SecondaryButtonStyle}" Click="RemoveMerge_Click" Margin="0,0,8,0"/><Button Content="Limpar" Style="{StaticResource GhostButtonStyle}" Click="ClearMerge_Click"/></WrapPanel>
                    <Grid Grid.Row="3" Margin="0,14,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="PDF de saída" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="MergeOutputBox"/></StackPanel><WrapPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="10,0,0,0"><Button Content="Escolher saída" Style="{StaticResource SecondaryButtonStyle}" Click="ChooseMergeOutput_Click" Margin="0,0,8,0"/><Button Content="Juntar PDFs" Style="{StaticResource PrimaryButtonStyle}" Click="Merge_Click"/></WrapPanel></Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Extrair / girar">
                <Grid Margin="16"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Style="{StaticResource SoftCardStyle}" Padding="16"><StackPanel><TextBlock Text="EXTRAIR PÁGINAS" Style="{StaticResource SectionTitleStyle}"/><TextBlock Text="Use 1,3-5,8. O novo PDF terá somente as páginas informadas." Style="{StaticResource SubtleTextStyle}" Margin="0,4,0,14"/><TextBlock Text="PDF de entrada" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="ExtractInputBox"/><Button Content="Escolher entrada" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Left" Click="ChooseExtractInput_Click" Margin="0,8,0,12"/><TextBlock Text="Páginas" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="ExtractPagesBox" Text="1"/><TextBlock Text="PDF de saída" Style="{StaticResource CaptionTextStyle}" Margin="0,10,0,0"/><TextBox x:Name="ExtractOutputBox"/><Button Content="Extrair páginas" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" Click="Extract_Click" Margin="0,14,0,0"/></StackPanel></Border>
                    <Border Grid.Column="2" Style="{StaticResource SoftCardStyle}" Padding="16"><StackPanel><TextBlock Text="GIRAR PÁGINAS" Style="{StaticResource SectionTitleStyle}"/><TextBlock Text="Deixe páginas em branco para girar o documento inteiro." Style="{StaticResource SubtleTextStyle}" Margin="0,4,0,14"/><TextBlock Text="PDF de entrada" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="RotateInputBox"/><Button Content="Escolher entrada" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Left" Click="ChooseRotateInput_Click" Margin="0,8,0,12"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Páginas" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="RotatePagesBox" ToolTip="Ex.: 1,3-5. Vazio = todas"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="Ângulo" Style="{StaticResource CaptionTextStyle}"/><ComboBox x:Name="RotateAngleBox" SelectedIndex="0"><ComboBoxItem Content="90°" Tag="90"/><ComboBoxItem Content="180°" Tag="180"/><ComboBoxItem Content="270°" Tag="270"/></ComboBox></StackPanel></Grid><TextBlock Text="PDF de saída" Style="{StaticResource CaptionTextStyle}" Margin="0,10,0,0"/><TextBox x:Name="RotateOutputBox"/><Button Content="Girar páginas" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" Click="Rotate_Click" Margin="0,14,0,0"/></StackPanel></Border>
                </Grid>
            </TabItem>

            <TabItem Header="Proteger">
                <Grid Margin="16"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="330"/></Grid.ColumnDefinitions>
                    <StackPanel><TextBlock Text="PROTEGER PDF COM SENHA" Style="{StaticResource SectionTitleStyle}"/><TextBlock Text="Gera uma nova cópia criptografada em AES-256. O arquivo original permanece intacto." Style="{StaticResource SubtleTextStyle}" Margin="0,4,0,16" TextWrapping="Wrap"/><TextBlock Text="PDF de entrada" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="EncryptInputBox"/><TextBlock Text="PDF protegido de saída" Style="{StaticResource CaptionTextStyle}" Margin="0,10,0,0"/><TextBox x:Name="EncryptOutputBox"/></StackPanel>
                    <Border Grid.Column="2" Style="{StaticResource SoftCardStyle}" Padding="16"><StackPanel><TextBlock Text="Senha de abertura" Style="{StaticResource CaptionTextStyle}"/><PasswordBox x:Name="EncryptPasswordBox" Margin="0,4,0,10"/><TextBlock Text="Confirmar senha" Style="{StaticResource CaptionTextStyle}"/><PasswordBox x:Name="EncryptConfirmBox" Margin="0,4,0,14"/><Button Content="Escolher entrada" Style="{StaticResource SecondaryButtonStyle}" Click="ChooseEncryptInput_Click" Margin="0,0,0,8"/><Button Content="Proteger PDF" Style="{StaticResource PrimaryButtonStyle}" Click="Encrypt_Click"/></StackPanel></Border>
                </Grid>
            </TabItem>

            <TabItem Header="Recursos">
                <Grid Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="RECURSOS LOCAIS DETECTADOS" Style="{StaticResource SectionTitleStyle}"/><DataGrid x:Name="ResourceGrid" Grid.Row="1" Margin="0,12,0,0" IsReadOnly="True" AutoGenerateColumns="False"><DataGrid.Columns><DataGridTextColumn Header="Recurso" Binding="{Binding Name}" Width="220"/><DataGridTextColumn Header="Situação" Binding="{Binding Status}" Width="120"/><DataGridTextColumn Header="Detalhe" Binding="{Binding Detail}" Width="*"/></DataGrid.Columns></DataGrid></Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="12" Margin="0,12,0,0"><Grid><TextBlock x:Name="StatusText" Text="Pronto." VerticalAlignment="Center"/><StackPanel HorizontalAlignment="Right" Orientation="Horizontal"><Button x:Name="OpenResultButton" Content="Abrir resultado" Style="{StaticResource SecondaryButtonStyle}" Click="OpenResult_Click" IsEnabled="False" Margin="0,0,10,0"/><ProgressBar x:Name="BusyBar" Width="180" Height="6" IsIndeterminate="True" Visibility="Collapsed" VerticalAlignment="Center"/></StackPanel></Grid></Border>
    </Grid>
</Window>
