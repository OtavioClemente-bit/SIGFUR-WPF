<Window x:Class="SIGFUR.Wpf.Views.Personnel.AbsenceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SIGFUR.Wpf.Controls"
        Title="Faltas e Atrasos" Width="1420" Height="840" MinWidth="1040" MinHeight="650" WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="18"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Grid Margin="0,0,0,14"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel><TextBlock Text="FALTAS &amp; ATRASOS" Style="{StaticResource PageTitleStyle}"/><TextBlock Text="Histórico disciplinar administrativo com filtros, justificativas, providências e relatórios." Style="{StaticResource PageSubtitleStyle}"/></StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <ComboBox x:Name="QuickMilitaryBox" Width="310" IsEditable="True" IsTextSearchEnabled="True" DisplayMemberPath="DisplayName" Margin="0,0,8,0" ToolTip="Pesquise o nome e lance a ocorrência diretamente"/>
                <Button Content="Lançar para selecionado" Style="{StaticResource PrimaryButtonStyle}" Click="QuickAdd_Click" Margin="0,0,8,0"/>
                <Button Content="Nova ocorrência" Style="{StaticResource SecondaryButtonStyle}" Click="Add_Click" Margin="0,0,8,0"/>
                <Button Content="Editar" Style="{StaticResource SecondaryButtonStyle}" Click="Edit_Click" Margin="0,0,8,0"/>
                <Button Content="Excluir" Style="{StaticResource DangerButtonStyle}" Click="Delete_Click"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1" Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="120"/><ColumnDefinition Width="10"/><ColumnDefinition Width="92"/><ColumnDefinition Width="10"/><ColumnDefinition Width="150"/><ColumnDefinition Width="10"/><ColumnDefinition Width="160"/></Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox" TextChanged="Filter_Changed" ToolTip="Pesquisar militar, motivo, providência ou observação"/>
            <ComboBox x:Name="MonthBox" Grid.Column="2" SelectionChanged="Filter_Changed"/>
            <ComboBox x:Name="YearBox" Grid.Column="4" SelectionChanged="Filter_Changed"/>
            <ComboBox x:Name="TypeFilterBox" Grid.Column="6" SelectionChanged="Filter_Changed"><ComboBoxItem Content="Todos"/><ComboBoxItem Content="ATRASO"/><ComboBoxItem Content="FALTA"/></ComboBox>
            <ComboBox x:Name="MilitaryFilterBox" Grid.Column="8" DisplayMemberPath="DisplayName" SelectionChanged="Filter_Changed"/>
        </Grid>
        <Grid Grid.Row="2"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="12"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <UniformGrid Columns="5">
                <Border Style="{StaticResource CardStyle}" Padding="14" Margin="0,0,8,0"><StackPanel><TextBlock Text="TOTAL" Style="{StaticResource CaptionTextStyle}"/><TextBlock x:Name="TotalText" Text="0" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource PrimaryDarkBrush}"/></StackPanel></Border>
                <Border Style="{StaticResource CardStyle}" Padding="14" Margin="0,0,8,0"><StackPanel><TextBlock Text="FALTAS" Style="{StaticResource CaptionTextStyle}"/><TextBlock x:Name="AbsencesText" Text="0" FontSize="26" FontWeight="Bold" Foreground="#B91C1C"/></StackPanel></Border>
                <Border Style="{StaticResource CardStyle}" Padding="14" Margin="0,0,8,0"><StackPanel><TextBlock Text="ATRASOS" Style="{StaticResource CaptionTextStyle}"/><TextBlock x:Name="DelaysText" Text="0" FontSize="26" FontWeight="Bold" Foreground="#D97706"/></StackPanel></Border>
                <Border Style="{StaticResource CardStyle}" Padding="14" Margin="0,0,8,0"><StackPanel><TextBlock Text="NÃO JUSTIFICADAS" Style="{StaticResource CaptionTextStyle}"/><TextBlock x:Name="UnjustifiedText" Text="0" FontSize="26" FontWeight="Bold" Foreground="#9F1239"/></StackPanel></Border>
                <Border Style="{StaticResource CardStyle}" Padding="14"><StackPanel><TextBlock Text="MINUTOS DE ATRASO" Style="{StaticResource CaptionTextStyle}"/><TextBlock x:Name="MinutesText" Text="0" FontSize="26" FontWeight="Bold" Foreground="#0F766E"/></StackPanel></Border>
            </UniformGrid>
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
                <DataGrid x:Name="OccurrenceGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" MouseDoubleClick="OccurrenceGrid_MouseDoubleClick">
                    <DataGrid.ContextMenu><ContextMenu><MenuItem Header="Editar ocorrência" Click="Edit_Click"/><MenuItem Header="Excluir ocorrência" Click="Delete_Click"/><Separator/><MenuItem Header="Copiar resumo" Click="CopySummary_Click"/></ContextMenu></DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Data" Binding="{Binding DateText}" Width="88"/>
                        <DataGridTextColumn Header="Hora" Binding="{Binding Time}" Width="62"/>
                        <DataGridTextColumn Header="P/G" Binding="{Binding ShortRank}" Width="74"/>
                        <DataGridTemplateColumn Header="Nome completo" Width="1.4*"><DataGridTemplateColumn.CellTemplate><DataTemplate><controls:HighlightedNameTextBlock FullName="{Binding Name}" WarName="{Binding WarName}" TextWrapping="Wrap"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                        <DataGridTextColumn Header="Tipo" Binding="{Binding Type}" Width="82"/>
                        <DataGridTextColumn Header="Duração" Binding="{Binding DurationText}" Width="78"/>
                        <DataGridTextColumn Header="Situação" Binding="{Binding JustifiedText}" Width="115"/>
                        <DataGridTextColumn Header="Motivo" Binding="{Binding Reason}" Width="1.1*"/>
                        <DataGridTextColumn Header="Providência" Binding="{Binding Measure}" Width="1.1*"/>
                        <DataGridTextColumn Header="Observações" Binding="{Binding Notes}" Width="1.1*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
        <Grid Grid.Row="3" Margin="0,12,0,0"><TextBlock x:Name="StatusText" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/><WrapPanel HorizontalAlignment="Right"><Button Content="Salvar fechamento" Style="{StaticResource GhostButtonStyle}" Click="SaveClosure_Click" Margin="0,0,8,0"/><Button Content="Exportar CSV" Style="{StaticResource SecondaryButtonStyle}" Click="ExportCsv_Click" Margin="0,0,8,0"/><Button Content="Gerar PDF" Style="{StaticResource PrimaryButtonStyle}" Click="ExportPdf_Click" Margin="0,0,8,0"/><Button Content="Gerar relatório HTML" Style="{StaticResource GhostButtonStyle}" Click="ExportHtml_Click" Margin="0,0,8,0"/><Button Content="Fechar" Style="{StaticResource GhostButtonStyle}" Click="Close_Click"/></WrapPanel></Grid>
    </Grid>
</Window>
