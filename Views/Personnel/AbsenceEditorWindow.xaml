<Window x:Class="SIGFUR.Wpf.Views.Personnel.AbsenceEditorWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ocorrência" Width="700" Height="740" MinWidth="580" MinHeight="580" WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="20"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel Margin="0,0,0,14"><TextBlock x:Name="TitleText" Text="Registrar ocorrência" Style="{StaticResource PageTitleStyle}"/><TextBlock Text="Falta ou atraso com histórico, justificativa e providência adotada." Style="{StaticResource PageSubtitleStyle}"/></StackPanel>
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="18"><ScrollViewer VerticalScrollBarVisibility="Auto"><Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="145"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
            <TextBlock Text="Pesquisar militar" VerticalAlignment="Center" Margin="0,0,10,10"/><TextBox x:Name="MilitarySearchBox" Grid.Column="1" Margin="0,0,0,10" TextChanged="MilitarySearchBox_TextChanged" ToolTip="Digite nome, nome de guerra, CPF ou posto"/>
            <TextBlock Grid.Row="1" Text="Militar" VerticalAlignment="Center" Margin="0,0,10,10"/><ComboBox x:Name="MilitaryBox" Grid.Row="1" Grid.Column="1" IsTextSearchEnabled="True" DisplayMemberPath="DisplayName" Margin="0,0,0,10"/>
            <TextBlock Grid.Row="2" Text="Data" VerticalAlignment="Center" Margin="0,0,10,10"/><DatePicker x:Name="DateBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,10"/>
            <TextBlock Grid.Row="3" Text="Hora" VerticalAlignment="Center" Margin="0,0,10,10"/><TextBox x:Name="TimeBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,10" ToolTip="HH:mm"/>
            <TextBlock Grid.Row="4" Text="Tipo" VerticalAlignment="Center" Margin="0,0,10,10"/><ComboBox x:Name="TypeBox" Grid.Row="4" Grid.Column="1" Margin="0,0,0,10"><ComboBoxItem Content="ATRASO"/><ComboBoxItem Content="FALTA"/></ComboBox>
            <TextBlock Grid.Row="5" Text="Minutos de atraso" VerticalAlignment="Center" Margin="0,0,10,10"/><TextBox x:Name="MinutesBox" Grid.Row="5" Grid.Column="1" Margin="0,0,0,10"/>
            <TextBlock Grid.Row="6" Text="Situação" VerticalAlignment="Center" Margin="0,0,10,10"/><CheckBox x:Name="JustifiedCheck" Grid.Row="6" Grid.Column="1" Content="Ocorrência justificada" Margin="0,2,0,10"/>
            <TextBlock Grid.Row="7" Text="Motivo" VerticalAlignment="Top" Margin="0,5,10,10"/><TextBox x:Name="ReasonBox" Grid.Row="7" Grid.Column="1" Height="80" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,10"/>
            <TextBlock Grid.Row="8" Text="Providência" VerticalAlignment="Top" Margin="0,5,10,10"/><TextBox x:Name="MeasureBox" Grid.Row="8" Grid.Column="1" Height="80" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,10"/>
            <TextBlock Grid.Row="9" Text="Observações" VerticalAlignment="Top" Margin="0,5,10,0"/><TextBox x:Name="NotesBox" Grid.Row="9" Grid.Column="1" Height="90" AcceptsReturn="True" TextWrapping="Wrap"/>
        </Grid></ScrollViewer></Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0"><Button Content="Cancelar" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/><Button Content="Salvar ocorrência" IsDefault="True" Style="{StaticResource PrimaryButtonStyle}" Click="Save_Click"/></StackPanel>
    </Grid>
</Window>
