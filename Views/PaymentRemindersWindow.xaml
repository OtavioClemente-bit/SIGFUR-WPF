<Window x:Class="SIGFUR.Wpf.Views.PaymentRemindersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Controle de Pagamentos" Width="1180" Height="740" MinWidth="920" MinHeight="570"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico">
    <Grid Margin="18">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Style="{StaticResource CardStyle}" Padding="18" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="CENTRAL DE CONTROLE DE PAGAMENTOS" FontSize="21" FontWeight="Bold" Foreground="{DynamicResource PrimaryDarkBrush}"/>
                    <TextBlock Text="Marque como OK depois de conferir. O SIGFUR registra data e hora para auditoria, sem rotular o controle como atrasado." Foreground="{DynamicResource MutedBrush}" Margin="0,5,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                <Border Grid.Column="1" Background="{DynamicResource PrimarySoftBrush}" CornerRadius="10" Padding="12,7" VerticalAlignment="Center"><TextBlock x:Name="CountText" Foreground="{DynamicResource PrimaryDarkBrush}" FontWeight="Bold"/></Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="190"/><ColumnDefinition Width="12"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" ToolTip="Pesquisar descrição, categoria, competência ou observação" TextChanged="Filter_Changed"/>
                <ComboBox x:Name="StatusFilterBox" Grid.Column="2" SelectionChanged="Filter_Changed"><ComboBoxItem Content="Todos"/><ComboBoxItem Content="A fazer"/><ComboBoxItem Content="OK / concluídos"/><ComboBoxItem Content="Permanentes"/></ComboBox>
                <Button Grid.Column="4" Content="Criar controles de Férias e AT" Style="{StaticResource SecondaryButtonStyle}" Click="CreateEssential_Click"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="2" x:Name="ControlTabs">
            <TabItem Header="Controles e lembretes">
                <Border Style="{StaticResource CardStyle}" Padding="0" Margin="8">
                    <DataGrid x:Name="ReminderGrid" Margin="0" IsReadOnly="True" AutoGenerateColumns="False" SelectionMode="Single" MouseDoubleClick="ReminderGrid_MouseDoubleClick">
                        <DataGrid.RowStyle><Style TargetType="DataGridRow"><Setter Property="ToolTip" Value="Duplo clique para editar"/><Style.Triggers><DataTrigger Binding="{Binding IsCompleted}" Value="True"><Setter Property="Opacity" Value="0.72"/><Setter Property="Background" Value="{DynamicResource SuccessSoftBrush}"/></DataTrigger></Style.Triggers></Style></DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Categoria" Binding="{Binding Category}" Width="145"/>
                            <DataGridTextColumn Header="O que conferir/pagar" Binding="{Binding Description}" Width="1.5*"/>
                            <DataGridTextColumn Header="Competência" Binding="{Binding Competence}" Width="155"/>
                            <DataGridTextColumn Header="Data de referência" Binding="{Binding Deadline}" Width="120"/>
                            <DataGridTextColumn Header="Observação" Binding="{Binding Observation}" Width="*"/>
                            <DataGridTextColumn Header="Controle" Binding="{Binding PermanentLabel}" Width="105"/>
                            <DataGridTextColumn Header="Situação" Binding="{Binding StatusLabel}" Width="105"/>
                            <DataGridTextColumn Header="Registrado em" Binding="{Binding CompletedAtLabel}" Width="145"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <TabItem Header="Férias — pagamento">
                <Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Border Style="{StaticResource CardStyle}" Padding="14" Margin="0,0,0,10">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left"><TextBlock Text="CONFERÊNCIA DE PAGAMENTO DAS FÉRIAS" FontWeight="Bold" Foreground="{DynamicResource PrimaryDarkBrush}"/><TextBlock Text="Mostra o plano do ano atual. Ao marcar como pago, a data fica salva no Plano de Férias e na carteira do militar." Foreground="{DynamicResource MutedBrush}" Margin="0,4,0,0"/></StackPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Atualizar" Style="{StaticResource SecondaryButtonStyle}" Click="RefreshOperational_Click" Margin="0,0,8,0"/><Button Content="✓ Marcar pago" Style="{StaticResource PrimaryButtonStyle}" Click="MarkVacationPaid_Click" Margin="0,0,8,0"/><Button Content="Reabrir pagamento" Style="{StaticResource SecondaryButtonStyle}" Click="ReopenVacationPaid_Click"/></StackPanel>
                        </DockPanel>
                    </Border>
                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
                        <DataGrid x:Name="VacationGrid" IsReadOnly="True" AutoGenerateColumns="False" SelectionMode="Extended">
                            <DataGrid.RowStyle><Style TargetType="DataGridRow"><Style.Triggers><DataTrigger Binding="{Binding IsPaid}" Value="False"><Setter Property="Background" Value="{DynamicResource WarningSoftBrush}"/><Setter Property="FontWeight" Value="SemiBold"/></DataTrigger><DataTrigger Binding="{Binding IsPaid}" Value="True"><Setter Property="Background" Value="{DynamicResource SuccessSoftBrush}"/></DataTrigger></Style.Triggers></Style></DataGrid.RowStyle>
                            <DataGrid.Columns><DataGridTextColumn Header="P/G" Binding="{Binding Rank}" Width="85"/><DataGridTextColumn Header="Militar" Binding="{Binding Name}" Width="*"/><DataGridTextColumn Header="Período" Binding="{Binding Period}" Width="210"/><DataGridTextColumn Header="Dias" Binding="{Binding Days}" Width="70"/><DataGridTextColumn Header="Situação" Binding="{Binding Status}" Width="115"/><DataGridTextColumn Header="Registrado em" Binding="{Binding PaidAtText}" Width="155"/></DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Auxílio-Transporte — conferir">
                <Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Border Style="{StaticResource CardStyle}" Padding="14" Margin="0,0,0,10">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left"><TextBlock Text="MILITARES MARCADOS COMO NÃO RECEBENDO AT" FontWeight="Bold" Foreground="{DynamicResource PrimaryDarkBrush}"/><TextBlock Text="Lista de conferência: use-a para identificar quem precisa de implantação ou pagamento. A lista não altera o cadastro automaticamente." Foreground="{DynamicResource MutedBrush}" Margin="0,4,0,0"/></StackPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Atualizar" Style="{StaticResource SecondaryButtonStyle}" Click="RefreshOperational_Click" Margin="0,0,8,0"/><Button Content="Criar controle do selecionado" Style="{StaticResource PrimaryButtonStyle}" Click="CreateTransportReminder_Click" Margin="0,0,8,0"/><Button Content="Abrir carteira" Style="{StaticResource SecondaryButtonStyle}" Click="OpenTransportWallet_Click"/></StackPanel>
                        </DockPanel>
                    </Border>
                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
                        <DataGrid x:Name="TransportGrid" IsReadOnly="True" AutoGenerateColumns="False" SelectionMode="Single">
                            <DataGrid.Columns><DataGridTextColumn Header="P/G" Binding="{Binding Rank}" Width="85"/><DataGridTextColumn Header="Militar" Binding="{Binding Name}" Width="*"/><DataGridTextColumn Header="Situação no cadastro" Binding="{Binding Status}" Width="150"/><DataGridTextColumn Header="Valor" Binding="{Binding Value}" Width="100"/><DataGridTextColumn Header="Telefone" Binding="{Binding Phone}" Width="135"/><DataGridTextColumn Header="Endereço para conferir" Binding="{Binding Address}" Width="1.4*"/></DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="3" Margin="0,14,0,0">
            <WrapPanel>
                <Button Content="＋ Novo controle" Style="{StaticResource PrimaryButtonStyle}" Click="New_Click" Margin="0,0,8,8"/>
                <Button Content="Editar" Style="{StaticResource SecondaryButtonStyle}" Click="Edit_Click" Margin="0,0,8,8"/>
                <Button Content="✓ Marcar OK" Style="{StaticResource PrimaryButtonStyle}" Click="Complete_Click" Margin="0,0,8,8"/>
                <Button Content="Reabrir" Style="{StaticResource SecondaryButtonStyle}" Click="Reopen_Click" Margin="0,0,8,8"/>
                <Button Content="Remover" Style="{StaticResource DangerButtonStyle}" Click="Delete_Click" Margin="0,0,16,8"/>
                <Button Content="Copiar resumo" Style="{StaticResource SecondaryButtonStyle}" Click="Copy_Click" Margin="0,0,8,8"/>
            </WrapPanel>
            <Button Content="Fechar" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Top"/>
        </Grid>
    </Grid>
</Window>
