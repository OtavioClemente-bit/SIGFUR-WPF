<Window x:Class="SIGFUR.Wpf.Views.Reminders.ReminderUrgentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lembretes urgentes" Width="820" Height="560" MinWidth="650" MinHeight="420"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico" ShowInTaskbar="False">
    <Grid Margin="18"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Background="{DynamicResource WarningSoftBrush}" CornerRadius="12" Padding="18" Margin="0,0,0,12"><StackPanel><TextBlock Text="ATENÇÃO — LEMBRETES URGENTES" Foreground="{DynamicResource WarningBrush}" FontWeight="Bold" FontSize="18"/><TextBlock x:Name="SummaryText" Margin="0,5,0,0" TextWrapping="Wrap"/></StackPanel></Border>
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="4"><DataGrid x:Name="UrgentGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"><DataGrid.Columns><DataGridTextColumn Header="Título" Binding="{Binding Title}" Width="*"/><DataGridTextColumn Header="Data" Binding="{Binding FormattedDate}" Width="105"/><DataGridTextColumn Header="Prazo" Binding="{Binding DaysText}" Width="145"/><DataGridTextColumn Header="Prioridade" Binding="{Binding EffectivePriority}" Width="120"/></DataGrid.Columns></DataGrid></Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0"><Button Content="Depois" Style="{StaticResource SecondaryButtonStyle}" IsCancel="True" Margin="0,0,8,0"/><Button Content="Abrir lembretes" Style="{StaticResource PrimaryButtonStyle}" Click="Open_Click"/></StackPanel>
    </Grid>
</Window>
