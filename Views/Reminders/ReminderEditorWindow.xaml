<Window x:Class="SIGFUR.Wpf.Views.Reminders.ReminderEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lembrete" Width="720" Height="680" MinWidth="620" MinHeight="560"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico"
        PreviewKeyDown="Window_PreviewKeyDown" Tag="UiState.BoundsOnly">
    <Grid Margin="18"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Style="{StaticResource CardStyle}" Padding="18" Margin="0,0,0,12">
            <StackPanel><TextBlock x:Name="TitleText" Text="NOVO LEMBRETE" Style="{StaticResource SectionTitleStyle}" FontSize="18"/><TextBlock Text="Defina o prazo, a prioridade e a recorrência. O Dashboard será atualizado automaticamente." Style="{StaticResource CaptionTextStyle}" Margin="0,5,0,0"/></StackPanel>
        </Border>
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="18"><ScrollViewer VerticalScrollBarVisibility="Auto"><Grid>
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/></Grid.ColumnDefinitions>
            <StackPanel Grid.ColumnSpan="3"><TextBlock Text="Título" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="ReminderTitleBox" FontSize="15"/></StackPanel>
            <StackPanel Grid.Row="1" Margin="0,14,0,0"><TextBlock Text="Data" Style="{StaticResource CaptionTextStyle}"/><DatePicker x:Name="DueDatePicker" SelectedDateFormat="Short"/><CheckBox x:Name="NoDateBox" Content="Lembrete sem data" Margin="0,8,0,0" Checked="NoDateBox_Changed" Unchecked="NoDateBox_Changed"/></StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,14,0,0"><TextBlock Text="Prioridade manual" Style="{StaticResource CaptionTextStyle}"/><ComboBox x:Name="PriorityBox"/></StackPanel>
            <StackPanel Grid.Row="2" Margin="0,14,0,0"><TextBlock Text="Recorrência" Style="{StaticResource CaptionTextStyle}"/><ComboBox x:Name="RecurrenceBox"/></StackPanel>
            <Border Grid.Row="2" Grid.Column="2" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="10" Padding="12" Margin="0,14,0,0"><CheckBox x:Name="AutoRescheduleBox" Content="Reagendar automaticamente ao concluir" IsChecked="True" VerticalAlignment="Center"/></Border>
            <CheckBox Grid.Row="3" Grid.ColumnSpan="3" x:Name="CompletedBox" Content="Marcar como concluído" Margin="0,14,0,0"/>
            <TextBlock Grid.Row="4" Grid.ColumnSpan="3" Text="Descrição / observações" Style="{StaticResource CaptionTextStyle}" Margin="0,14,0,4"/>
            <TextBox Grid.Row="5" Grid.ColumnSpan="3" x:Name="BodyBox" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="210"/>
        </Grid></ScrollViewer></Border>
        <Grid Grid.Row="2" Margin="0,14,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock x:Name="ValidationText" Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal"><Button Content="Cancelar" Style="{StaticResource SecondaryButtonStyle}" IsCancel="True" Margin="0,0,8,0"/><Button Content="Salvar lembrete" Style="{StaticResource PrimaryButtonStyle}" Click="Save_Click"/></StackPanel>
        </Grid>
    </Grid>
</Window>
