<Window x:Class="SIGFUR.Wpf.Views.Reminders.ReminderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIGFUR — Lembretes" Width="1380" Height="820" MinWidth="980" MinHeight="650"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico"
        Loaded="Window_Loaded" PreviewKeyDown="Window_PreviewKeyDown">
    <Grid><Grid.RowDefinitions><RowDefinition Height="70"/><RowDefinition Height="*"/><RowDefinition Height="36"/></Grid.RowDefinitions>
        <Border Background="{DynamicResource PrimaryDarkBrush}" Padding="20,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center"><TextBlock Text="LEMBRETES" Foreground="White" FontWeight="Bold" FontSize="19"/><TextBlock Text="Prazos, prioridades, recorrências e histórico operacional" Foreground="{DynamicResource TextOnPrimaryMutedBrush}"/></StackPanel>
            <Button Grid.Column="1" Content="Novo lembrete" Style="{StaticResource LightOnDarkButtonStyle}" Click="New_Click" VerticalAlignment="Center"/>
        </Grid></Border>

        <Grid Grid.Row="1" Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <UniformGrid Columns="5" Margin="0,0,0,12">
                <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,6,0"><StackPanel><TextBlock Text="ATRASADOS" Style="{StaticResource MetricCaptionStyle}"/><TextBlock x:Name="OverdueText" Text="0" Foreground="{DynamicResource DangerBrush}" Style="{StaticResource MetricValueStyle}"/></StackPanel></Border>
                <Border Style="{StaticResource MetricCardStyle}" Margin="6,0"><StackPanel><TextBlock Text="HOJE" Style="{StaticResource MetricCaptionStyle}"/><TextBlock x:Name="TodayText" Text="0" Foreground="{DynamicResource WarningBrush}" Style="{StaticResource MetricValueStyle}"/></StackPanel></Border>
                <Border Style="{StaticResource MetricCardStyle}" Margin="6,0"><StackPanel><TextBlock Text="PRÓXIMOS" Style="{StaticResource MetricCaptionStyle}"/><TextBlock x:Name="UpcomingText" Text="0" Foreground="{DynamicResource InfoBrush}" Style="{StaticResource MetricValueStyle}"/></StackPanel></Border>
                <Border Style="{StaticResource MetricCardStyle}" Margin="6,0"><StackPanel><TextBlock Text="SEM DATA" Style="{StaticResource MetricCaptionStyle}"/><TextBlock x:Name="NoDateText" Text="0" Style="{StaticResource MetricValueStyle}"/></StackPanel></Border>
                <Border Style="{StaticResource SoftMetricCardStyle}" Margin="6,0,0,0"><StackPanel><TextBlock Text="CONCLUÍDOS" Style="{StaticResource MetricCaptionStyle}"/><TextBlock x:Name="CompletedText" Text="0" Foreground="{DynamicResource SuccessBrush}" Style="{StaticResource MetricValueStyle}"/></StackPanel></Border>
            </UniformGrid>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="14" Margin="0,0,0,12"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="12"/><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel><TextBlock Text="Buscar" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="SearchBox" TextChanged="Filter_Changed" ToolTip="Título, descrição, prioridade, recorrência ou data"/></StackPanel>
                <StackPanel Grid.Column="2"><TextBlock Text="Ordenação" Style="{StaticResource CaptionTextStyle}"/><ComboBox x:Name="OrderBox" SelectionChanged="Filter_Changed"><ComboBoxItem Content="Data (mais próximo)"/><ComboBoxItem Content="Data (mais distante)"/><ComboBoxItem Content="Título (A→Z)"/><ComboBoxItem Content="Status"/><ComboBoxItem Content="Prioridade"/></ComboBox></StackPanel>
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <StackPanel Margin="0,0,14,0"><TextBlock Text="Próximos (dias)" Style="{StaticResource CaptionTextStyle}"/><TextBox x:Name="UpcomingDaysBox" Width="60" Text="2" TextChanged="Filter_Changed" TextAlignment="Center"/></StackPanel>
                    <StackPanel VerticalAlignment="Center"><CheckBox x:Name="ShowCompletedBox" Content="Mostrar concluídos" IsChecked="True" Checked="Filter_Changed" Unchecked="Filter_Changed"/><CheckBox x:Name="GroupBox" Content="Agrupar por prioridade" IsChecked="True" Margin="0,6,0,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/><CheckBox x:Name="AutoPriorityBox" Content="Classificação automática" IsChecked="True" Margin="0,6,0,0" Checked="AutoPriority_Changed" Unchecked="AutoPriority_Changed"/></StackPanel>
                </StackPanel>
            </Grid></Border>

            <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition Width="310"/></Grid.ColumnDefinitions>
                <Border Style="{StaticResource CardStyle}" Padding="4"><DataGrid x:Name="ReminderGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="ReminderGrid_SelectionChanged" MouseDoubleClick="ReminderGrid_MouseDoubleClick" Sorting="ReminderGrid_Sorting">
                    <DataGrid.ContextMenu><ContextMenu><MenuItem Header="Editar" Click="Edit_Click"/><MenuItem Header="Marcar / desmarcar concluído" Click="Toggle_Click"/><Separator/><MenuItem Header="Excluir" Click="Delete_Click"/></ContextMenu></DataGrid.ContextMenu>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="ToolTip" Value="{Binding Body}"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="Atrasado">
                                    <Setter Property="Background" Value="#FFFFD2D2"/>
                                    <Setter Property="BorderBrush" Value="#FFB71C1C"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Hoje">
                                    <Setter Property="Background" Value="#FFFFE6A6"/>
                                    <Setter Property="BorderBrush" Value="#FFB36B00"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Pendente">
                                    <Setter Property="Background" Value="#FFE1F0FF"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Concluído">
                                    <Setter Property="Background" Value="#FFD9F4DD"/>
                                    <Setter Property="Opacity" Value="0.85"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Título" Binding="{Binding Title}" Width="*" MinWidth="230" SortMemberPath="Title"/>
                        <DataGridTextColumn Header="Data" Binding="{Binding FormattedDate}" Width="105" SortMemberPath="DueDate"/>
                        <DataGridTextColumn Header="Prazo" Binding="{Binding DaysText}" Width="135" SortMemberPath="DaysRemaining"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="105" SortMemberPath="Status"/>
                        <DataGridTextColumn Header="Prioridade" Binding="{Binding Priority}" Width="120" SortMemberPath="EffectivePriority"/>
                        <DataGridTextColumn Header="Recorrência" Binding="{Binding Recurrence}" Width="115" SortMemberPath="Recurrence"/>
                        <DataGridTextColumn Header="Concluído" Binding="{Binding CompletionText}" Width="90" SortMemberPath="Completed"/>
                    </DataGrid.Columns>
                </DataGrid></Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="16"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBlock Text="Lembrete selecionado" Style="{StaticResource SectionTitleStyle}"/>
                    <StackPanel Grid.Row="1" Margin="0,12,0,12"><TextBlock x:Name="SelectedTitleText" Text="Nenhum lembrete selecionado" FontSize="17" FontWeight="SemiBold" TextWrapping="Wrap"/><TextBlock x:Name="SelectedInfoText" Style="{StaticResource CaptionTextStyle}" Margin="0,7,0,0" TextWrapping="Wrap"/></StackPanel>
                    <Border Grid.Row="2" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="10" Padding="12"><ScrollViewer VerticalScrollBarVisibility="Auto"><TextBlock x:Name="SelectedBodyText" Text="Selecione um item para ver a descrição." TextWrapping="Wrap" LineHeight="22"/></ScrollViewer></Border>
                    <StackPanel Grid.Row="3" Margin="0,14,0,0"><Button Content="Editar" Style="{StaticResource PrimaryButtonStyle}" Click="Edit_Click" Margin="0,0,0,7"/><Button Content="Marcar / desmarcar concluído" Style="{StaticResource SidebarActionButtonStyle}" Click="Toggle_Click"/><Button Content="Arquivar concluídos" Style="{StaticResource SidebarActionButtonStyle}" Click="Archive_Click"/><Button Content="Histórico" Style="{StaticResource SidebarActionButtonStyle}" Click="History_Click"/><Button Content="Exportar lembretes" Style="{StaticResource SidebarActionButtonStyle}" Click="Export_Click"/><Button Content="Excluir" Style="{StaticResource DangerButtonStyle}" Click="Delete_Click" Margin="0,8,0,0"/></StackPanel>
                </Grid></Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0" Padding="16,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock x:Name="StatusText" VerticalAlignment="Center"/><TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{DynamicResource SubtleTextBrush}" Text="Ctrl+N novo  •  Ctrl+F pesquisar  •  Enter editar  •  Espaço concluir  •  Delete excluir"/></Grid></Border>
    </Grid>
</Window>
