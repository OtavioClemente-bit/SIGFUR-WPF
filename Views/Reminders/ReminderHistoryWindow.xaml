<Window x:Class="SIGFUR.Wpf.Views.Reminders.ReminderHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Histórico de Lembretes" Width="1000" Height="650" MinWidth="760" MinHeight="480"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico">
    <Grid Margin="18"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Style="{StaticResource CardStyle}" Padding="18" Margin="0,0,0,12"><StackPanel><TextBlock Text="HISTÓRICO DE LEMBRETES" Style="{StaticResource SectionTitleStyle}" FontSize="18"/><TextBlock Text="Itens arquivados podem ser restaurados, exportados ou excluídos definitivamente." Style="{StaticResource CaptionTextStyle}" Margin="0,5,0,0"/></StackPanel></Border>
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="4"><DataGrid x:Name="HistoryGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns><DataGridTextColumn Header="Título" Binding="{Binding Title}" Width="*"/><DataGridTextColumn Header="Data" Binding="{Binding FormattedDate}" Width="110"/><DataGridTextColumn Header="Prioridade" Binding="{Binding EffectivePriority}" Width="130"/><DataGridTextColumn Header="Recorrência" Binding="{Binding Recurrence}" Width="120"/><DataGridTextColumn Header="Arquivado em" Binding="{Binding ArchivedAt}" Width="155"/></DataGrid.Columns>
        </DataGrid></Border>
        <Grid Grid.Row="2" Margin="0,14,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock x:Name="StatusText" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal"><Button Content="Exportar histórico" Style="{StaticResource SecondaryButtonStyle}" Click="Export_Click" Margin="0,0,8,0"/><Button Content="Excluir definitivamente" Style="{StaticResource DangerButtonStyle}" Click="Delete_Click" Margin="0,0,8,0"/><Button Content="Restaurar" Style="{StaticResource PrimaryButtonStyle}" Click="Restore_Click"/></StackPanel>
        </Grid>
    </Grid>
</Window>
