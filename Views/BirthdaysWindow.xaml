<Window x:Class="SIGFUR.Wpf.Views.BirthdaysWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SIGFUR.Wpf.Controls"
        Title="Aniversariantes do Mês" Width="900" Height="620" MinWidth="760" MinHeight="520" WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Grid><StackPanel><TextBlock Text="Aniversariantes do Mês" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryDarkBrush}"/><TextBlock x:Name="SummaryText" Foreground="{DynamicResource MutedBrush}" Margin="0,4,0,14"/></StackPanel><Button Content="Gerar e conferir boletim" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Right" Click="GenerateBulletin_Click"/></Grid>
        <DataGrid x:Name="BirthdayGrid" Grid.Row="1" IsReadOnly="False" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Conferido" Binding="{Binding Confirmed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="82"/>
                <DataGridTextColumn Header="Dia" Binding="{Binding Day}" IsReadOnly="True" Width="55"/>
                <DataGridTextColumn Header="P/G" Binding="{Binding Rank}" IsReadOnly="True" Width="95"/>
                <DataGridTemplateColumn Header="Nome completo" Width="*" IsReadOnly="True"><DataGridTemplateColumn.CellTemplate><DataTemplate><controls:HighlightedNameTextBlock FullName="{Binding Name}" WarName="{Binding WarName}" TextWrapping="Wrap"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                <DataGridTextColumn Header="Idade" Binding="{Binding Age}" IsReadOnly="True" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0"><Button Content="Copiar lista" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" Click="CopyList_Click"/><Button Content="Salvar conferência" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Click="Save_Click"/><Button Content="Fechar" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}"/></StackPanel>
    </Grid>
</Window>
