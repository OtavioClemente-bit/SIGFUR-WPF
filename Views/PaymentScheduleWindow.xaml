<Window x:Class="SIGFUR.Wpf.Views.PaymentScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Corrida de Pagamento" Width="760" Height="555" MinWidth="720" MinHeight="520"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico"
        Tag="UiState.BoundsOnly">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}" Padding="18" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="💸 Corrida de Pagamento" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryDarkBrush}"/>
                    <TextBlock Text="Configure a referência do pagamento. A 1ª corrida é lançada pela data informada pelo órgão pagador; a 2ª corrida é sempre calculada pelo SIGFUR como o 3º dia útil do mês do pagamento." Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,18,0"/>
                </StackPanel>
                <Border Grid.Column="1" Background="{DynamicResource PrimarySoftBrush}" CornerRadius="14" Padding="14,9" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="REFERÊNCIA" Foreground="{DynamicResource PrimaryDarkBrush}" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="ReferenceText" Text="Pagamento" Foreground="{DynamicResource PrimaryDarkBrush}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Pagamento" VerticalAlignment="Center" Margin="0,0,12,18" FontWeight="SemiBold"/>
                <Grid Grid.Column="1" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="MonthBox" SelectionChanged="Competence_Changed" ToolTip="Mês de referência do pagamento"/>
                    <TextBox x:Name="YearBox" Grid.Column="2" TextChanged="Competence_Changed" ToolTip="Ano do pagamento"/>
                </Grid>

                <StackPanel Grid.Row="1" Margin="0,0,12,18">
                    <TextBlock Text="1ª corrida" FontWeight="SemiBold"/>
                    <TextBlock Text="data manual" Foreground="{DynamicResource MutedBrush}" FontSize="11"/>
                </StackPanel>
                <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <DatePicker x:Name="FirstDatePicker" SelectedDateFormat="Short" SelectedDateChanged="FirstDatePicker_SelectedDateChanged"/>
                    <TextBlock x:Name="FirstRunHintText" Grid.Column="2" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap"/>
                </Grid>

                <StackPanel Grid.Row="2" Margin="0,0,12,18">
                    <TextBlock Text="2ª corrida" FontWeight="SemiBold"/>
                    <TextBlock Text="automática" Foreground="{DynamicResource MutedBrush}" FontSize="11"/>
                </StackPanel>
                <Border Grid.Row="2" Grid.Column="1" Background="{DynamicResource SuccessSoftBrush}" CornerRadius="12" Padding="13,10" Margin="0,0,0,18">
                    <DockPanel>
                        <TextBlock Text="3º dia útil" DockPanel.Dock="Right" Foreground="{DynamicResource SuccessBrush}" FontWeight="SemiBold" Margin="12,0,0,0"/>
                        <TextBlock x:Name="AutoSecondRunText" Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold" TextWrapping="Wrap"/>
                    </DockPanel>
                </Border>

                <Border Grid.Row="3" Grid.ColumnSpan="2" Background="{DynamicResource PrimarySurfaceBrush}" CornerRadius="14" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Informe para o Dashboard" Foreground="{DynamicResource PrimaryDarkBrush}" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="SummaryText" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancelar" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="Salvar corrida" IsDefault="True" Style="{StaticResource PrimaryButtonStyle}" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
