<Window x:Class="SIGFUR.Wpf.Views.NumberToWordsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIGFUR — Valor por extenso" Width="780" Height="570" MinWidth="680" MinHeight="510"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="104"/><RowDefinition Height="*"/><RowDefinition Height="72"/></Grid.RowDefinitions>

        <Border Background="{DynamicResource PrimaryGradientBrush}" Padding="26,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="VALOR POR EXTENSO" Foreground="White" FontSize="23" FontWeight="Bold"/>
                    <TextBlock Text="Conversão segura em português do Brasil para documentos, boletins e conferências." Foreground="#DCEBFF" Margin="0,6,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Width="58" Height="58" CornerRadius="16" Background="#22FFFFFF" VerticalAlignment="Center">
                    <TextBlock Text="123" Foreground="White" FontSize="19" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="22">
                <Border Style="{StaticResource CardStyle}" Padding="18">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="210"/></Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,14,0">
                            <TextBlock Text="Valor ou número" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,6"/>
                            <TextBox x:Name="InputBox" FontSize="22" MinHeight="48" VerticalContentAlignment="Center"
                                     ToolTip="Ex.: 1.234,56" TextChanged="InputBox_TextChanged"/>
                            <TextBlock Text="Aceita 1234,56 · 1.234,56 · R$ 1.234,56" Foreground="{DynamicResource SubtleTextBrush}" FontSize="10" Margin="2,6,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Tipo de conversão" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,6"/>
                            <ComboBox x:Name="ModeBox" SelectedIndex="0" SelectionChanged="ModeBox_SelectionChanged" MinHeight="48" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="Valor em reais" Tag="currency"/>
                                <ComboBoxItem Content="Número comum" Tag="number"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}" Padding="18" Margin="0,14,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="RESULTADO" Foreground="{DynamicResource MutedBrush}" FontSize="10" FontWeight="SemiBold"/>
                                <TextBlock x:Name="NumericPreviewText" Text="Digite um valor para converter" Foreground="{DynamicResource PrimaryDarkBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" Background="{DynamicResource SuccessSoftBrush}" CornerRadius="12" Padding="10,4" VerticalAlignment="Center">
                                <TextBlock x:Name="ValidationText" Text="PRONTO" Foreground="{DynamicResource SuccessBrush}" FontSize="10" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                        <Border Background="{DynamicResource PrimarySurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16" MinHeight="180">
                            <TextBox x:Name="ResultBox" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                                     BorderThickness="0" Background="Transparent" FontSize="19"
                                     VerticalScrollBarVisibility="Auto"/>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,0">
            <Grid>
                <Button Content="Limpar" Style="{StaticResource GhostButtonStyle}" HorizontalAlignment="Left" Click="Clear_Click"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Copiar minúsculo" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" Click="CopyLower_Click"/>
                    <Button Content="Copiar MAIÚSCULO" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" Click="CopyUpper_Click"/>
                    <Button Content="Fechar" IsCancel="True" Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
