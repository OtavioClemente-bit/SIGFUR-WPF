<Window x:Class="SIGFUR.Wpf.Views.Furriel.FurrielBulletinWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SIGFUR.Wpf.Controls"
        Title="SIGFUR — Boletim Furriel"
        Width="1480" Height="860" MinWidth="1080" MinHeight="680"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico"
        Loaded="Window_Loaded" Closing="Window_Closing" PreviewKeyDown="Window_PreviewKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="54"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource PrimaryDarkBrush}" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Image Source="/Assets/sigfur.png" Width="32" Height="32" Stretch="Uniform" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="BOLETIM FURRIEL" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Importação, indexação, pesquisa de menções e controle dos PDFs assinados" FontSize="10" Foreground="#DCEBFF"/>
                </StackPanel>
                <Border Grid.Column="3" Background="#22FFFFFF" CornerRadius="8" Padding="10,5" VerticalAlignment="Center">
                    <TextBlock x:Name="HeaderStateText" Text="Índice pronto" Foreground="White" FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="15" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.2*" MinWidth="270"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="1.45*" MinWidth="190"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="1.65*" MinWidth="280"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Militar" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="MilitaryBox" IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                                  MaxDropDownHeight="320" SelectionChanged="MilitaryBox_SelectionChanged" KeyUp="SearchInput_KeyUp"
                                  ToolTip="Digite nome, nome de guerra, CPF, IDT ou Prec-CP para ver as sugestões">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="3,2">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Rank}" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                            <controls:HighlightedNameTextBlock FullName="{Binding FullName}" WarName="{Binding WarName}"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Source}" FontSize="9" Foreground="{DynamicResource SubtleTextBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Fonte dos nomes" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="PersonnelSourceBox" SelectionChanged="PersonnelSourceBox_SelectionChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Busca livre" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/>
                        <TextBox x:Name="FreeSearchBox" TextChanged="SearchInput_TextChanged" ToolTip="Assunto, trecho, CPF, IDT ou qualquer texto existente no PDF"/>
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Filtrar por" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="PeriodModeBox" SelectionChanged="PeriodModeBox_SelectionChanged">
                            <ComboBoxItem Content="Mês/Ano"/>
                            <ComboBoxItem Content="Intervalo de datas"/>
                        </ComboBox>
                    </StackPanel>

                    <Grid Grid.Column="8">
                        <Grid x:Name="MonthYearPanel">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="1.35*"/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="Mês" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><ComboBox x:Name="MonthBox" SelectionChanged="Filter_Changed"/></StackPanel>
                            <StackPanel Grid.Column="2"><TextBlock Text="Ano" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><ComboBox x:Name="YearBox" SelectionChanged="Filter_Changed"/></StackPanel>
                        </Grid>
                        <Grid x:Name="DateRangePanel" Visibility="Collapsed">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="Data inicial" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><DatePicker x:Name="StartDatePicker" SelectedDateChanged="Filter_Changed"/></StackPanel>
                            <StackPanel Grid.Column="2"><TextBlock Text="Data final" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/><DatePicker x:Name="EndDatePicker" SelectedDateChanged="Filter_Changed"/></StackPanel>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="1" Grid.ColumnSpan="9" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="22"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="SearchUnregisteredCheck" Content="Pesquisar o texto digitado quando não houver cadastro"
                                  IsChecked="True" Checked="SearchOption_Changed" Unchecked="SearchOption_Changed"/>
                        <CheckBox Grid.Column="2" x:Name="AutoUpdateCheckBox" Content="Monitoramento automático desativado"
                                  Visibility="Collapsed" IsEnabled="False"
                                  Checked="AutoUpdateCheckBox_Changed" Unchecked="AutoUpdateCheckBox_Changed"/>
                        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="18,0">
                            <TextBlock Text="Consequências:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="ConsequenceFilterBox" Width="245" SelectionChanged="Filter_Changed">
                                <ComboBoxItem Content="Todos" IsSelected="True"/>
                                <ComboBoxItem Content="Apenas com consequência"/>
                                <ComboBoxItem Content="Apenas Furriel/Secretaria/Pagamento"/>
                            </ComboBox>
                        </StackPanel>
                        <Button Grid.Column="4" Content="Pesquisar menções" Style="{StaticResource PrimaryButtonStyle}"
                                Click="SearchNow_Click" MinWidth="150" Padding="17,9"/>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                    <StackPanel><TextBlock Text="PDFs INDEXADOS" Style="{StaticResource MetricCaptionStyle}"/><TextBlock x:Name="IndexedCountText" Text="0" Style="{StaticResource MetricValueStyle}"/></StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}">
                    <StackPanel><TextBlock Text="PDFs ASSINADOS" Style="{StaticResource MetricCaptionStyle}"/><TextBlock x:Name="SignedCountText" Text="0" Style="{StaticResource MetricValueStyle}"/></StackPanel>
                </Border>
                <Border Grid.Column="4" Style="{StaticResource SoftMetricCardStyle}">
                    <StackPanel><TextBlock Text="PÁGINAS" Style="{StaticResource MetricCaptionStyle}"/><TextBlock x:Name="PagesCountText" Text="0" Style="{StaticResource MetricValueStyle}"/></StackPanel>
                </Border>
                <Border Grid.Column="6" Style="{StaticResource SoftMetricCardStyle}">
                    <StackPanel><TextBlock Text="RESULTADOS" Style="{StaticResource MetricCaptionStyle}"/><TextBlock x:Name="ResultsCountText" Text="0" Style="{StaticResource MetricValueStyle}"/></StackPanel>
                </Border>
                <Border Grid.Column="8" Style="{StaticResource CardStyle}" Padding="12">
                    <StackPanel>
                        <TextBlock Text="ÚLTIMA ATUALIZAÇÃO" Style="{StaticResource MetricCaptionStyle}"/>
                        <TextBlock x:Name="UpdatedAtText" Text="—" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,0,10">
                <WrapPanel>
                    <Button Content="Importar PDFs/ZIP" Style="{StaticResource PrimaryButtonStyle}" Click="ImportFiles_Click" Margin="0,0,8,8" MinWidth="132"/>
                    <Button Content="Baixar ADT SisBol" Style="{StaticResource ToolbarActionButtonStyle}" Click="DownloadSisbolFurriel_Click" MinWidth="120" ToolTip="Baixa automaticamente os Aditamentos do Furriel do ano selecionado usando a sessão já preparada do SisBol."/>
                    <Button Content="Índice SisBol" Style="{StaticResource ToolbarActionButtonStyle}" Click="OpenSisbolIndex_Click" MinWidth="105" ToolTip="Abre a consulta/importação do Índice Remissivo por Pessoa do SisBol."/>
                    <Button Content="Índice assunto" Style="{StaticResource ToolbarActionButtonStyle}" Click="ImportSubjectIndex_Click" MinWidth="118" ToolTip="Importa o Índice Remissivo por Assunto do Aditamento Furriel para corrigir assunto/nota oficialmente."/>
                    <Button Content="Salvar assinado" Style="{StaticResource ToolbarActionButtonStyle}" Click="ImportSigned_Click" MinWidth="112"/>
                    <Border Width="1" Height="25" Background="{DynamicResource BorderBrush}" Margin="3,4,11,8"/>
                    <Button Content="Abrir PDF" Style="{StaticResource ToolbarActionButtonStyle}" Click="OpenSelectedPdf_Click" MinWidth="95"/>
                    <Button Content="Abrir assinado" Style="{StaticResource ToolbarActionButtonStyle}" Click="OpenSelectedSigned_Click" MinWidth="108"/>
                    <Button Content="Usar como chave" Style="{StaticResource ToolbarActionButtonStyle}" Click="UseAsBulletinKey_Click" MinWidth="118" ToolTip="Cria [[ADT_REFERENCIA]], [[NUM_ADT]], [[DATA_ADT]] e as chaves compatíveis de BI"/>
                    <Button Content="Exportar resultados" Style="{StaticResource ToolbarActionButtonStyle}" Click="Export_Click" MinWidth="125"/>
                    <Border Width="1" Height="25" Background="{DynamicResource BorderBrush}" Margin="3,4,11,8"/>
                    <Button Content="Pasta PDFs" Style="{StaticResource ToolbarActionButtonStyle}" Click="OpenPdfFolder_Click" MinWidth="92"/>
                    <Button Content="Pasta assinados" Style="{StaticResource ToolbarActionButtonStyle}" Click="OpenSignedFolder_Click" MinWidth="108"/>
                    <Button Content="Remover" Style="{StaticResource ToolbarActionButtonStyle}" Click="RemoveSelected_Click" MinWidth="86"/>
                    <Button Content="Limpar base" Style="{StaticResource DangerButtonStyle}" Click="ClearBase_Click" Margin="0,0,0,8" MinWidth="92"/>
                </WrapPanel>
            </Border>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="430" MinWidth="350"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*" MinWidth="560"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="170"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Boletins importados" Style="{StaticResource SectionTitleStyle}"/>
                        <Grid Grid.Row="1" Margin="0,8,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBox x:Name="BulletinFilterBox" TextChanged="BulletinFilterBox_TextChanged" ToolTip="Número, data, BAR, mês, ano ou nome do arquivo"/>
                            <Button Grid.Column="2" Content="Limpar" Style="{StaticResource GhostButtonStyle}" Click="ClearBulletinFilter_Click"/>
                        </Grid>
                        <DataGrid x:Name="FilesGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                                  SelectionChanged="FilesGrid_SelectionChanged" MouseDoubleClick="FilesGrid_MouseDoubleClick">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Abrir PDF comum" Click="OpenSelectedPdf_Click"/>
                                    <MenuItem Header="Abrir PDF assinado" Click="OpenSelectedSigned_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Usar como chave do Boletim" Click="UseAsBulletinKey_Click"/>
                                    <MenuItem Header="Abrir pasta do arquivo" Click="OpenSelectedFolder_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Remover do índice" Click="RemoveSelected_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Boletim" Binding="{Binding DisplayBulletin}" Width="82"/>
                                <DataGridTextColumn Header="Data" Binding="{Binding DisplayDate}" Width="86"/>
                                <DataGridTextColumn Header="BAR" Binding="{Binding DisplayBar}" Width="48"/>
                                <DataGridTextColumn Header="Pág." Binding="{Binding Pages}" Width="48"/>
                                <DataGridTextColumn Header="Ass." Binding="{Binding SignedStatus}" Width="50"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBox x:Name="FileDetailBox" Grid.Row="3" Margin="0,10,0,0" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="190"/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Menções indexadas" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Cada linha mostra assunto/nota, militar, consequência, página e arquivo." Style="{StaticResource SubtleTextStyle}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" x:Name="VisibleBulletinsText" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}"/>
                        </Grid>
                        <DataGrid x:Name="ResultsGrid" Grid.Row="1" Margin="0,10,0,0" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                                  SelectionChanged="ResultsGrid_SelectionChanged" MouseDoubleClick="ResultsGrid_MouseDoubleClick">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Abrir PDF comum" Click="OpenSelectedPdf_Click"/>
                                    <MenuItem Header="Abrir PDF assinado" Click="OpenSelectedSigned_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Copiar trecho" Click="CopySelectedContext_Click"/>
                                    <MenuItem Header="Copiar referência" Click="CopySelectedReference_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Militar mencionado" Width="225">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <controls:HighlightedNameTextBlock FullName="{Binding Military}" WarName="{Binding WarName}" TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Tipo" Binding="{Binding Type}" Width="125"/>
                                <DataGridTextColumn Header="Aditamento" Binding="{Binding Bulletin}" Width="78"/>
                                <DataGridTextColumn Header="Data" Binding="{Binding Date}" Width="84"/>
                                <DataGridTextColumn Header="Pág." Binding="{Binding Page}" Width="48"/>
                                <DataGridTextColumn Header="Ass." Binding="{Binding Signed}" Width="48"/>
                                <DataGridTextColumn Header="Assunto/Nota" Binding="{Binding SubjectNoteDisplay}" Width="280"/>
                                <DataGridTextColumn Header="Consequência" Binding="{Binding ConsequenceDisplay}" Width="95"/>
                                <DataGridTextColumn Header="Arquivo" Binding="{Binding FileName}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBox x:Name="ResultDetailBox" Grid.Row="2" Margin="0,10,0,0" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="{DynamicResource PrimaryDarkBrush}" Padding="14,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Text="Pronto." Foreground="White" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1" Text="F5 atualizar índice  •  Esc limpar pesquisa  •  Delete remover PDF" Foreground="#DCEBFF" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid x:Name="BusyOverlay" Grid.RowSpan="3" Background="#99000000" Visibility="Collapsed">
            <Border Background="White" CornerRadius="12" Padding="24" Width="520" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock x:Name="BusyTitleText" Text="Processando boletins" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryDarkBrush}"/>
                    <TextBlock x:Name="BusyMessageText" Margin="0,8,0,14" Text="Aguarde..." TextWrapping="Wrap"/>
                    <ProgressBar Height="8" IsIndeterminate="True"/>
                    <TextBlock Margin="0,10,0,0" Text="A janela continuará respondendo enquanto o índice é atualizado." Style="{StaticResource SubtleTextStyle}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
