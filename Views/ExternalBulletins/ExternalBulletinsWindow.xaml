<Window x:Class="SIGFUR.Wpf.Views.ExternalBulletins.ExternalBulletinsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIGFUR — Boletins de Fora" Width="1510" Height="900" MinWidth="1160" MinHeight="720"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico"
        Loaded="Window_Loaded" Closing="Window_Closing" PreviewKeyDown="Window_PreviewKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="82"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource PrimaryGradientBrush}" Padding="22,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="BOLETINS DE FORA" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="4ª Região Militar e CML: biblioteca permanente, busca por OM/nome e abertura direta na menção." Foreground="#DCEBFF" Margin="0,4,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Background="#1EFFFFFF" CornerRadius="16" Padding="13,7" VerticalAlignment="Center">
                    <TextBlock x:Name="HeaderSearchBadge" Text="Pesquisa: 4ª Cia PE" Foreground="White" FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="16,14,16,10" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.8*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="190"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Nome ou OM pesquisada" Style="{StaticResource CaptionTextStyle}"/>
                    <TextBox x:Name="SearchTermBox" FontSize="15" FontWeight="SemiBold" VerticalContentAlignment="Center"
                             ToolTip="Ex.: 4ª Cia PE, 4ª RM, nome completo ou outro termo que exista nos PDFs"/>
                    <TextBlock Text="Ao trocar o termo, clique em ‘Pesquisar novamente’. A biblioteca salva os PDFs e não precisa importar tudo de novo." Foreground="{DynamicResource MutedBrush}" FontSize="10" Margin="0,5,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Pesquisar novamente" Style="{StaticResource PrimaryButtonStyle}" Click="ReindexAll_Click"
                        MinWidth="155" Height="38" Margin="12,18,0,0" VerticalAlignment="Top"/>

                <Border Grid.Column="3" Style="{StaticResource InsetCardStyle}" Padding="12,9">
                    <StackPanel><TextBlock Text="REGIÃO" Foreground="{DynamicResource MutedBrush}" FontSize="9" FontWeight="Bold"/><TextBlock x:Name="RegionSummaryText" Text="0 boletins" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryDarkBrush}"/><TextBlock Text="com menção após a 1ª Parte" FontSize="9" Foreground="{DynamicResource SubtleTextBrush}"/></StackPanel>
                </Border>
                <Border Grid.Column="5" Style="{StaticResource InsetCardStyle}" Padding="12,9">
                    <StackPanel><TextBlock Text="CML" Foreground="{DynamicResource MutedBrush}" FontSize="9" FontWeight="Bold"/><TextBlock x:Name="CmlSummaryText" Text="0 boletins" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryDarkBrush}"/><TextBlock Text="com autorização/liberação" FontSize="9" Foreground="{DynamicResource SubtleTextBrush}"/></StackPanel>
                </Border>
                <Border Grid.Column="7" Style="{StaticResource InsetCardStyle}" Padding="12,9">
                    <StackPanel><TextBlock Text="MENÇÕES" Foreground="{DynamicResource MutedBrush}" FontSize="9" FontWeight="Bold"/><TextBlock x:Name="MentionsSummaryText" Text="0 encontradas" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryDarkBrush}"/><TextBlock Text="na biblioteca externa" FontSize="9" Foreground="{DynamicResource SubtleTextBrush}"/></StackPanel>
                </Border>
            </Grid>
        </Border>

        <TabControl Grid.Row="2" Margin="16,0,16,12" x:Name="SourceTabs">
            <TabItem Header="Boletim Regional — 4ª RM">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Border Background="{DynamicResource InfoSoftBrush}" BorderBrush="{DynamicResource InfoBrush}" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,0,10">
                        <TextBlock Text="Regra aplicada: a 1ª Parte — Serviços Diários é ignorada integralmente. A pesquisa começa somente na 2ª Parte/Instrução e segue para os assuntos administrativos e demais partes." Foreground="{DynamicResource PrimaryDarkBrush}" TextWrapping="Wrap"/>
                    </Border>
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <Button Content="Importar pasta Região" Style="{StaticResource PrimaryButtonStyle}" Click="ImportRegionFolder_Click" MinWidth="145"/>
                        <Button Grid.Column="1" Content="Adicionar PDFs" Style="{StaticResource SecondaryButtonStyle}" Click="ImportRegionFiles_Click" Margin="8,0,0,0" MinWidth="112"/>
                        <Button Grid.Column="2" Content="Abrir biblioteca" Style="{StaticResource GhostButtonStyle}" Click="OpenRegionFolder_Click" Margin="8,0,0,0" MinWidth="112"/>
                        <Button Grid.Column="3" Content="Remover selecionado" Style="{StaticResource DangerButtonStyle}" Click="RemoveRegion_Click" Margin="8,0,0,0" MinWidth="128"/>
                        <TextBox Grid.Column="5" x:Name="RegionFilterBox" TextChanged="RegionFilterBox_TextChanged" ToolTip="Filtrar por número, data, seção, resumo ou texto da menção"/>
                        <CheckBox Grid.Column="6" x:Name="ShowAllRegionCheck" Content="Mostrar também sem menção" Checked="ShowAllRegionCheck_Changed" Unchecked="ShowAllRegionCheck_Changed" VerticalAlignment="Center" Margin="14,0,0,0"/>
                    </Grid>
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="430"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource CardStyle}" Padding="0">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <StackPanel Margin="14,13,14,9"><TextBlock Text="BOLETINS REGIONAIS" Style="{StaticResource SectionTitleStyle}"/><TextBlock x:Name="RegionFilesCountText" Foreground="{DynamicResource MutedBrush}" FontSize="10"/></StackPanel>
                                <DataGrid Grid.Row="1" x:Name="RegionFilesGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single" SelectionChanged="RegionFilesGrid_SelectionChanged" MouseDoubleClick="RegionFilesGrid_MouseDoubleClick" Margin="8,0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Nº" Binding="{Binding DisplayNumber}" Width="112"/>
                                        <DataGridTextColumn Header="Data" Binding="{Binding DisplayDate}" Width="88"/>
                                        <DataGridTextColumn Header="Menções" Binding="{Binding MentionCount}" Width="65"/>
                                        <DataGridTextColumn Header="Arquivo" Binding="{Binding OriginalFileName}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Grid.Row="2" Margin="12,8" Orientation="Horizontal"><Button Content="Abrir PDF" Style="{StaticResource PrimaryButtonStyle}" Click="OpenRegionPdf_Click"/><Button Content="Mostrar na pasta" Style="{StaticResource SecondaryButtonStyle}" Click="RevealRegionPdf_Click" Margin="8,0,0,0"/></StackPanel>
                            </Grid>
                        </Border>
                        <Grid Grid.Column="2"><Grid.RowDefinitions><RowDefinition Height="1.15*"/><RowDefinition Height="10"/><RowDefinition Height="0.85*"/></Grid.RowDefinitions>
                            <Border Style="{StaticResource CardStyle}" Padding="0">
                                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                    <StackPanel Margin="14,13,14,9"><TextBlock Text="MENÇÕES ENCONTRADAS" Style="{StaticResource SectionTitleStyle}"/><TextBlock x:Name="RegionMentionsCountText" Foreground="{DynamicResource MutedBrush}" FontSize="10"/></StackPanel>
                                    <DataGrid Grid.Row="1" x:Name="RegionMentionsGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single" SelectionChanged="RegionMentionsGrid_SelectionChanged" MouseDoubleClick="RegionMentionsGrid_MouseDoubleClick" Margin="8,0,8,8">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Página" Binding="{Binding PageText}" Width="72"/>
                                            <DataGridTextColumn Header="Tipo" Binding="{Binding Type}" Width="180"/>
                                            <DataGridTextColumn Header="Seção" Binding="{Binding Section}" Width="250"/>
                                            <DataGridTextColumn Header="Resumo" Binding="{Binding Summary}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="14">
                                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <TextBlock Text="DETALHE DA MENÇÃO" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBox Grid.Row="1" x:Name="RegionDetailText" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" BorderThickness="0" Background="Transparent" Margin="0,8,0,8"/>
                                    <Button Grid.Row="2" Content="Abrir exatamente nesta menção" Style="{StaticResource PrimaryButtonStyle}" Click="OpenRegionMention_Click" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Aditamento CML — Pagamentos">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Border Background="{DynamicResource SuccessSoftBrush}" BorderBrush="{DynamicResource SuccessBrush}" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,0,10">
                        <TextBlock Text="Leitura orientada a pagamento: o SIGFUR destaca autorização de saque, exercícios anteriores, evento, duração, efetivo autorizado, valor estimado e a OM atendida." Foreground="{DynamicResource SuccessBrush}" TextWrapping="Wrap"/>
                    </Border>
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <Button Content="Importar pasta CML" Style="{StaticResource PrimaryButtonStyle}" Click="ImportCmlFolder_Click" MinWidth="135"/>
                        <Button Grid.Column="1" Content="Adicionar PDFs" Style="{StaticResource SecondaryButtonStyle}" Click="ImportCmlFiles_Click" Margin="8,0,0,0" MinWidth="112"/>
                        <Button Grid.Column="2" Content="Abrir biblioteca" Style="{StaticResource GhostButtonStyle}" Click="OpenCmlFolder_Click" Margin="8,0,0,0" MinWidth="112"/>
                        <Button Grid.Column="3" Content="Remover selecionado" Style="{StaticResource DangerButtonStyle}" Click="RemoveCml_Click" Margin="8,0,0,0" MinWidth="128"/>
                        <TextBox Grid.Column="5" x:Name="CmlFilterBox" TextChanged="CmlFilterBox_TextChanged" ToolTip="Filtrar por número, data, seção, evento, valor ou contexto"/>
                        <CheckBox Grid.Column="6" x:Name="ShowAllCmlCheck" Content="Mostrar também sem menção" Checked="ShowAllCmlCheck_Changed" Unchecked="ShowAllCmlCheck_Changed" VerticalAlignment="Center" Margin="14,0,0,0"/>
                    </Grid>
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="430"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource CardStyle}" Padding="0">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <StackPanel Margin="14,13,14,9"><TextBlock Text="ADITAMENTOS DO CML" Style="{StaticResource SectionTitleStyle}"/><TextBlock x:Name="CmlFilesCountText" Foreground="{DynamicResource MutedBrush}" FontSize="10"/></StackPanel>
                                <DataGrid Grid.Row="1" x:Name="CmlFilesGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single" SelectionChanged="CmlFilesGrid_SelectionChanged" MouseDoubleClick="CmlFilesGrid_MouseDoubleClick" Margin="8,0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Aditamento / BI" Binding="{Binding DisplayNumber}" Width="170"/>
                                        <DataGridTextColumn Header="Data" Binding="{Binding DisplayDate}" Width="88"/>
                                        <DataGridTextColumn Header="Menções" Binding="{Binding MentionCount}" Width="65"/>
                                        <DataGridTextColumn Header="Arquivo" Binding="{Binding OriginalFileName}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Grid.Row="2" Margin="12,8" Orientation="Horizontal"><Button Content="Abrir PDF" Style="{StaticResource PrimaryButtonStyle}" Click="OpenCmlPdf_Click"/><Button Content="Mostrar na pasta" Style="{StaticResource SecondaryButtonStyle}" Click="RevealCmlPdf_Click" Margin="8,0,0,0"/></StackPanel>
                            </Grid>
                        </Border>
                        <Grid Grid.Column="2"><Grid.RowDefinitions><RowDefinition Height="1.15*"/><RowDefinition Height="10"/><RowDefinition Height="0.85*"/></Grid.RowDefinitions>
                            <Border Style="{StaticResource CardStyle}" Padding="0">
                                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                    <StackPanel Margin="14,13,14,9"><TextBlock Text="LIBERAÇÕES / AUTORIZAÇÕES" Style="{StaticResource SectionTitleStyle}"/><TextBlock x:Name="CmlMentionsCountText" Foreground="{DynamicResource MutedBrush}" FontSize="10"/></StackPanel>
                                    <DataGrid Grid.Row="1" x:Name="CmlMentionsGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single" SelectionChanged="CmlMentionsGrid_SelectionChanged" MouseDoubleClick="CmlMentionsGrid_MouseDoubleClick" Margin="8,0,8,8">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Página" Binding="{Binding PageText}" Width="72"/>
                                            <DataGridTextColumn Header="Classificação" Binding="{Binding Type}" Width="245"/>
                                            <DataGridTextColumn Header="Evento" Binding="{Binding Event}" Width="210"/>
                                            <DataGridTextColumn Header="Valor" Binding="{Binding Amount}" Width="110"/>
                                            <DataGridTextColumn Header="Resumo" Binding="{Binding Summary}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="14">
                                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <TextBlock Text="DETALHE DA LIBERAÇÃO" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBox Grid.Row="1" x:Name="CmlDetailText" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" BorderThickness="0" Background="Transparent" Margin="0,8,0,8"/>
                                    <Button Grid.Row="2" Content="Abrir exatamente nesta liberação" Style="{StaticResource PrimaryButtonStyle}" Click="OpenCmlMention_Click" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="3" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="14,0">
            <Grid><TextBlock x:Name="StatusText" Text="Pronto." VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}"/><ProgressBar x:Name="BusyBar" Width="170" Height="5" IsIndeterminate="True" Visibility="Collapsed" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
        </Border>
    </Grid>
</Window>
