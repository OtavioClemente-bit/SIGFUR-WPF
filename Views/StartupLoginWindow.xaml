<Window x:Class="SIGFUR.Wpf.Views.StartupLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIGFUR — Perfil e Backup" Width="960" Height="780" MinWidth="720" MinHeight="520"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize" Background="#F4F7FB" Tag="UiState.BoundsOnly"
        SizeChanged="Window_SizeChanged" LocationChanged="Window_LocationChanged" StateChanged="Window_StateChanged">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap" TextAlignment="Center" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="0,3,0,8"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="0,3,0,8"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Margin" Value="0,3,0,8"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Margin="24" MinWidth="660">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Background="#143D66" CornerRadius="18" Padding="24" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="76" Height="76" CornerRadius="20" Background="#22FFFFFF" Margin="0,0,18,0">
                        <Image Source="/Assets/sigfur-mark.png" Width="62" Height="62" Stretch="Uniform"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="SIGFUR" Foreground="White" FontSize="34" FontWeight="Bold"/>
                        <TextBlock Text="Sistema Integrado de Gestão do Furriel" Foreground="#DCEBFF" FontSize="15" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        <TextBlock Text="Perfil opcional para backup, sincronização e restauração segura entre computadores." Foreground="#BFD8F4" FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.02*" MinWidth="310"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="1*" MinWidth="310"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Background="White" CornerRadius="14" Padding="18" BorderBrush="#D8E2EF" BorderThickness="1" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Acesso rápido" FontSize="18" FontWeight="Bold" Foreground="#143D66"/>
                            <TextBlock Text="Usar os dados salvos neste computador. Nenhum backup será restaurado." TextWrapping="Wrap" Foreground="#546579" Margin="0,6,0,12"/>
                            <Button x:Name="NoLoginButton" Content="Entrar sem login" Click="NoLoginButton_Click" Background="#143D66" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="14" Padding="18" BorderBrush="#D8E2EF" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Primeiro uso ou novo computador" FontSize="18" FontWeight="Bold" Foreground="#143D66"/>
                            <TextBlock Text="Crie um Perfil SIGFUR ou conecte este computador a uma pasta já sincronizada." TextWrapping="Wrap" Foreground="#546579" Margin="0,6,0,12"/>
                            <Button Content="Criar novo perfil" Click="CreateProfileButton_Click" Background="#EAF2FB" Foreground="#143D66"/>
                            <Button Content="Usar perfil existente" Click="UseExistingProfileButton_Click" Background="#EAF2FB" Foreground="#143D66"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Grid.Column="2" Background="White" CornerRadius="14" Padding="18" BorderBrush="#D8E2EF" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Perfil SIGFUR" FontSize="18" FontWeight="Bold" Foreground="#143D66"/>
                        <TextBlock Text="Entrar com perfil carrega os dados locais configurados. A restauração só acontece se você escolher carregar o último backup." TextWrapping="Wrap" Foreground="#546579" Margin="0,6,0,14"/>

                        <TextBlock Text="Perfil" FontWeight="SemiBold" Foreground="#26384D"/>
                        <ComboBox x:Name="ProfilesComboBox" DisplayMemberPath="ProfileName" SelectionChanged="ProfilesComboBox_SelectionChanged"/>

                        <TextBlock Text="Senha" FontWeight="SemiBold" Foreground="#26384D"/>
                        <PasswordBox x:Name="ProfilePasswordBox"/>

                        <Button Content="Entrar" Click="EnterProfileButton_Click" Background="#143D66" Foreground="White"/>
                        <Button Content="Entrar e carregar último backup" Click="EnterAndRestoreButton_Click" Background="#0F6B4F" Foreground="White"/>
                        <Button Content="Esqueci/alterar pasta de sincronização" Click="UseExistingProfileButton_Click" Background="#F0F4F9" Foreground="#143D66"/>
                        <Button Content="Cancelar" Click="CancelButton_Click" Background="#F8EDEE" Foreground="#9F1D2D"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="#EAF2FB" CornerRadius="12" Padding="14" Margin="0,16,0,0" BorderBrush="#D8E2EF" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="StatusTextBlock" Text="Status: aguardando escolha de entrada." Foreground="#143D66" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    <TextBlock x:Name="FooterTextBlock" Foreground="#546579" FontSize="12" TextWrapping="Wrap" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
