<Window x:Class="SIGFUR.Wpf.Views.Documents.LegislationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Legislação — Pesquisa Operacional Offline" Width="1500" Height="900" MinWidth="1180" MinHeight="720"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackgroundBrush}" KeyDown="Window_KeyDown">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}" Padding="20" Background="{DynamicResource PrimarySurfaceBrush}">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="PESQUISA OPERACIONAL DE LEGISLAÇÃO" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryDarkerBrush}"/>
                    <TextBlock Text="Digite como você pergunta no serviço: pagamento, FuSEx, PNR, auxílio-transporte, férias, IRRF, ajuste de contas ou artigo. A pesquisa é offline, ranqueada por relevância e abre direto na fonte." Margin="0,6,0,0" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap"/>
                    <TextBlock Text="Biblioteca da IA: salve aqui leis, decretos, portarias, manuais SIPPES/CPEx e orientações de pagamento. Tudo que for importado e indexado poderá ser usado pelo Assistente SIGFUR para responder e montar boletins com fonte." Margin="0,5,0,0" Foreground="{DynamicResource PrimaryBrush}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Style="{StaticResource MetricCardStyle}" MinWidth="150" Margin="8,0,0,0">
                        <StackPanel><TextBlock Text="DOCUMENTOS" Style="{StaticResource MetricCaptionStyle}"/><TextBlock x:Name="DocumentsMetric" Text="0" Style="{StaticResource MetricValueStyle}"/></StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricCardStyle}" MinWidth="150" Margin="8,0,0,0">
                        <StackPanel><TextBlock Text="PÁGINAS" Style="{StaticResource MetricCaptionStyle}"/><TextBlock x:Name="PagesMetric" Text="0" Style="{StaticResource MetricValueStyle}"/></StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,12,0,12" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <TextBox x:Name="SearchBox" Height="42" FontSize="15" VerticalContentAlignment="Center" Padding="12,0"
                         ToolTip="Digite uma pergunta, tema, artigo, rubrica ou expressão. Ctrl+F para focar."
                         KeyDown="SearchBox_KeyDown" TextChanged="SearchBox_TextChanged"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                    <Button Content="Pesquisar" Style="{StaticResource PrimaryButtonStyle}" Padding="22,10" Click="Search_Click"/>
                    <Button Content="Montar resposta offline" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" Padding="18,10" Click="Answer_Click"/>
                    <Button Style="{StaticResource PrimaryButtonStyle}" Margin="8,0,0,0" Padding="18,10" Click="OpenAiResearch_Click" ToolTip="Abre o Assistente SIGFUR com os PDFs locais mais relevantes anexados"><StackPanel Orientation="Horizontal"><TextBlock Text="✦" FontSize="16" FontWeight="Bold" Margin="0,0,8,0"/><TextBlock Text="Consultar com IA" FontWeight="SemiBold"/></StackPanel></Button>
                </StackPanel>
                <WrapPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,10,0,0">
                    <Button Content="Importar arquivos" Style="{StaticResource GhostButtonStyle}" Click="ImportFiles_Click" Margin="0,0,8,6"/>
                    <Button Content="Importar ZIP" Style="{StaticResource GhostButtonStyle}" Click="ImportZip_Click" Margin="0,0,8,6"/>
                    <Button Content="Importar pasta" Style="{StaticResource GhostButtonStyle}" Click="ImportFolder_Click" Margin="0,0,8,6"/>
                    <Button Content="Atualizar índice" Style="{StaticResource GhostButtonStyle}" Click="Index_Click" Margin="0,0,8,6"/>
                    <Button Content="Reindexar tudo" Style="{StaticResource GhostButtonStyle}" Click="ForceIndex_Click" Margin="0,0,8,6"/>
                    <Button Content="Abrir biblioteca" Style="{StaticResource GhostButtonStyle}" Click="OpenLibrary_Click" Margin="0,0,8,6"/>
                    <Button Content="Pesquisar pagamento oficial" Style="{StaticResource GhostButtonStyle}" Click="OpenOfficialPaymentSearch_Click" Margin="0,0,8,6" ToolTip="Abre uma pesquisa externa restrita a fontes oficiais do Governo, Planalto e Exército"/>
                    <Button Content="SGEx/EB" Style="{StaticResource GhostButtonStyle}" Click="OpenSgexSearch_Click" Margin="0,0,8,6" ToolTip="Pesquisa portarias, normas e boletins do Exército no SGEx"/>
                    <Button Content="Planalto" Style="{StaticResource GhostButtonStyle}" Click="OpenPlanaltoSearch_Click" Margin="0,0,8,6" ToolTip="Pesquisa leis, decretos e medidas provisórias no Planalto"/>
                    <TextBlock x:Name="IndexStatusText" Margin="10,0,0,6" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}" Text="Biblioteca pronta."/>
                    <Border Background="{DynamicResource PrimarySoftBrush}" CornerRadius="12" Padding="10,4" Margin="10,0,0,6"><TextBlock Text="Ex.: porcentagem do PNR" Foreground="{DynamicResource PrimaryDarkBrush}" FontSize="10" FontWeight="SemiBold"/></Border>
                    <Border Background="{DynamicResource SuccessSoftBrush}" CornerRadius="12" Padding="10,4" Margin="6,0,0,6"><TextBlock Text="Ex.: pagamento do Exército" Foreground="{DynamicResource SuccessBrush}" FontSize="10" FontWeight="SemiBold"/></Border>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="280"/><ColumnDefinition Width="8"/><ColumnDefinition Width="1.15*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="0.95*"/></Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="12">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <TextBlock Text="BIBLIOTECA" Style="{StaticResource SectionTitleStyle}"/>
                    <TextBox x:Name="DocumentFilterBox" Grid.Row="1" Margin="0,10,0,10" Height="34" VerticalContentAlignment="Center" Padding="8,0" TextChanged="DocumentFilterBox_TextChanged" ToolTip="Filtrar documentos importados"/>
                    <ListBox x:Name="DocumentList" Grid.Row="2" DisplayMemberPath="Title" SelectionChanged="DocumentList_SelectionChanged" MouseDoubleClick="DocumentList_MouseDoubleClick">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Abrir documento" Click="OpenSelectedDocument_Click"/>
                                <MenuItem Header="Abrir pasta do documento" Click="OpenSelectedDocumentFolder_Click"/>
                                <MenuItem Header="Ler documento inteiro" Click="ReadWholeDocument_Click"/>
                                <Separator/>
                                <MenuItem Header="Copiar caminho" Click="CopyDocumentPath_Click"/>
                                <MenuItem Header="Remover da biblioteca" Click="DeleteDocument_Click"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="Transparent"/>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="12">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="RESULTADOS RANQUEADOS" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock x:Name="ResultCountText" Grid.Column="1" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/>
                    </Grid>
                    <DataGrid x:Name="ResultsGrid" Grid.Row="1" Margin="0,10,0,10" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single" SelectionChanged="ResultsGrid_SelectionChanged" MouseDoubleClick="ResultsGrid_MouseDoubleClick">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Abrir documento" Click="OpenSelectedResult_Click"/>
                                <MenuItem Header="Copiar referência" Click="CopyReference_Click"/>
                                <MenuItem Header="Copiar trecho" Click="CopySnippet_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Documento" Binding="{Binding Title}" Width="190"/>
                            <DataGridTextColumn Header="Pág." Binding="{Binding Page}" Width="58"/>
                            <DataGridTextColumn Header="Trecho relevante" Binding="{Binding Snippet}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Copiar referência" Style="{StaticResource GhostButtonStyle}" Click="CopyReference_Click"/>
                        <Button Content="Abrir selecionado" Style="{StaticResource PrimaryButtonStyle}" Margin="8,0,0,0" Click="OpenSelectedResult_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" Width="8" HorizontalAlignment="Stretch" Background="Transparent"/>

            <Border Grid.Column="4" Style="{StaticResource CardStyle}" Padding="12">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBlock Text="FONTE, TRECHO E RESPOSTA" Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock x:Name="ReferenceText" Grid.Row="1" Margin="0,8,0,8" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    <TextBox x:Name="PreviewBox" Grid.Row="2" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="12" FontFamily="Segoe UI" FontSize="13">
                        <TextBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Copiar seleção" Command="ApplicationCommands.Copy"/>
                                <MenuItem Header="Selecionar tudo" Command="ApplicationCommands.SelectAll"/>
                            </ContextMenu>
                        </TextBox.ContextMenu>
                    </TextBox>
                    <WrapPanel Grid.Row="3" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Ler documento inteiro" Style="{StaticResource GhostButtonStyle}" Margin="0,0,8,0" Click="ReadWholeDocument_Click"/>
                        <Button Content="Exportar resposta" Style="{StaticResource GhostButtonStyle}" Margin="0,0,8,0" Click="ExportPreview_Click"/>
                        <Button Content="Copiar resposta/trecho" Style="{StaticResource SecondaryButtonStyle}" Click="CopyPreview_Click"/>
                        <Button Content="Abrir fonte" Style="{StaticResource PrimaryButtonStyle}" Margin="8,0,0,0" Click="OpenSelectedResult_Click"/>
                    </WrapPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Margin="0,12,0,0" Padding="12,8" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="8">
            <TextBlock x:Name="FooterStatusText" Text="Modo offline disponível. A consulta com IA usa a API configurada e somente os PDFs locais selecionados pelo SIGFUR; a pesquisa externa abre fontes oficiais separadamente." Foreground="{DynamicResource MutedBrush}"/>
        </Border>
    </Grid>
</Window>
