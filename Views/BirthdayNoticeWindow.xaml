<Window x:Class="SIGFUR.Wpf.Views.BirthdayNoticeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIGFUR — Aniversariantes" Width="560" Height="430" MinWidth="520" MinHeight="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="Transparent"
        AllowsTransparency="True" WindowStyle="None" ShowInTaskbar="False">
    <Border CornerRadius="18" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="0">
        <Border.Effect><DropShadowEffect BlurRadius="28" ShadowDepth="6" Opacity="0.28"/></Border.Effect>
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="96"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <Border Background="{DynamicResource PrimaryGradientBrush}" CornerRadius="18,18,0,0" Padding="22,0">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <Border Width="54" Height="54" CornerRadius="16" Background="#22FFFFFF" VerticalAlignment="Center">
                        <TextBlock Text="🎂" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="ANIVERSARIANTE(S) DO DIA" Foreground="White" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="Conferência rápida antes de gerar boletim ou cumprimentos." Foreground="#DCEBFF" FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="×" Width="34" Height="34" Click="Close_Click" Background="#22FFFFFF" Foreground="White" BorderThickness="0" FontSize="18" FontWeight="Bold"/>
                </Grid>
            </Border>
            <Border Grid.Row="1" Padding="20" Background="{DynamicResource SurfaceBrush}">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <TextBlock Text="Militares localizados para hoje" Style="{StaticResource SectionTitleStyle}"/>
                    <ListBox x:Name="BirthdaysList" Grid.Row="1" Margin="0,12,0,0" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="12" Padding="12" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <Border Width="38" Height="38" CornerRadius="19" Background="{DynamicResource PrimarySoftBrush}">
                                            <TextBlock Text="★" Foreground="{DynamicResource PrimaryDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                            <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap">
                                                <Run Text="{Binding Rank}"/><Run Text=" "/><Run Text="{Binding NameBeforeWar}"/><Run Text="{Binding NameWarBold}" FontWeight="Bold"/><Run Text="{Binding NameAfterWar}"/>
                                            </TextBlock>
                                            <TextBlock Foreground="{DynamicResource MutedBrush}" FontSize="11" Margin="0,3,0,0"><Run Text="Idade: "/><Run Text="{Binding Age}"/><Run Text=" ano(s)"/></TextBlock>
                                        </StackPanel>
                                        <Border Grid.Column="2" Background="{DynamicResource SuccessSoftBrush}" CornerRadius="12" Padding="9,4" VerticalAlignment="Center">
                                            <TextBlock Text="HOJE" Foreground="{DynamicResource SuccessBrush}" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
            <Border Grid.Row="2" Background="{DynamicResource SurfaceAltBrush}" Padding="16" CornerRadius="0,0,18,18">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Agora não" Style="{StaticResource SecondaryButtonStyle}" Click="Close_Click" Margin="0,0,8,0"/>
                    <Button Content="Abrir conferência" Style="{StaticResource PrimaryButtonStyle}" Click="Open_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
