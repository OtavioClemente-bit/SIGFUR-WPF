<Window x:Class="SIGFUR.Wpf.Views.Bulletin.SisbolLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIGFUR — Preparar SisBol" Width="760" Height="660" MinWidth="700" MinHeight="610"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="96"/><RowDefinition Height="*"/><RowDefinition Height="76"/></Grid.RowDefinitions>
        <Border Background="{DynamicResource PrimaryGradientBrush}" Padding="24,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="PREPARAR SISBOL" Foreground="White" FontWeight="Bold" FontSize="22"/>
                </StackPanel>
                <Border Grid.Column="1" Background="#1EFFFFFF" CornerRadius="17" Padding="12,7" VerticalAlignment="Center">
                    <TextBlock x:Name="StepBadge" Text="1. Abrir login" Foreground="White" FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Style="{StaticResource CardStyle}" Margin="20" Padding="20">
                <StackPanel>
                    <TextBlock Text="Navegador" Style="{StaticResource CaptionTextStyle}"/>
                    <ComboBox x:Name="BrowserBox" Margin="0,6,0,14" SelectedValuePath="Tag">
                        <ComboBoxItem Content="Microsoft Edge (recomendado)" Tag="edge"/>
                        <ComboBoxItem Content="Google Chrome" Tag="chrome"/>
                        <ComboBoxItem Content="Mozilla Firefox" Tag="firefox"/>
                    </ComboBox>

                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Login" Style="{StaticResource CaptionTextStyle}"/>
                            <TextBox x:Name="LoginBox" Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Senha" Style="{StaticResource CaptionTextStyle}"/>
                            <PasswordBox x:Name="PasswordBox" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>

                    <CheckBox x:Name="SavePasswordCheck" Content="Salvar login e senha protegidos pelo usuário do Windows" Margin="0,16,0,0"/>
                    <CheckBox x:Name="HideAfterLoginCheck" Content="Ocultar completamente o navegador depois de validar o login (obrigatório)" Margin="0,10,0,0" IsChecked="True" IsEnabled="False"/>
                    <CheckBox x:Name="IncludeAutomaticallyCheck" Content="Incluir automaticamente após validar campos e texto (padrão operacional)" Margin="0,10,0,0" IsChecked="True" IsEnabled="False"/>

                    <Border x:Name="StatusBorder" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="9" Padding="13" Margin="0,14,0,0">
                        <TextBlock x:Name="StatusText" Text="Escolha o navegador e clique em Abrir SisBol." TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}"/>
                    </Border>
                    <ProgressBar x:Name="BusyProgress" Height="4" Margin="0,12,0,0" IsIndeterminate="True" Visibility="Collapsed"/>

                    <Border Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="MODO DIAGNÓSTICO SISBOL" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource PrimaryDarkBrush}"/>
                            <TextBlock Text="Grava seu passo a passo manual, selectors, HTML dos frames, print e valores dos campos. Login, captcha e decisão de incluir continuam humanos." TextWrapping="Wrap" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,6,0,0"/>
                            <TextBlock x:Name="DiagnosticHintText" Text="Assunto de teste para buscar: AD PESSOAL - Diferenca. Corpo de teste: TESTE TÉCNICO SIGFUR - DIAGNÓSTICO DO FLUXO SISBOL." TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,8,0,0"/>

                            <UniformGrid Columns="3" Margin="0,12,0,0">
                                <Button x:Name="DiagnosticStartButton" Content="Iniciar diagnóstico" Style="{StaticResource SecondaryButtonStyle}" Click="DiagnosticStart_Click" Margin="0,0,8,8"/>
                                <Button x:Name="DiagnosticSubjectButton" Content="Colar assunto teste" Style="{StaticResource GhostButtonStyle}" Click="DiagnosticSubject_Click" Margin="0,0,8,8"/>
                                <Button x:Name="DiagnosticBodyButton" Content="Colar corpo teste" Style="{StaticResource GhostButtonStyle}" Click="DiagnosticBody_Click" Margin="0,0,0,8"/>
                                <Button x:Name="DiagnosticCheckpointButton" Content="Marcar checkpoint" Style="{StaticResource GhostButtonStyle}" Click="DiagnosticCheckpoint_Click" Margin="0,0,8,0"/>
                                <Button x:Name="DiagnosticFinishButton" Content="Gerar pacote ZIP" Style="{StaticResource PrimaryButtonStyle}" Click="DiagnosticFinish_Click" Margin="0,0,8,0"/>
                                <Button x:Name="DiagnosticOpenFolderButton" Content="Abrir pasta" Style="{StaticResource GhostButtonStyle}" Click="DiagnosticOpenFolder_Click"/>
                            </UniformGrid>

                            <TextBlock x:Name="DiagnosticStatusText" Text="Fluxo recomendado: abrir SisBol → login/captcha → iniciar diagnóstico → clicar buscar assunto → colar assunto teste → selecionar a linha → colar corpo → gerar pacote." TextWrapping="Wrap" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <Button Content="Mostrar navegador" Style="{StaticResource GhostButtonStyle}" Click="ShowBrowser_Click" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="CancelButton" Content="Cancelar" Style="{StaticResource GhostButtonStyle}" Click="Cancel_Click" Margin="0,0,8,0"/>
                    <Button x:Name="ConfirmButton" Content="Já entrei — validar e ocultar" Style="{StaticResource SecondaryButtonStyle}" Click="Confirm_Click" IsEnabled="False" Margin="0,0,8,0"/>
                    <Button x:Name="OpenButton" Content="Abrir SisBol" Style="{StaticResource PrimaryButtonStyle}" Click="Open_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
