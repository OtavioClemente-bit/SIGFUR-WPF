<Window x:Class="SIGFUR.Wpf.Views.Bulletin.BulletinWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SIGFUR.Wpf.Controls"
        xmlns:services="clr-namespace:SIGFUR.Wpf.Services"
        Title="SIGFUR — Boletim" Width="1520" Height="920" MinWidth="1180" MinHeight="760" FontSize="12.5"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="72"/>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="128" MinHeight="112"/>
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource PrimaryGradientBrush}" Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="BOLETIM" Foreground="White" FontSize="21" FontWeight="Bold"/>
                    <TextBlock Text="Modelos, chaves, ordem dos militares, Word e lançamento automático no SisBol." Foreground="#DCEBFF" Margin="0,5,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,12,0" VerticalAlignment="Center">
                        <TextBlock Text="Sessão compartilhada" Foreground="#DCEBFF" FontSize="10" HorizontalAlignment="Right"/>
                        <TextBlock Text="Prepare o SisBol somente na tela principal" Foreground="White" FontWeight="SemiBold"/>
                    </StackPanel>
                    <Border x:Name="SisbolBadge" Background="#1EFFFFFF" CornerRadius="16" Padding="12,7">
                        <TextBlock x:Name="SisbolStatusText" Text="SisBol não preparado" Foreground="White" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="14,7">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <WrapPanel VerticalAlignment="Center">
                    <Button Content="Novo modelo" Style="{StaticResource PrimaryButtonStyle}" Click="NewTemplate_Click" Margin="0,0,8,0" MinWidth="112"/>
                    <Button Content="Editar modelo" Style="{StaticResource SecondaryButtonStyle}" Click="EditTemplate_Click" Margin="0,0,8,0" MinWidth="108"/>
                    <Button Content="Duplicar" Style="{StaticResource SecondaryButtonStyle}" Click="DuplicateTemplate_Click" Margin="0,0,8,0" MinWidth="88"/>
                    <Button Content="Excluir" Style="{StaticResource DangerButtonStyle}" Click="DeleteTemplate_Click" Margin="0,0,14,0" MinWidth="80"/>
                    <Button Content="Chaves salvas" Style="{StaticResource GhostButtonStyle}" Click="SavedKeys_Click" Margin="0,0,8,0" MinWidth="105"/>
                    <Button Content="Usar BI/ADT salvo" Style="{StaticResource GhostButtonStyle}" Click="SavedBulletin_Click" Margin="0,0,8,0" MinWidth="125"/>
                    <Button Content="Boletins de fora" Style="{StaticResource GhostButtonStyle}" Click="ExternalBulletins_Click" Margin="0,0,8,0" MinWidth="118"/>
                    <Button Content="Valor por extenso" Style="{StaticResource GhostButtonStyle}" Click="NumberToWords_Click" MinWidth="125" Margin="0,0,8,0"/>
                    <CheckBox x:Name="LockBulletinOrderCheck" Content="Travar ordem" Checked="LockBulletinOrderCheck_Changed" Unchecked="LockBulletinOrderCheck_Changed" VerticalAlignment="Center" ToolTip="Bloqueia o arraste dos modelos e dos militares."/>
                </WrapPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="18,0,0,0">
                    <Button Content="Gerar prévia" Style="{StaticResource PrimaryButtonStyle}" Click="Generate_Click" Margin="0,0,8,0" MinWidth="108"/>
                    <Button Content="Copiar para Word" Style="{StaticResource SecondaryButtonStyle}" Click="CopyWord_Click" Margin="0,0,8,0" MinWidth="125"/>
                    <Button x:Name="SendSisbolButton" Content="Enviar ao SisBol" Style="{StaticResource PrimaryButtonStyle}" Click="SendSisbol_Click" MinWidth="128"/>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions><RowDefinition Height="0.82*" MinHeight="205"/><RowDefinition Height="6"/><RowDefinition Height="1.18*" MinHeight="285"/></Grid.RowDefinitions>

            <Border Grid.RowSpan="3" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <StackPanel Margin="11,10,11,7">
                        <TextBlock Text="MODELOS DE BOLETIM" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Arraste para salvar a ordem; use ‘Travar ordem’ para evitar mudanças acidentais." Foreground="{DynamicResource MutedBrush}" Margin="0,3,0,0"/>
                    </StackPanel>
                    <TextBox x:Name="TemplateSearchBox" Grid.Row="1" Margin="10,0,10,7" Padding="8,6" FontSize="12" TextChanged="TemplateSearch_TextChanged" ToolTip="Pesquisar modelo"/>
                    <ListBox x:Name="TemplateList" Grid.Row="2" Margin="8,0" DisplayMemberPath="Name" SelectionChanged="TemplateList_SelectionChanged"
                             FontSize="12"
                             PreviewMouseLeftButtonDown="TemplateList_PreviewMouseLeftButtonDown" PreviewMouseMove="TemplateList_PreviewMouseMove"
                             AllowDrop="True" Drop="TemplateList_Drop"/>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="7">
                        <Button Content="▲" Style="{StaticResource GhostButtonStyle}" Click="MoveTemplateUp_Click" Width="44"/>
                        <Button Content="▼" Style="{StaticResource GhostButtonStyle}" Click="MoveTemplateDown_Click" Width="44" Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Grid Margin="11,10,11,7">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="MILITARES DISPONÍVEIS" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock x:Name="AvailableCountText" Foreground="{DynamicResource MutedBrush}" Margin="0,3,0,0"/>
                        </StackPanel>
                        <ComboBox x:Name="AvailableSortBox" Grid.Column="1" Width="205" FontSize="12" SelectionChanged="AvailableSortBox_SelectionChanged">
                            <ComboBoxItem Content="Ordem salva (Listar Militares)"/>
                            <ComboBoxItem Content="Posto/Graduação + Nome"/>
                            <ComboBoxItem Content="Somente Nome (A→Z)"/>
                            <ComboBoxItem Content="ID (cadastro)"/>
                        </ComboBox>
                    </Grid>
                    <TextBox x:Name="MilitarySearchBox" Grid.Row="1" Margin="10,0,10,7" Padding="8,6" FontSize="12" TextChanged="MilitarySearch_TextChanged" ToolTip="Pesquisar por nome, CPF, Prec-CP ou posto"/>
                    <DataGrid x:Name="AvailableGrid" Grid.Row="2" Margin="8,0" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              FontSize="12" RowHeight="29" ColumnHeaderHeight="31" SelectionMode="Extended" SelectionUnit="FullRow" MouseDoubleClick="AvailableGrid_MouseDoubleClick">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Adicionar selecionados ao boletim" Click="AddSelected_Click"/>
                                <MenuItem Header="Adicionar marcados" Click="AddMarked_Click"/>
                                <Separator/>
                                <MenuItem Header="Selecionar todos os visíveis" Click="SelectAllAvailable_Click"/>
                                <MenuItem Header="Limpar seleção" Click="ClearAvailableSelection_Click"/>
                                <Separator/>
                                <MenuItem Header="Copiar selecionados" Click="CopyAvailableSelection_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="P/G" Binding="{Binding ShortRank}" Width="76"/>
                            <DataGridTemplateColumn Header="Nome" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate><controls:HighlightedNameTextBlock FullName="{Binding Name}" WarName="{Binding WarName}" TextTrimming="CharacterEllipsis"/></DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="CPF" Binding="{Binding FormattedCpf}" Width="122"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="8" HorizontalAlignment="Center">
                        <Button Content="Adicionar selecionados →" Style="{StaticResource PrimaryButtonStyle}" Click="AddSelected_Click"/>
                        <Button Content="Adicionar marcados" Style="{StaticResource SecondaryButtonStyle}" Click="AddMarked_Click" Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <StackPanel Margin="11,10,11,7">
                        <TextBlock Text="ORDEM NO BOLETIM" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock x:Name="SelectedCountText" Foreground="{DynamicResource MutedBrush}" Margin="0,3,0,0"/>
                    </StackPanel>
                    <DataGrid x:Name="SelectedGrid" Grid.Row="1" Margin="8,0" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              FontSize="12" RowHeight="29" ColumnHeaderHeight="31" SelectionMode="Extended" SelectionUnit="FullRow" AllowDrop="True"
                              PreviewMouseLeftButtonDown="SelectedGrid_PreviewMouseLeftButtonDown" PreviewMouseMove="SelectedGrid_PreviewMouseMove" Drop="SelectedGrid_Drop">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Remover selecionados" Click="RemoveSelected_Click"/>
                                <MenuItem Header="Mover para cima" Click="MoveSelectedUp_Click"/>
                                <MenuItem Header="Mover para baixo" Click="MoveSelectedDown_Click"/>
                                <Separator/>
                                <MenuItem Header="Selecionar todos" Click="SelectAllSelected_Click"/>
                                <MenuItem Header="Limpar seleção" Click="ClearSelectedSelection_Click"/>
                                <Separator/>
                                <MenuItem Header="Copiar selecionados" Click="CopySelectedSelection_Click"/>
                                <Separator/>
                                <MenuItem Header="Limpar lista do boletim" Click="ClearSelected_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Position}" Width="44"/>
                            <DataGridTextColumn Header="P/G" Binding="{Binding Military.ShortRank}" Width="76"/>
                            <DataGridTemplateColumn Header="Nome" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate><controls:HighlightedNameTextBlock FullName="{Binding Military.Name}" WarName="{Binding Military.WarName}" TextTrimming="CharacterEllipsis"/></DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <WrapPanel Grid.Row="2" Margin="8" HorizontalAlignment="Center">
                        <Button Content="← Remover" Style="{StaticResource DangerButtonStyle}" Click="RemoveSelected_Click" Margin="0,0,8,8"/>
                        <Button Content="▲" Style="{StaticResource GhostButtonStyle}" Click="MoveSelectedUp_Click" Width="44" Margin="0,0,8,8"/>
                        <Button Content="▼" Style="{StaticResource GhostButtonStyle}" Click="MoveSelectedDown_Click" Width="44" Margin="0,0,8,8"/>
                        <Button Content="Limpar" Style="{StaticResource GhostButtonStyle}" Click="ClearSelected_Click" Margin="0,0,0,8"/>
                    </WrapPanel>
                </Grid>
            </Border>

            <GridSplitter Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="3" Height="6" HorizontalAlignment="Stretch"
                          VerticalAlignment="Center" Background="Transparent" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"
                          Cursor="SizeNS" ToolTip="Arraste para ajustar o espaço entre militares e preenchimento"/>

            <Border Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="3" Style="{StaticResource CardStyle}" Padding="0">
                <TabControl x:Name="WorkTabs" BorderThickness="0">
                    <TabItem Header="Preenchimento do modelo">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Border Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="14,9">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="FieldsSummaryText" Text="Preencha os dados usados no texto" FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Text="Os campos mudam a prévia automaticamente. Sugestões SIPPES e auditoria por IA não bloqueiam o envio." Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,16,0"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12,7" VerticalAlignment="Center">
                                        <TextBlock x:Name="FieldsProgressText" Text="0 de 0 preenchidos" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="10">
                                <StackPanel x:Name="FieldsPanel"/>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>
                    <TabItem x:Name="ComplianceTab" Header="Conferência SIPPES">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="16">
                                <StackPanel x:Name="CompliancePanel"/>
                            </ScrollViewer>
                            <Border Grid.Row="1" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12">
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="A auditoria IA revisa coerência e redação. Ela serve para conferência e nunca transforma uma sugestão em campo obrigatório." Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                    <Button x:Name="AuditAiButton" Grid.Column="1" Content="✦ Auditar com IA" Style="{StaticResource PrimaryButtonStyle}" Click="AuditWithAi_Click"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>
                    <TabItem x:Name="PreviewTab" Header="Prévia profissional">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <FlowDocumentScrollViewer x:Name="PreviewDocumentViewer" IsToolBarVisible="False" VerticalScrollBarVisibility="Auto" Margin="8"/>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="12">
                                <Button Content="Copiar texto" Style="{StaticResource GhostButtonStyle}" Click="CopyText_Click"/>
                                <Button Content="Salvar .txt" Style="{StaticResource SecondaryButtonStyle}" Click="SaveText_Click" Margin="8,0,0,0"/>
                                <Button Content="Copiar Word" Style="{StaticResource PrimaryButtonStyle}" Click="CopyWord_Click" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Texto do modelo">
                        <Grid Margin="10">
                            <TextBox x:Name="RawTemplateBox" Tag="UiState.NoPersist" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="13" Padding="12"/>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="14,9">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Texto de fechamento / Em consequência" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                        <CheckBox x:Name="IncludeConsequencesCheck" Content="Incluir no SisBol" IsChecked="True" VerticalAlignment="Center" Margin="14,0,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="StatusText" Grid.Column="1" Text="Carregando boletim…" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}" TextTrimming="CharacterEllipsis" Margin="18,0"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="UnresolvedText" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{DynamicResource WarningBrush}" FontWeight="SemiBold"/>
                        <Button Content="Editar em tela maior" Style="{StaticResource GhostButtonStyle}" Click="EditConsequencesLarge_Click" MinWidth="138"/>
                    </StackPanel>
                </Grid>
                <TextBox x:Name="ConsequencesTextBox"
                         Grid.Row="1"
                         Text="{x:Static services:SisbolTexts.BulletinConsequencesText}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         VerticalContentAlignment="Top"
                         FontFamily="Segoe UI"
                         FontSize="13.5"
                         MinLines="3"
                         MaxLines="4"
                         Padding="10,8"
                         Margin="0,8,0,0"
                         ToolTip="Texto editável enviado exclusivamente ao campo Texto de Fechamento do SisBol."/>
            </Grid>
        </Border>
    </Grid>
</Window>
