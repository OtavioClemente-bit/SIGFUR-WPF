<Window x:Class="SIGFUR.Wpf.Views.Bulletin.BulletinTemplateEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIGFUR — Editor de modelo de boletim" Width="1120" Height="780" MinWidth="900" MinHeight="650"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico" Tag="UiState.BoundsOnly">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="88"/><RowDefinition Height="*"/><RowDefinition Height="70"/></Grid.RowDefinitions>
        <Border Background="{DynamicResource PrimaryGradientBrush}" Padding="24,0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="EDITOR DE MODELO" Foreground="White" FontSize="21" FontWeight="Bold"/>
                <TextBlock Text="Use chaves entre [[...]]. O bloco [[ITEM]]...[[/ITEM]] é repetido para cada militar." Foreground="#DCEBFF" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        <Grid Grid.Row="1" Margin="18">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Style="{StaticResource CardStyle}" Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Nome do modelo" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,14,0"/>
                    <TextBox x:Name="NameBox" Grid.Column="1" Tag="UiState.NoPersist"/>
                </Grid>
            </Border>
            <WrapPanel Grid.Row="1" Margin="0,12,0,12">
                <Button Content="Chave automática" Style="{StaticResource SecondaryButtonStyle}" Click="InsertAutoKey_Click" Margin="0,0,8,8"/>
                <Button Content="Campo de texto" Style="{StaticResource SecondaryButtonStyle}" Click="InsertTextField_Click" Margin="0,0,8,8"/>
                <Button Content="Lista" Style="{StaticResource SecondaryButtonStyle}" Click="InsertListField_Click" Margin="0,0,8,8"/>
                <Button Content="Data" Style="{StaticResource SecondaryButtonStyle}" Click="InsertDateField_Click" Margin="0,0,8,8"/>
                <Button Content="Mês" Style="{StaticResource SecondaryButtonStyle}" Click="InsertMonthField_Click" Margin="0,0,8,8"/>
                <Button Content="Valor" Style="{StaticResource SecondaryButtonStyle}" Click="InsertMoneyField_Click" Margin="0,0,8,8"/>
                <Button Content="Bloco de militares" Style="{StaticResource PrimaryButtonStyle}" Click="InsertItemBlock_Click" Margin="0,0,8,8"/>
                <Button Content="Desfazer" Style="{StaticResource GhostButtonStyle}" Click="Undo_Click" Margin="0,0,8,8"/>
                <Button Content="Refazer" Style="{StaticResource GhostButtonStyle}" Click="Redo_Click" Margin="0,0,8,8"/>
            </WrapPanel>
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
                <TextBox x:Name="TemplateTextBox" Tag="UiState.NoPersist" AcceptsReturn="True" AcceptsTab="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="14" Padding="14" SpellCheck.IsEnabled="True"/>
            </Border>
        </Grid>
        <Border Grid.Row="2" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="18,0">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock Text="As alterações são salvas no AppData do SIGFUR e reaparecem na próxima abertura." VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Cancelar" Style="{StaticResource GhostButtonStyle}" Click="Cancel_Click" Margin="0,0,8,0"/>
                    <Button Content="Salvar modelo" Style="{StaticResource PrimaryButtonStyle}" Click="Save_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
