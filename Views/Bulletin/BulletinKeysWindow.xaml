<Window x:Class="SIGFUR.Wpf.Views.Bulletin.BulletinKeysWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIGFUR — Chaves do boletim" Width="980" Height="760" MinWidth="820" MinHeight="620"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="96"/><RowDefinition Height="*"/><RowDefinition Height="70"/></Grid.RowDefinitions>
        <Border Background="{DynamicResource PrimaryGradientBrush}" Padding="24,0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="CHAVES DO BOLETIM" Foreground="White" FontSize="22" FontWeight="Bold"/>
                <TextBlock Text="Salve textos ou crie chaves inteligentes de data, mês e valor com prévia imediata." Foreground="#DCEBFF" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="18">
            <TabItem Header="Chaves salvas">
                <Grid Margin="12">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Adicionar chave simples" Style="{StaticResource PrimaryButtonStyle}" Click="Add_Click"/>
                        <Button Content="Excluir selecionada" Style="{StaticResource DangerButtonStyle}" Click="Delete_Click" Margin="8,0,0,0"/>
                    </StackPanel>
                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
                        <DataGrid x:Name="KeysGrid" AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Chave" Binding="{Binding Key, UpdateSourceTrigger=PropertyChanged}" Width="280"/>
                                <DataGridTextColumn Header="Valor bruto salvo" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                    <TextBlock Grid.Row="2" Margin="2,9,0,0" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap"
                               Text="Esta grade contém somente chaves criadas manualmente. Datas atuais, BI/ADT e dados de certidões ficam em fontes automáticas separadas para não serem sobrescritos por engano."/>
                </Grid>
            </TabItem>

            <TabItem Header="Criar chave inteligente">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <Border Style="{StaticResource CardStyle}" Padding="18">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="1*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="1*"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Nome da chave" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,5"/>
                                    <TextBox x:Name="SmartKeyBox" Text="VALOR_DOCUMENTO" TextChanged="SmartBuilder_Changed"/>
                                    <TextBlock Text="Tipo" Style="{StaticResource CaptionTextStyle}" Margin="0,13,0,5"/>
                                    <ComboBox x:Name="SmartTypeBox" SelectedIndex="3" SelectionChanged="SmartTypeBox_SelectionChanged">
                                        <ComboBoxItem Content="Texto simples" Tag="text"/>
                                        <ComboBoxItem Content="Data" Tag="date"/>
                                        <ComboBoxItem Content="Mês" Tag="month"/>
                                        <ComboBoxItem Content="Valor" Tag="money"/>
                                    </ComboBox>
                                    <TextBlock Text="Valor a salvar" Style="{StaticResource CaptionTextStyle}" Margin="0,13,0,5"/>
                                    <TextBox x:Name="SmartValueBox" Text="1.234,56" TextChanged="SmartBuilder_Changed"/>
                                    <DatePicker x:Name="SmartDatePicker" Visibility="Collapsed" SelectedDateChanged="SmartDatePicker_Changed"/>
                                    <ComboBox x:Name="SmartMonthBox" Visibility="Collapsed" IsEditable="True" SelectionChanged="SmartMonthBox_Changed"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Formato do marcador" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="SmartFormatBox" SelectionChanged="SmartBuilder_Changed"/>
                                    <TextBlock Text="Marcador para usar no modelo" Style="{StaticResource CaptionTextStyle}" Margin="0,13,0,5"/>
                                    <Border Background="{DynamicResource PrimarySurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="12">
                                        <TextBox x:Name="SmartTokenBox" IsReadOnly="True" BorderThickness="0" Background="Transparent" FontFamily="Consolas" FontWeight="SemiBold"/>
                                    </Border>
                                    <TextBlock Text="Prévia" Style="{StaticResource CaptionTextStyle}" Margin="0,13,0,5"/>
                                    <Border Background="{DynamicResource SuccessSoftBrush}" BorderBrush="{DynamicResource SuccessBrush}" BorderThickness="1" CornerRadius="10" Padding="14" MinHeight="100">
                                        <TextBlock x:Name="SmartPreviewText" TextWrapping="Wrap" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryDarkBrush}"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource SoftCardStyle}" Padding="15" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="Exemplos disponíveis" FontWeight="SemiBold"/>
                                <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}">
                                    <Run Text="Data: "/><Run Text="[[DATA_DOCUMENTO:DATA=ABREV]]" FontFamily="Consolas"/>
                                    <Run Text="  → 22 ABR 26&#10;"/><Run Text="Valor: "/><Run Text="[[VALOR_DOCUMENTO:VALOR=AMBOS]]" FontFamily="Consolas"/>
                                    <Run Text="  → R$ 1.234,56 (mil duzentos e trinta e quatro reais...)"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                            <Button Content="Copiar marcador" Style="{StaticResource SecondaryButtonStyle}" Click="CopySmartToken_Click" Margin="0,0,8,0"/>
                            <Button Content="Adicionar / atualizar chave" Style="{StaticResource PrimaryButtonStyle}" Click="SaveSmartKey_Click"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="18,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="Cancelar" Style="{StaticResource GhostButtonStyle}" Click="Cancel_Click" Margin="0,0,8,0"/>
                <Button Content="Salvar chaves" Style="{StaticResource PrimaryButtonStyle}" Click="Save_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
