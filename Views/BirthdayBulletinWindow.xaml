<Window x:Class="SIGFUR.Wpf.Views.BirthdayBulletinWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Boletim — Aniversariantes" Width="1040" Height="700" MinWidth="820" MinHeight="560" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico" Tag="UiState.BoundsOnly">
    <Grid Margin="18">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Boletim dos Aniversariantes" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryDarkBrush}"/>
                <TextBlock Text="Edite o modelo, gere a prévia final e confira todo o texto antes de copiar. O marcador {ANIVERSARIANTES} pode ser movido."
                           Foreground="{DynamicResource MutedBrush}" Margin="0,4,0,12" TextWrapping="Wrap"/>
            </StackPanel>
            <Border Grid.Column="1" Background="{DynamicResource PrimarySurfaceBrush}" CornerRadius="10" Padding="12,8" VerticalAlignment="Center">
                <TextBlock x:Name="PreviewStatusText" Text="Prévia ainda não gerada" Foreground="{DynamicResource PrimaryDarkBrush}" FontWeight="SemiBold"/>
            </Border>
        </Grid>

        <TabControl x:Name="BulletinTabs" Grid.Row="1" Margin="0,4,0,0">
            <TabItem Header="1. Modelo editável">
                <Grid Margin="10">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Border Padding="10" Margin="0,0,0,8" CornerRadius="8" Background="{DynamicResource SurfaceAltBrush}">
                        <TextBlock Text="Altere o texto livremente. Ao modificar o modelo, gere novamente a prévia para atualizar o resultado."
                                   Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap"/>
                    </Border>
                    <TextBox x:Name="Editor" Grid.Row="1" AcceptsReturn="True" AcceptsTab="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                             VerticalContentAlignment="Top" HorizontalContentAlignment="Left"
                             FontFamily="Consolas" FontSize="13" TextChanged="Editor_TextChanged"/>
                </Grid>
            </TabItem>
            <TabItem x:Name="PreviewTab" Header="2. Prévia final">
                <Grid Margin="10">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Border Padding="10" Margin="0,0,0,8" CornerRadius="8" Background="#E8F5E9" BorderBrush="#43A047" BorderThickness="1">
                        <TextBlock Text="Este é o texto final que será copiado. Confira nomes, datas e ordem dos aniversariantes."
                                   Foreground="#1B5E20" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    </Border>
                    <FlowDocumentScrollViewer x:Name="Preview" Grid.Row="1" IsToolBarVisible="False"
                                              VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                              FontFamily="Arial" FontSize="14" Padding="12"/>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <Button Content="Salvar modelo" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" Click="SaveTemplate_Click"/>
                <Button Content="Restaurar modelo" Style="{StaticResource GhostButtonStyle}" Margin="0,0,8,0" Click="Restore_Click"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Gerar / atualizar prévia" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Click="GeneratePreview_Click"/>
                <Button x:Name="CopyButton" Content="Copiar texto conferido" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Click="Copy_Click" IsEnabled="False"/>
                <Button Content="Fechar" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
