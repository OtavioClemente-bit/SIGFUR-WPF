<Window x:Class="SIGFUR.Wpf.Views.AssistantChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Assistente SIGFUR" Width="1240" Height="820" MinWidth="980" MinHeight="680"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackgroundBrush}" Icon="/Assets/sigfur.ico">
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="290"/>
        </Grid.ColumnDefinitions>

        <!-- Painel esquerdo -->
        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="14">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <StackPanel>
                    <Border Width="54" Height="54" CornerRadius="16" Background="{DynamicResource PrimaryBrush}" HorizontalAlignment="Left">
                        <TextBlock Text="✦" Foreground="White" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="ASSISTENTE SIGFUR" Style="{StaticResource SectionTitleStyle}" Margin="0,12,0,2"/>
                    <TextBlock Text="Chat administrativo conectado aos dados locais autorizados." Style="{StaticResource CaptionTextStyle}"/>
                    <Border x:Name="ConnectionBadge" CornerRadius="10" Background="{DynamicResource SurfaceAltBrush}" Padding="9,6" Margin="0,12,0,0">
                        <TextBlock x:Name="ConnectionText" Text="Verificando API..." FontSize="10" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,16,0,0">
                    <Button Content="＋ Nova conversa" Style="{StaticResource PrimaryButtonStyle}" Click="NewConversation_Click" Margin="0,0,0,7"/>
                    <Button Content="⚙ Configurar API" Style="{StaticResource SecondaryButtonStyle}" Click="OpenSettings_Click"/>
                </StackPanel>

                <ScrollViewer Grid.Row="2" Margin="0,18,0,10" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="ATALHOS OPERACIONAIS" Style="{StaticResource MetricCaptionStyle}" Margin="2,0,0,8"/>
                        <Button Content="🏖 Consultar férias" Tag="Consulte as férias de [NOME DO MILITAR] no ano de [ANO]. Verifique os períodos cadastrados e, se houver, publicações relacionadas nos boletins." Style="{StaticResource GhostButtonStyle}" HorizontalContentAlignment="Left" Click="QuickPrompt_Click"/>
                        <Button Content="🗂 Pesquisar boletins" Tag="Pesquise nos boletins por [NOME DO MILITAR OU ASSUNTO] e organize as ocorrências por BI, data e página." Style="{StaticResource GhostButtonStyle}" HorizontalContentAlignment="Left" Click="QuickPrompt_Click"/>
                        <Button Content="💰 Orientação de pagamento" Tag="Preciso de uma orientação administrativa sobre pagamento: [DESCREVA O PROBLEMA]. Consulte os dados locais e a legislação indexada quando forem pertinentes. Não invente rubricas ou normas." Style="{StaticResource GhostButtonStyle}" HorizontalContentAlignment="Left" Click="QuickPrompt_Click"/>
                        <Button Content="📄 Gerar minuta de DIEx" Tag="Elabore uma minuta de DIEx sobre [ASSUNTO]. Finalidade: [FINALIDADE]. Destinatário: [DESTINATÁRIO]. Dados e fatos: [INFORME]. Use campos entre colchetes para tudo que estiver faltando e não invente referências." Style="{StaticResource GhostButtonStyle}" HorizontalContentAlignment="Left" Click="QuickPrompt_Click"/>
                        <Button Content="💬 Criar mensagem" Tag="Crie uma mensagem profissional e objetiva para [DESTINATÁRIO] informando: [CONTEÚDO]." Style="{StaticResource GhostButtonStyle}" HorizontalContentAlignment="Left" Click="QuickPrompt_Click"/>
                        <Button Content="🖨 Preparar impressão" Tag="Localize o arquivo gerado referente a [DOCUMENTO OU MILITAR] e prepare a impressão de [QUANTIDADE] cópia(s)." Style="{StaticResource GhostButtonStyle}" HorizontalContentAlignment="Left" Click="QuickPrompt_Click"/>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="3" Style="{StaticResource InsetCardStyle}" Padding="10">
                    <StackPanel>
                        <TextBlock Text="SEGURANÇA" Style="{StaticResource MetricCaptionStyle}"/>
                        <TextBlock x:Name="DataPermissionText" Text="Consultas locais: verificando" Style="{StaticResource CaptionTextStyle}" Margin="0,5,0,0"/>
                        <TextBlock Text="Impressão e alterações nunca são executadas sem confirmação." Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Área central -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <Border Style="{StaticResource CardStyle}" Background="{DynamicResource PrimarySurfaceBrush}" Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Conversa operacional" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock x:Name="ConversationSubtitle" Text="Pergunte sobre militares, férias, boletins, legislação, pagamento ou peça uma minuta." Style="{StaticResource CaptionTextStyle}" Margin="0,3,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Copiar última resposta" Style="{StaticResource GhostButtonStyle}" Click="CopyLastAnswer_Click" Margin="0,0,5,0"/>
                        <Button Content="Exportar DIEx" Style="{StaticResource SecondaryButtonStyle}" Click="ExportDiex_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl x:Name="WorkspaceTabs" Grid.Row="1" Margin="0,12" Background="Transparent" BorderThickness="0">
                <TabItem Header="Conversa">
                    <Grid Margin="0,8,0,0">
                <ListBox x:Name="ConversationList" Margin="0" ItemsSource="{Binding Messages}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,10"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="IsHitTestVisible" Value="True"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Border x:Name="Bubble" MaxWidth="780" HorizontalAlignment="Left" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="18" Padding="16">
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="{Binding RoleLabel}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource PrimaryDarkBrush}"/>
                                            <TextBlock Text="{Binding TimeLabel}" FontSize="9" Foreground="{DynamicResource SubtleTextBrush}" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="13" Margin="0,9,0,0"/>
                                        <ItemsControl ItemsSource="{Binding ActionLinks}" Margin="0,9,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Tag="{Binding}" Click="ExecuteAction_Click" Margin="0,0,8,7" Padding="10,5" Cursor="Hand" ToolTip="{Binding ConversationToolTip}" Background="{DynamicResource PrimarySurfaceBrush}" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1">
                                                        <TextBlock Text="{Binding ConversationLinkLabel}" Foreground="{DynamicResource PrimaryBrush}" TextDecorations="Underline" FontWeight="SemiBold" FontSize="11.5" TextWrapping="Wrap"/>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="{Binding AttachmentLabel}" TextWrapping="Wrap" FontSize="9" Foreground="{DynamicResource MutedBrush}" Margin="0,8,0,0" Visibility="{Binding AttachmentLabel, Converter={StaticResource StringToVisibility}}"/>
                                        <TextBlock Text="{Binding CostLabel}" FontSize="9" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,6,0,0" Visibility="{Binding CostLabel, Converter={StaticResource StringToVisibility}}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                    <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Right"/>
                                    <Setter TargetName="Bubble" Property="Background" Value="{DynamicResource PrimarySoftBrush}"/>
                                    <Setter TargetName="Bubble" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsError}" Value="True">
                                    <Setter TargetName="Bubble" Property="Background" Value="{DynamicResource DangerSoftBrush}"/>
                                    <Setter TargetName="Bubble" Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                    </Grid>
                </TabItem>
                <TabItem Header="Editor de DIEx / texto">
                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource InsetCardStyle}" Padding="10">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="190"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="EDITOR ADMINISTRATIVO" Style="{StaticResource MetricCaptionStyle}"/>
                                    <TextBlock Text="Cole um texto, selecione somente o trecho desejado e use a revisão da IA sem substituir o restante." Style="{StaticResource CaptionTextStyle}" Margin="0,4,12,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="RITEX DO OPERADOR" Style="{StaticResource MetricCaptionStyle}"/>
                                    <TextBox x:Name="RitexBox" Margin="0,4,0,0" LostFocus="RitexBox_LostFocus" ToolTip="Número usado no encerramento das minutas de DIEx."/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <WrapPanel Grid.Row="1" Margin="0,9,0,8">
                            <Button Content="Colar" Style="{StaticResource SecondaryButtonStyle}" Click="PasteDraft_Click" Margin="0,0,6,5"/>
                            <Button Content="Inserir última resposta" Style="{StaticResource SecondaryButtonStyle}" Click="InsertLastAnswer_Click" Margin="0,0,6,5"/>
                            <Button Content="✦ Corrigir seleção" Style="{StaticResource SecondaryButtonStyle}" Click="ReviewDraftSelection_Click" Margin="0,0,6,5"/>
                            <Button Content="✦ Linguagem administrativa" Style="{StaticResource SecondaryButtonStyle}" Click="FormalizeDraftSelection_Click" Margin="0,0,6,5"/>
                            <Button Content="Adicionar encerramento DIEx" Style="{StaticResource SecondaryButtonStyle}" Click="AddDiexClosing_Click" Margin="0,0,6,5"/>
                            <Button Content="Exportar Word" Style="{StaticResource PrimaryButtonStyle}" Click="ExportDiex_Click" Margin="0,0,0,5"/>
                        </WrapPanel>
                        <TextBox x:Name="DraftEditorBox" Grid.Row="2" AcceptsReturn="True" AcceptsTab="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="14"
                                 FontFamily="Arial" FontSize="12.5" SpellCheck.IsEnabled="True" Language="pt-BR"
                                 ToolTip="Clique com o botão direito para corretor ortográfico e revisão profissional com IA."/>
                        <TextBlock Grid.Row="3" Text="O corretor local sublinha palavras; o botão direito oferece sugestões, revisão com IA e substituição somente do trecho selecionado." Style="{StaticResource CaptionTextStyle}" Margin="2,7,0,0"/>
                    </Grid>
                </TabItem>
            </TabControl>

            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="12">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBox x:Name="PromptBox" MinHeight="82" MaxHeight="180" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Padding="11" KeyDown="PromptBox_KeyDown" ToolTip="Digite sua solicitação. Use Ctrl+Enter para enviar."/>
                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="AttachButton" Content="📎 Anexar" Style="{StaticResource SecondaryButtonStyle}" Click="Attach_Click" Margin="0,0,7,0"/>
                            <Button Content="Limpar texto" Style="{StaticResource GhostButtonStyle}" Click="ClearPrompt_Click"/>
                            <TextBlock Text="Ctrl+Enter para enviar" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="CancelButton" Content="Cancelar" Style="{StaticResource SecondaryButtonStyle}" Click="CancelRequest_Click" Visibility="Collapsed" Margin="0,0,7,0"/>
                            <Button x:Name="SendButton" Content="Enviar" Style="{StaticResource PrimaryButtonStyle}" Click="Send_Click" MinWidth="105"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border x:Name="BusyOverlay" Grid.RowSpan="3" Background="{DynamicResource OverlayBrush}" Visibility="Collapsed" Panel.ZIndex="20">
                <Border Style="{StaticResource CardStyle}" Width="390" Padding="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel>
                        <ProgressBar IsIndeterminate="True" Height="8"/>
                        <TextBlock Text="Consultando o Assistente SIGFUR" Style="{StaticResource SectionTitleStyle}" Margin="0,15,0,4" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="BusyText" Text="Analisando sua solicitação e consultando as fontes autorizadas..." Style="{StaticResource CaptionTextStyle}" TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>

        <!-- Contexto direito -->
        <Grid Grid.Column="4">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <Border Style="{StaticResource CardStyle}" Padding="14">
                <StackPanel>
                    <Grid>
                        <TextBlock Text="CONSUMO ESTIMADO" Style="{StaticResource MetricCaptionStyle}"/>
                        <TextBlock x:Name="UsageRequestText" Text="0 solicitações" HorizontalAlignment="Right" Style="{StaticResource SubtleTextStyle}"/>
                    </Grid>
                    <TextBlock x:Name="UsageValueText" Text="R$ 0,00 de R$ 10,00" Style="{StaticResource MetricValueStyle}" FontSize="20"/>
                    <ProgressBar x:Name="UsageProgress" Minimum="0" Maximum="100" Value="0" Margin="0,8,0,0"/>
                    <TextBlock x:Name="UsageTokensText" Text="0 tokens de entrada • 0 de saída" Style="{StaticResource CaptionTextStyle}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1" Margin="0,12" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource CardStyle}" Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="ANEXOS" Style="{StaticResource MetricCaptionStyle}"/>
                                <Button Content="Limpar" Style="{StaticResource GhostButtonStyle}" Padding="7,3" HorizontalAlignment="Right" Click="ClearAttachments_Click"/>
                            </Grid>
                            <TextBlock Text="O conteúdo é extraído localmente e enviado somente junto da pergunta." Style="{StaticResource CaptionTextStyle}" Margin="0,5,0,9"/>
                            <ItemsControl ItemsSource="{Binding Attachments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource InsetCardStyle}" Padding="9" Margin="0,0,0,7">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" ToolTip="{Binding Path}"/>
                                                    <TextBlock Text="{Binding SizeLabel}" Style="{StaticResource SubtleTextStyle}"/>
                                                    <TextBlock Text="{Binding Status}" Style="{StaticResource CaptionTextStyle}"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="✕" Tag="{Binding}" Style="{StaticResource GhostButtonStyle}" Padding="5" Click="RemoveAttachment_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="NoAttachmentsText" Text="Nenhum arquivo anexado." Style="{StaticResource CaptionTextStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Padding="14">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="AÇÕES PENDENTES" Style="{StaticResource MetricCaptionStyle}"/>
                                <Button Content="Limpar ações" Style="{StaticResource GhostButtonStyle}" Padding="7,3" HorizontalAlignment="Right" Click="ClearActions_Click"/>
                            </Grid>
                            <TextBlock Text="Somente o operador executa. O Assistente apenas deixa links seguros para clique." Style="{StaticResource CaptionTextStyle}" Margin="0,5,0,0"/>
                            <TextBlock x:Name="NoActionsText" Text="Nenhum link/ação disponível para esta resposta." Style="{StaticResource CaptionTextStyle}" Margin="0,6,0,0"/>
                            <ItemsControl ItemsSource="{Binding PendingActions}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource InsetCardStyle}" Padding="11" Margin="0,0,0,9">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Description}" Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,8" TextWrapping="Wrap"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <Button Content="{Binding PrimaryButtonLabel}" Tag="{Binding}" Style="{StaticResource PrimaryButtonStyle}" Click="ExecuteAction_Click"/>
                                                    <Button Grid.Column="2" Content="Copiar caminho" Tag="{Binding}" IsEnabled="{Binding HasFilePath}" Style="{StaticResource SecondaryButtonStyle}" Click="CopyActionPath_Click"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Style="{StaticResource InsetCardStyle}" Padding="11">
                <StackPanel>
                    <TextBlock x:Name="LastToolText" Text="As fontes consultadas aparecerão aqui." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap"/>
                    <Button Content="Abrir pasta de documentos" Style="{StaticResource GhostButtonStyle}" HorizontalAlignment="Left" Margin="0,6,0,0" Click="OpenExports_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
