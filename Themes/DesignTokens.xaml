<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
      Estes são os únicos tokens visuais que precisam mudar para recolorir todo o SIGFUR WPF.
      O ThemeService altera estes recursos em tempo de execução e salva a escolha no AppData.
    -->
    <Color x:Key="PrimaryColor">#1565C0</Color>
    <Color x:Key="PrimaryHoverColor">#0F59AD</Color>
    <Color x:Key="PrimaryPressedColor">#0B4A91</Color>
    <Color x:Key="PrimaryDarkColor">#0B3D91</Color>
    <Color x:Key="PrimaryDarkerColor">#072A66</Color>
    <Color x:Key="PrimarySoftColor">#E8F2FD</Color>
    <Color x:Key="PrimarySurfaceColor">#F3F8FE</Color>
    <Color x:Key="AccentColor">#4DA3F5</Color>

    <Color x:Key="AppBackgroundColor">#EEF3F8</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceElevatedColor">#FFFFFF</Color>
    <Color x:Key="SurfaceAltColor">#F7F9FC</Color>
    <Color x:Key="SurfaceHoverColor">#F0F5FA</Color>
    <Color x:Key="BorderColor">#DCE5EF</Color>
    <Color x:Key="BorderStrongColor">#C8D6E5</Color>
    <Color x:Key="DividerColor">#E8EEF5</Color>

    <Color x:Key="TextColor">#102A43</Color>
    <Color x:Key="MutedColor">#61758A</Color>
    <Color x:Key="SubtleTextColor">#8294A6</Color>
    <Color x:Key="TextOnPrimaryColor">#FFFFFF</Color>
    <Color x:Key="TextOnPrimaryMutedColor">#D7EAFE</Color>

    <Color x:Key="SuccessColor">#2E7D32</Color>
    <Color x:Key="SuccessSoftColor">#EAF6EC</Color>
    <Color x:Key="WarningColor">#E58A00</Color>
    <Color x:Key="WarningSoftColor">#FFF4D8</Color>
    <Color x:Key="DangerColor">#C62828</Color>
    <Color x:Key="DangerSoftColor">#FDECEC</Color>
    <Color x:Key="InfoColor">#1976D2</Color>
    <Color x:Key="InfoSoftColor">#E8F3FD</Color>

    <Color x:Key="SidebarColor">#0B315F</Color>
    <Color x:Key="SidebarHoverColor">#134578</Color>
    <Color x:Key="SidebarSelectedColor">#1C5C98</Color>
    <Color x:Key="SidebarTextColor">#F4F9FF</Color>
    <Color x:Key="SidebarMutedColor">#B8D2EB</Color>
    <Color x:Key="OverlayColor">#99081726</Color>
    <Color x:Key="ShadowColor">#20384F</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{DynamicResource PrimaryHoverColor}"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="{DynamicResource PrimaryPressedColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{DynamicResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkerBrush" Color="{DynamicResource PrimaryDarkerColor}"/>
    <SolidColorBrush x:Key="PrimarySoftBrush" Color="{DynamicResource PrimarySoftColor}"/>
    <SolidColorBrush x:Key="PrimarySurfaceBrush" Color="{DynamicResource PrimarySurfaceColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}"/>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{DynamicResource AppBackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{DynamicResource SurfaceElevatedColor}"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource SurfaceAltColor}"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{DynamicResource SurfaceHoverColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{DynamicResource BorderStrongColor}"/>
    <SolidColorBrush x:Key="DividerBrush" Color="{DynamicResource DividerColor}"/>

    <SolidColorBrush x:Key="TextBrush" Color="{DynamicResource TextColor}"/>
    <SolidColorBrush x:Key="MutedBrush" Color="{DynamicResource MutedColor}"/>
    <SolidColorBrush x:Key="SubtleTextBrush" Color="{DynamicResource SubtleTextColor}"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="{DynamicResource TextOnPrimaryColor}"/>
    <SolidColorBrush x:Key="TextOnPrimaryMutedBrush" Color="{DynamicResource TextOnPrimaryMutedColor}"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource SuccessColor}"/>
    <SolidColorBrush x:Key="SuccessSoftBrush" Color="{DynamicResource SuccessSoftColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{DynamicResource WarningColor}"/>
    <SolidColorBrush x:Key="WarningSoftBrush" Color="{DynamicResource WarningSoftColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{DynamicResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerSoftBrush" Color="{DynamicResource DangerSoftColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{DynamicResource InfoColor}"/>
    <SolidColorBrush x:Key="InfoSoftBrush" Color="{DynamicResource InfoSoftColor}"/>

    <SolidColorBrush x:Key="SidebarBrush" Color="{DynamicResource SidebarColor}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{DynamicResource SidebarHoverColor}"/>
    <SolidColorBrush x:Key="SidebarSelectedBrush" Color="{DynamicResource SidebarSelectedColor}"/>
    <SolidColorBrush x:Key="SidebarTextBrush" Color="{DynamicResource SidebarTextColor}"/>
    <SolidColorBrush x:Key="SidebarMutedBrush" Color="{DynamicResource SidebarMutedColor}"/>
    <SolidColorBrush x:Key="OverlayBrush" Color="{DynamicResource OverlayColor}"/>
    <SolidColorBrush x:Key="ShadowBrush" Color="{DynamicResource ShadowColor}"/>

    <LinearGradientBrush x:Key="PrimaryGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{DynamicResource PrimaryDarkerColor}" Offset="0"/>
        <GradientStop Color="{DynamicResource PrimaryDarkColor}" Offset="0.48"/>
        <GradientStop Color="{DynamicResource PrimaryColor}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="HeroGlowBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#00FFFFFF" Offset="0"/>
        <GradientStop Color="#24FFFFFF" Offset="1"/>
    </LinearGradientBrush>
</ResourceDictionary>
