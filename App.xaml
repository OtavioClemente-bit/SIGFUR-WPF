<Application x:Class="SIGFUR.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SIGFUR.Wpf.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DesignTokens.xaml"/>
                <ResourceDictionary Source="Themes/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
            <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <conv:StringToVisibilityConverter x:Key="StringToVisibility"/>
            <conv:HexColorToBrushConverter x:Key="HexColorToBrush"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
